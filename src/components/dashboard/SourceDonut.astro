---
---
<div class="rounded-2xl border border-base-300 bg-base-200 p-3">
  <div class="flex items-center justify-between mb-1">
    <h3 class="text-xs uppercase tracking-wider opacity-70">Lead Sources</h3>
    <span class="text-[10px] opacity-50">attribution</span>
  </div>
  <div id="chart-source" class="min-h-[220px]"></div>
</div>

<script>
  import { subscribe, getState } from '../../scripts/dashboard/store';
  import { waitForApex, baseOptions, PALETTE } from '../../scripts/dashboard/charts';

  let chart: any = null;

  function dataFromState() {
    const leads = getState().leads || [];
    const tally: Record<string, number> = {};
    for (const l of leads) {
      const src = (l.manual_source as string) || (l.source as string) || 'intake-form';
      tally[src] = (tally[src] || 0) + 1;
    }
    const sorted = Object.entries(tally).sort((a, b) => b[1] - a[1]).slice(0, 6);
    return {
      labels: sorted.map((e) => e[0] || 'unknown'),
      vals: sorted.map((e) => e[1]),
    };
  }

  async function init() {
    const ApexCharts = await waitForApex();
    const el = document.getElementById('chart-source');
    if (!el || !ApexCharts) return;
    const d = dataFromState();
    const opts = {
      ...baseOptions(),
      series: d.vals.length ? d.vals : [1],
      labels: d.labels.length ? d.labels : ['no data'],
      chart: { ...baseOptions().chart, type: 'donut', height: 240 },
      colors: [PALETTE.violet, PALETTE.cyan, PALETTE.emerald, PALETTE.amber, PALETTE.coral, PALETTE.rose],
      plotOptions: {
        pie: {
          donut: {
            size: '68%',
            labels: {
              show: true,
              name: { fontSize: '11px', color: '#94a3b8' },
              value: { fontSize: '20px', color: '#f1f5f9', fontWeight: 600 },
              total: {
                show: true,
                label: 'Total',
                fontSize: '11px',
                color: '#94a3b8',
                formatter: (w: any) => String(w.globals.seriesTotals.reduce((a: number, b: number) => a + b, 0)),
              },
            },
          },
        },
      },
      legend: { ...baseOptions().legend, position: 'bottom' },
    };
    chart = new ApexCharts(el, opts);
    chart.render();
  }

  function update() {
    if (!chart) return;
    const d = dataFromState();
    chart.updateOptions({ labels: d.labels.length ? d.labels : ['no data'] });
    chart.updateSeries(d.vals.length ? d.vals : [1]);
  }

  init();
  subscribe(update);
</script>
