---
---
<section id="pin-gate" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-base-100 px-6">
  <div class="flex flex-col items-center gap-8 w-full max-w-xs">
    <div class="text-center">
      <div class="w-14 h-14 rounded-2xl bg-primary flex items-center justify-center mx-auto mb-4">
        <span class="text-primary-content text-2xl font-bold">P</span>
      </div>
      <h1 class="text-xl font-display font-semibold">Dashboard</h1>
      <p class="text-sm opacity-60 mt-1">ใส่ PIN 6 หลักเพื่อเข้าใช้งาน</p>
    </div>

    <!-- Dot indicators -->
    <div id="pin-dots" class="flex gap-4" aria-hidden="true">
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="0"></div>
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="1"></div>
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="2"></div>
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="3"></div>
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="4"></div>
      <div class="pin-dot w-4 h-4 rounded-full border-2 border-base-content/40" data-index="5"></div>
    </div>

    <!-- Error message -->
    <div id="pin-error" class="text-error text-sm min-h-[1.25rem] text-center -mt-4" role="alert" aria-live="polite"></div>

    <!-- Number keypad -->
    <div id="pin-keypad" class="grid grid-cols-3 gap-3 w-full">
      {[1,2,3,4,5,6,7,8,9].map(n => (
        <button
          class="pin-key btn btn-ghost text-xl font-semibold h-16 rounded-2xl border border-base-300 active:scale-95 transition-transform"
          data-digit={String(n)}
          aria-label={String(n)}
        >{n}</button>
      ))}
      <div></div>
      <button
        class="pin-key btn btn-ghost text-xl font-semibold h-16 rounded-2xl border border-base-300 active:scale-95 transition-transform"
        data-digit="0"
        aria-label="0"
      >0</button>
      <button
        id="pin-delete"
        class="btn btn-ghost h-16 rounded-2xl border border-base-300 active:scale-95 transition-transform"
        aria-label="ลบ"
      >⌫</button>
    </div>

    <!-- Hidden input for accessibility / physical keyboard -->
    <input
      id="pin-input"
      type="password"
      inputmode="numeric"
      autocomplete="off"
      maxlength="6"
      pattern="[0-9]*"
      class="sr-only"
      aria-label="PIN"
    />
  </div>
</section>

<script>
  import { tryLogin, subscribe, getState } from '../../scripts/dashboard/store';

  function applyAuthVisibility() {
    const gate = document.getElementById('pin-gate');
    const app = document.getElementById('dashboard-app');
    const authed = getState().authed;
    if (gate) gate.classList.toggle('hidden', authed);
    if (app) app.classList.toggle('hidden', !authed);
  }

  applyAuthVisibility();
  subscribe(applyAuthVisibility);

  const errEl = document.getElementById('pin-error');
  const hiddenInput = document.getElementById('pin-input') as HTMLInputElement | null;
  let pinBuffer = '';
  let submitting = false;

  function updateDots() {
    document.querySelectorAll<HTMLElement>('.pin-dot').forEach((dot, i) => {
      const filled = i < pinBuffer.length;
      dot.classList.toggle('bg-primary', filled);
      dot.classList.toggle('border-primary', filled);
      dot.classList.toggle('border-base-content/40', !filled);
    });
  }

  function shakeError() {
    const dots = document.getElementById('pin-dots');
    dots?.classList.add('animate-[shake_0.35s_ease-in-out]');
    setTimeout(() => dots?.classList.remove('animate-[shake_0.35s_ease-in-out]'), 400);
  }

  async function submitPin() {
    if (submitting || pinBuffer.length !== 6) return;
    submitting = true;
    if (errEl) errEl.textContent = '';
    try {
      await tryLogin(pinBuffer);
      pinBuffer = '';
      updateDots();
    } catch (err) {
      const e = err as Error & { code?: string };
      if (e.code === 'locked') {
        if (errEl) errEl.textContent = 'ถูกล็อก 15 นาที — ลองใหม่ภายหลัง';
      } else {
        if (errEl) errEl.textContent = 'PIN ไม่ถูกต้อง';
      }
      shakeError();
      pinBuffer = '';
      updateDots();
    } finally {
      submitting = false;
    }
  }

  function pushDigit(d: string) {
    if (submitting || pinBuffer.length >= 6) return;
    pinBuffer += d;
    updateDots();
    if (pinBuffer.length === 6) void submitPin();
  }

  function popDigit() {
    if (submitting || !pinBuffer.length) return;
    pinBuffer = pinBuffer.slice(0, -1);
    if (errEl) errEl.textContent = '';
    updateDots();
  }

  document.querySelectorAll<HTMLButtonElement>('.pin-key').forEach((btn) => {
    btn.addEventListener('click', () => pushDigit(btn.dataset.digit || ''));
  });
  document.getElementById('pin-delete')?.addEventListener('click', popDigit);

  // Physical keyboard support
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (getState().authed) return;
    if (/^\d$/.test(e.key)) { e.preventDefault(); pushDigit(e.key); }
    else if (e.key === 'Backspace') { e.preventDefault(); popDigit(); }
  });

  updateDots();
</script>
