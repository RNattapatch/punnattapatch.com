---
interface Props {
  id: string;
  label: string;
  accent?: 'cyan' | 'coral' | 'violet' | 'emerald';
}
const { id, label, accent = 'cyan' } = Astro.props;
const ring = {
  cyan: 'ring-1 ring-[color:var(--color-pun-cyan)]/40',
  coral: 'ring-1 ring-[color:var(--color-pun-coral)]/40',
  violet: 'ring-1 ring-[color:var(--color-pun-violet)]/40',
  emerald: 'ring-1 ring-[color:var(--color-pun-emerald)]/40',
}[accent];
---
<div class={`card bg-base-200 border border-base-300 ${ring}`}>
  <div class="card-body p-4 gap-1">
    <div class="text-xs uppercase tracking-wider opacity-70">{label}</div>
    <div id={id} class="text-2xl font-display leading-tight">—</div>
    <div id={`${id}-sub`} class="text-xs opacity-70 min-h-[1rem]"></div>
  </div>
</div>
