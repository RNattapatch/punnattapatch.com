---
interface Props {
  id: string;
  label: string;
  accent?: 'cyan' | 'coral' | 'violet' | 'emerald' | 'warning' | 'info';
}
const { id, label, accent = 'cyan' } = Astro.props;
const colorVar = {
  cyan: 'var(--color-pun-cyan)',
  coral: 'var(--color-pun-coral)',
  violet: 'var(--color-pun-violet)',
  emerald: 'var(--color-pun-emerald)',
  warning: 'var(--color-warning)',
  info: 'var(--color-info)',
}[accent];
---
<div class="relative overflow-hidden rounded-xl border border-base-300 bg-base-200 px-3 py-3 pl-4">
  <div class="absolute inset-y-0 left-0 w-1" style={`background-color: ${colorVar};`}></div>
  <div class="text-[10px] uppercase tracking-wider opacity-60 mb-0.5 truncate">{label}</div>
  <div id={id} class="text-2xl md:text-3xl font-display font-semibold leading-none tabular-nums" style={`color: ${colorVar};`}>—</div>
  <div id={`${id}-sub`} class="text-[11px] opacity-60 mt-1 min-h-[1rem] truncate"></div>
</div>
