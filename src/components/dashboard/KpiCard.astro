---
interface Props {
  id: string;
  label: string;
  accent?: 'cyan' | 'coral' | 'violet' | 'emerald' | 'warning' | 'info';
}
const { id, label, accent = 'cyan' } = Astro.props;
const colorVar = {
  cyan: 'var(--color-pun-cyan)',
  coral: 'var(--color-pun-coral)',
  violet: 'var(--color-pun-violet)',
  emerald: 'var(--color-pun-emerald)',
  warning: 'var(--color-warning)',
  info: 'var(--color-info)',
}[accent];
---
<div class="card rounded-3xl border border-base-300 bg-base-200 shadow-sm">
  <div class="card-body p-4 md:p-5">
    <div class="flex items-start justify-between gap-2">
      <p class="text-xs opacity-60 uppercase tracking-wider leading-tight">{label}</p>
      <span id={`${id}-badge`} class="shrink-0"></span>
    </div>
    <div id={id} class="text-2xl md:text-3xl font-display font-semibold tabular-nums mt-2 leading-none" style={`color: ${colorVar};`}>—</div>
    <div id={`${id}-sub`} class="text-[11px] opacity-50 mt-1 min-h-[1rem] truncate"></div>
  </div>
</div>
