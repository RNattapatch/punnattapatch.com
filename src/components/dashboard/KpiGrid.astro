---
import KpiCard from './KpiCard.astro';
---
<section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-2 md:gap-3 mb-4">
  <KpiCard id="kpi-sales-total" label="ยอดขายรวม" accent="emerald" />
  <KpiCard id="kpi-sales-month" label="ยอดเดือนนี้" accent="coral" />
  <KpiCard id="kpi-leads" label="Leads ทั้งหมด" accent="violet" />
  <KpiCard id="kpi-pipeline" label="In Pipeline" accent="warning" />
  <KpiCard id="kpi-conversion" label="Conversion" accent="cyan" />
  <KpiCard id="kpi-industry" label="Top อุตสาหกรรม" accent="info" />
</section>

<script>
  import { subscribe, getState } from '../../scripts/dashboard/store';

  function fmtTHB(n: number): string {
    if (!n) return '฿0';
    if (n >= 1_000_000) return `฿${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1_000) return `฿${(n / 1_000).toFixed(0)}K`;
    return `฿${n}`;
  }
  function fmtPct(n: number): string {
    if (!Number.isFinite(n)) return '—';
    const v = Math.round(n * 1000) / 10;
    const sign = v > 0 ? '+' : '';
    return `${sign}${v.toFixed(1)}%`;
  }
  function setText(id: string, txt: string) {
    const el = document.getElementById(id); if (el) el.textContent = txt;
  }

  function render() {
    const k = getState().kpis;
    if (!k) return;
    setText('kpi-sales-total', fmtTHB(k.sales_total));
    setText('kpi-sales-total-sub', `ก่อนหน้า ${fmtTHB(k.sales_prev_month)}`);

    setText('kpi-sales-month', fmtTHB(k.sales_this_month));
    setText('kpi-sales-month-sub', `Δ ${fmtPct(k.sales_delta_pct)}`);

    setText('kpi-leads', String(k.leads_total));
    setText('kpi-leads-sub', `เดือนนี้ +${k.leads_this_month}`);

    setText('kpi-pipeline', String(k.pipeline.in_progress));
    setText('kpi-pipeline-sub', `prop ${k.pipeline.proposal_sent} · walk ${k.pipeline.walkthrough_done}`);

    setText('kpi-conversion', fmtPct(k.conversion_rate));
    setText('kpi-conversion-sub', `won ${k.pipeline.won}`);

    const top = k.top_industry || [];
    setText('kpi-industry', top[0]?.label || '—');
    setText('kpi-industry-sub', top[0] ? `${top[0].count} leads` : '');
  }

  render();
  subscribe(render);
</script>
