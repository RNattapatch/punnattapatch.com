---
import KpiCard from './KpiCard.astro';
---
<section class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-3 mb-4">
  <KpiCard id="kpi-sales-total" label="ยอดขายรวม" accent="emerald" />
  <KpiCard id="kpi-sales-month" label="ยอดเดือนนี้" accent="coral" />
  <KpiCard id="kpi-leads" label="Leads ทั้งหมด" accent="violet" />
  <KpiCard id="kpi-pipeline" label="In Pipeline" accent="warning" />
  <KpiCard id="kpi-conversion" label="Conversion" accent="cyan" />
  <KpiCard id="kpi-industry" label="Top อุตสาหกรรม" accent="info" />
  <KpiCard id="kpi-expense-month" label="ค่าใช้จ่ายเดือนนี้" accent="coral" />
  <KpiCard id="kpi-net-revenue" label="Net Revenue เดือนนี้" accent="emerald" />
</section>

<script>
  import { subscribe, getState } from '../../scripts/dashboard/store';

  function fmtTHB(n: number): string {
    if (!n) return '฿0';
    if (n >= 1_000_000) return `฿${(n / 1_000_000).toFixed(1)}M`;
    if (n >= 1_000) return `฿${(n / 1_000).toFixed(0)}K`;
    return `฿${n}`;
  }
  function fmtPct(n: number): string {
    if (!Number.isFinite(n)) return '—';
    const v = Math.round(n * 1000) / 10;
    const sign = v > 0 ? '+' : '';
    return `${sign}${v.toFixed(1)}%`;
  }
  function setText(id: string, txt: string) {
    const el = document.getElementById(id); if (el) el.textContent = txt;
  }

  function render() {
    const { kpis, expenseSummary } = getState();
    if (!kpis) return;
    setText('kpi-sales-total', fmtTHB(kpis.sales_total));
    setText('kpi-sales-total-sub', `ก่อนหน้า ${fmtTHB(kpis.sales_prev_month)}`);

    setText('kpi-sales-month', fmtTHB(kpis.sales_this_month));
    setText('kpi-sales-month-sub', `เทียบเดือนก่อน ${fmtTHB(kpis.sales_prev_month)}`);
    const deltaEl = document.getElementById('kpi-sales-month-badge');
    if (deltaEl) {
      const d = kpis.sales_delta_pct;
      const positive = d >= 0;
      deltaEl.textContent = fmtPct(d);
      deltaEl.className = `badge badge-sm border-0 ${positive ? 'bg-success/20 text-success' : 'bg-error/20 text-error'}`;
    }

    setText('kpi-leads', String(kpis.leads_total));
    setText('kpi-leads-sub', `เดือนนี้ +${kpis.leads_this_month}`);

    setText('kpi-pipeline', String(kpis.pipeline.in_progress));
    setText('kpi-pipeline-sub', `prop ${kpis.pipeline.proposal_sent} · walk ${kpis.pipeline.walkthrough_done}`);

    setText('kpi-conversion', fmtPct(kpis.conversion_rate));
    setText('kpi-conversion-sub', `won ${kpis.pipeline.won}`);

    const top = kpis.top_industry || [];
    setText('kpi-industry', top[0]?.label || '—');
    setText('kpi-industry-sub', top[0] ? `${top[0].count} leads` : '');

    const expMonth = expenseSummary?.this_month_thb ?? 0;
    setText('kpi-expense-month', fmtTHB(expMonth));
    setText('kpi-expense-month-sub', expenseSummary ? `รวมทั้งหมด ${fmtTHB(expenseSummary.total_thb)}` : '—');

    const netRev = kpis.sales_this_month - expMonth;
    setText('kpi-net-revenue', fmtTHB(netRev));
    setText('kpi-net-revenue-sub', `ยอดขาย ${fmtTHB(kpis.sales_this_month)} − ค่าใช้จ่าย ${fmtTHB(expMonth)}`);
  }

  render();
  subscribe(render);
</script>
