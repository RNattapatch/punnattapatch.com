---
---
<div class="drawer-side z-40">
  <label for="dash-sidebar-toggle" aria-label="ปิด sidebar" class="drawer-overlay"></label>
  <aside class="min-h-full w-72 border-r border-base-300 bg-base-100 p-4 flex flex-col">

    <!-- Brand header -->
    <div class="mb-6 rounded-3xl p-5" style="background-color:var(--color-brand-navy);">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-white/20 grid place-items-center font-bold text-white text-lg">P</div>
        <div>
          <p class="text-base font-bold text-white">Pun Nattapatch</p>
          <p class="text-xs text-white/60">AI Consultant</p>
        </div>
      </div>
      <p class="mt-3 text-xs text-white/50">Internal dashboard · Private</p>
    </div>

    <!-- Nav links -->
    <ul class="menu gap-1 text-base flex-1">
      <li>
        <a id="nav-dashboard" class="rounded-2xl font-medium" style="background-color:var(--color-brand-navy);color:white;" href="#">
          <svg class="w-4 h-4 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5zm10 0a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1V5zM4 15a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-4zm10 0a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1v-4z"/></svg>
          Dashboard
        </a>
      </li>
      <li>
        <a id="nav-leads" class="rounded-2xl" href="#" data-scroll-to="leads-view">
          <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 0 0-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 0 1 5.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 0 1 9.288 0"/></svg>
          Leads
        </a>
      </li>
      <li>
        <a id="nav-pipeline" class="rounded-2xl" href="#" data-scroll-to="kanban-section">
          <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m0 10a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 7a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m0 10V7m0 10a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2"/></svg>
          Sales Pipeline
        </a>
      </li>
      <li>
        <a id="nav-expenses" class="rounded-2xl" href="#" data-tab="expenses">
          <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2m2 4h10a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2zm7-5a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/></svg>
          Expenses
        </a>
      </li>
    </ul>

    <!-- Bottom actions -->
    <div class="pt-4 border-t border-base-300">
      <button id="sidebar-logout" class="btn btn-ghost btn-sm w-full justify-start gap-2 rounded-2xl opacity-60 hover:opacity-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1"/></svg>
        ออกจากระบบ
      </button>
    </div>
  </aside>
</div>

<script>
  import { logout, switchTab } from '../../scripts/dashboard/store';

  document.getElementById('sidebar-logout')?.addEventListener('click', () => logout());

  document.querySelectorAll<HTMLAnchorElement>('[data-scroll-to]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.getElementById(a.dataset.scrollTo || '');
      target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      (document.getElementById('dash-sidebar-toggle') as HTMLInputElement | null)?.click();
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('[data-tab]').forEach((a) => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      switchTab(a.dataset.tab as 'leads' | 'expenses');
      (document.getElementById('dash-sidebar-toggle') as HTMLInputElement | null)?.click();
    });
  });
</script>
