<section class="mb-3">
  <h3 class="text-xs uppercase tracking-wider opacity-70 mb-1">Notes</h3>
  <textarea id="notes-textarea" rows="4" class="textarea textarea-bordered w-full tap-44" placeholder="memo อิสระ..." autocomplete="off"></textarea>
  <div class="text-xs opacity-60 mt-1">กดปุ่ม "บันทึก" ด้านล่าง drawer เพื่อ save</div>
</section>

<script>
  import { subscribe, getState } from '../../scripts/dashboard/store';

  function apply() {
    const lead = getState().selectedLead;
    const ta = document.getElementById('notes-textarea') as HTMLTextAreaElement | null;
    if (!ta || !lead) return;
    if (document.activeElement === ta) return; // don't clobber while typing
    ta.value = (lead.crm_notes as string) || '';
  }

  apply();
  subscribe(apply);
  // Save is triggered by the drawer's bottom "บันทึก" button — see LeadDetailDrawer.astro.
</script>
