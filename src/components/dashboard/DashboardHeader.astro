---
---
<header class="sticky top-0 z-30 border-b border-base-300 bg-base-100/90 backdrop-blur">
  <div class="navbar px-4 lg:px-6 min-h-14">

    <!-- Hamburger (mobile) -->
    <div class="flex-none lg:hidden">
      <label for="dash-sidebar-toggle" class="btn btn-square btn-ghost btn-sm tap-44" aria-label="เมนู">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </label>
    </div>

    <!-- Brand -->
    <div class="flex-1 min-w-0 ml-2 lg:ml-0">
      <h1 class="font-display text-base font-bold leading-tight truncate" style="color:var(--color-pun-cyan)">Pun Nattapatch</h1>
      <p class="text-xs opacity-50 leading-tight hidden sm:block">AI Agent Workspace</p>
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-2 shrink-0">
      <p id="dash-meta" class="hidden md:block text-xs opacity-40 tabular-nums">—</p>
      <button id="dash-refresh" class="btn btn-sm btn-ghost tap-44" aria-label="Refresh">↻</button>
      <button id="dash-add-lead-header" class="btn btn-sm rounded-2xl tap-44" style="background-color:var(--color-brand-navy);color:white;">
        + Add Lead
      </button>
    </div>
  </div>
</header>

<script>
  import { refresh, logout, subscribe, getState, emit } from '../../scripts/dashboard/store';

  function relTime(iso: string | null): string {
    if (!iso) return '—';
    const ms = Date.now() - new Date(iso).getTime();
    if (!Number.isFinite(ms)) return '—';
    const s = Math.floor(ms / 1000);
    if (s < 60) return `อัปเดต ${s} วิที่แล้ว`;
    const m = Math.floor(s / 60);
    if (m < 60) return `อัปเดต ${m} นาทีที่แล้ว`;
    const h = Math.floor(m / 60);
    if (h < 24) return `อัปเดต ${h} ชม.ที่แล้ว`;
    return `อัปเดต ${new Date(iso).toLocaleString('th-TH')}`;
  }

  function render() {
    const meta = document.getElementById('dash-meta');
    if (!meta) return;
    const s = getState();
    meta.textContent = relTime(s.generatedAt);
  }

  render();
  subscribe(render);
  setInterval(render, 30000);

  document.getElementById('dash-refresh')?.addEventListener('click', () => void refresh());
  document.getElementById('dash-add-lead-header')?.addEventListener('click', () => emit('modal:add-lead'));
</script>
