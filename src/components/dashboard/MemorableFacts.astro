---
---
<section class="mb-3">
  <h3 class="text-xs uppercase tracking-wider opacity-70 mb-1">Memorable facts</h3>
  <div class="grid gap-2">
    <input id="mf-nickname" class="input input-bordered input-sm tap-44" placeholder="Nickname" autocomplete="off" />
    <input id="mf-fact-1" class="input input-bordered input-sm tap-44" placeholder="Fact #1" autocomplete="off" />
    <input id="mf-fact-2" class="input input-bordered input-sm tap-44" placeholder="Fact #2" autocomplete="off" />
    <input id="mf-fact-3" class="input input-bordered input-sm tap-44" placeholder="Fact #3" autocomplete="off" />
  </div>
</section>

<script>
  import { subscribe, getState } from '../../scripts/dashboard/store';

  const fields: Array<[string, string]> = [
    ['mf-nickname', 'nickname'],
    ['mf-fact-1', 'fact_1'],
    ['mf-fact-2', 'fact_2'],
    ['mf-fact-3', 'fact_3'],
  ];

  function apply() {
    const lead = getState().selectedLead;
    if (!lead) return;
    for (const [id, key] of fields) {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (!el) continue;
      if (document.activeElement === el) continue; // don't clobber user input
      el.value = ((lead as Record<string, unknown>)[key] as string) || '';
    }
  }

  apply();
  subscribe(apply);
  // Save is triggered by the drawer's bottom "บันทึก" button — see LeadDetailDrawer.astro.
</script>
