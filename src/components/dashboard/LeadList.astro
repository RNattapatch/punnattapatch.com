---
import LeadCard from './LeadCard.astro';
---
<section class="mb-20">
  <div class="flex items-center justify-between mb-3 gap-2">
    <h2 class="font-display text-base">Leads</h2>
    <span id="lead-total" class="text-xs opacity-60"></span>
  </div>

  <div class="flex gap-2 mb-3">
    <input
      id="lead-search"
      type="search"
      placeholder="ค้นชื่อ บริษัท เบอร์..."
      class="input input-bordered input-sm flex-1 tap-44"
      autocomplete="off"
    />
    <select id="lead-sort" class="select select-bordered select-sm tap-44">
      <option value="submitted_desc">ล่าสุด</option>
      <option value="next_due_asc">ครบกำหนดก่อน</option>
      <option value="amount_desc">ยอดสูงก่อน</option>
    </select>
  </div>

  <div id="lead-filters" class="flex flex-wrap gap-2 mb-3 text-xs">
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="all">All</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="today">Today</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="hot">🔥 Hot</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="warm">🌤 Warm</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="cold">❄️ Cold</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="in_progress">In Progress</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="proposal_sent">Proposal Sent</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="walkthrough_done">Walkthrough Done</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="won">Won</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="lost">Lost</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="unqualified">🚫 Unqualified</button>
    <button class="filter-chip btn btn-xs btn-outline tap-44" data-chip="manual">Manual</button>
  </div>

  <div id="lead-list" class="grid gap-2"></div>
  <div id="lead-empty" class="hidden text-sm opacity-70 px-2 py-6 text-center">ไม่พบ lead</div>

  <div class="flex justify-center mt-4">
    <button id="lead-load-more" class="btn btn-sm btn-ghost tap-44 hidden">โหลดเพิ่ม</button>
  </div>
</section>

<LeadCard variant="list" />

<script>
  import { subscribe, getState, openLead, setFilter, setSort, setSearch, visibleLeads, loadMore } from '../../scripts/dashboard/store';
  import type { LeadUi } from '../../scripts/dashboard/adapter';

  function ageDays(iso?: string): string {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    if (!Number.isFinite(ms)) return '';
    const d = Math.max(0, Math.floor(ms / 86400000));
    return d === 0 ? 'วันนี้' : `${d} วัน`;
  }
  function fmtTHB(n: unknown): string {
    const v = Number(n) || 0;
    if (!v) return '—';
    return new Intl.NumberFormat('th-TH', { maximumFractionDigits: 0 }).format(v) + ' ฿';
  }
  function badgeFor(l: LeadUi): { text: string; cls: string } {
    if (l.deal_outcome === 'won') return { text: 'won', cls: 'badge-success' };
    if (l.deal_outcome === 'lost') return { text: 'lost', cls: 'badge-error' };
    if (l.deal_outcome === 'unqualified') return { text: 'unqualified', cls: 'badge-neutral' };
    if (l.walkthrough_at) return { text: 'walk', cls: 'badge-info' };
    if (l.proposal_sent_at) return { text: 'prop', cls: 'badge-warning' };
    return { text: 'in progress', cls: 'badge-ghost' };
  }
  function tempEmoji(t: unknown): string {
    if (t === 'hot') return '🔥';
    if (t === 'warm') return '🌤';
    if (t === 'cold') return '❄️';
    return '';
  }
  function relAgo(iso?: string): string {
    if (!iso) return '';
    const ms = Date.now() - new Date(iso).getTime();
    if (!Number.isFinite(ms) || ms < 0) return '';
    const d = Math.floor(ms / 86400000);
    if (d === 0) return 'วันนี้';
    if (d === 1) return 'เมื่อวาน';
    if (d < 30) return `${d}d ago`;
    const mo = Math.floor(d / 30);
    return `${mo}mo ago`;
  }
  function setField(node: HTMLElement, sel: string, v: string) {
    const el = node.querySelector(`[data-field="${sel}"]`);
    if (el) el.textContent = v;
  }
  function clearChildren(el: HTMLElement) {
    while (el.firstChild) el.removeChild(el.firstChild);
  }

  function fillCard(node: HTMLElement, lead: LeadUi) {
    node.setAttribute('data-lead-id', String(lead.lead_id || ''));
    setField(node, 'temp', tempEmoji(lead.temperature));
    setField(node, 'name', (lead.nickname || lead.full_name || '—').toString());
    setField(node, 'company', (lead.company_name || '').toString());
    const due = lead.next_action_due ? `ครบ ${new Date(lead.next_action_due).toLocaleDateString('th-TH')}` : '';
    const next = (lead.next_action || '').toString();
    setField(node, 'meta', [next, due].filter(Boolean).join(' · '));
    const touch = lead.last_touch_at ? `📞 last ${relAgo(lead.last_touch_at as string)}` : '';
    const reason = lead.deal_outcome === 'unqualified' || lead.deal_outcome === 'lost'
      ? (lead.close_reason ? `· ${lead.close_reason}` : '')
      : '';
    setField(node, 'log', [touch, reason].filter(Boolean).join(' '));
    setField(node, 'amount', fmtTHB(lead.package_price));
    setField(node, 'age', ageDays(lead.submitted_at));
    const badge = node.querySelector('[data-field="badge"]') as HTMLElement | null;
    const b = badgeFor(lead);
    if (badge) {
      badge.className = `badge badge-sm ${b.cls}`;
      badge.textContent = b.text;
    }
  }

  function render() {
    const s = getState();
    const list = document.getElementById('lead-list');
    const empty = document.getElementById('lead-empty');
    const total = document.getElementById('lead-total');
    const tpl = document.getElementById('lead-card-tpl-list') as HTMLTemplateElement | null;
    const more = document.getElementById('lead-load-more');
    if (!list || !empty || !total || !tpl || !more) return;

    const rows = visibleLeads();
    total.textContent = `${rows.length} / ${s.total}`;
    clearChildren(list as HTMLElement);

    if (!rows.length) {
      empty.classList.remove('hidden');
    } else {
      empty.classList.add('hidden');
      for (const lead of rows) {
        const frag = tpl.content.cloneNode(true) as DocumentFragment;
        const btn = frag.querySelector('button') as HTMLElement | null;
        if (!btn) continue;
        fillCard(btn, lead);
        btn.addEventListener('click', () => void openLead(String(lead.lead_id || '')));
        list.appendChild(frag);
      }
    }
    more.classList.toggle('hidden', s.leads.length >= s.total);

    document.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((b) => {
      const active = b.getAttribute('data-chip') === s.filter;
      b.classList.toggle('btn-primary', active);
      b.classList.toggle('btn-outline', !active);
    });
  }

  render();
  subscribe(render);

  document.querySelectorAll<HTMLButtonElement>('.filter-chip').forEach((b) => {
    b.addEventListener('click', () => setFilter(b.getAttribute('data-chip') as never));
  });
  document.getElementById('lead-search')?.addEventListener('input', (e) => {
    setSearch((e.target as HTMLInputElement).value);
  });
  document.getElementById('lead-sort')?.addEventListener('change', (e) => {
    setSort((e.target as HTMLSelectElement).value as never);
  });
  document.getElementById('lead-load-more')?.addEventListener('click', () => void loadMore());
</script>
