---
interface Props {
  variant?: 'list' | 'today';
}
const { variant = 'list' } = Astro.props;
---
<template id={`lead-card-tpl-${variant}`}>
  <button
    class="lead-card group w-full text-left bg-base-200 hover:bg-base-300 border border-base-300 rounded-box px-4 py-3 flex items-start gap-3 transition tap-44"
    data-lead-id=""
    data-variant={variant}
  >
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5">
        <span class="font-display text-base break-words" data-field="name"></span>
        <span class="badge badge-sm shrink-0" data-field="badge"></span>
      </div>
      <div class="text-xs opacity-70 break-words" data-field="company"></div>
      <div class="text-xs opacity-60 mt-0.5 break-words" data-field="meta"></div>
    </div>
    <div class="text-right shrink-0">
      <div class="text-sm font-semibold whitespace-nowrap" data-field="amount"></div>
      <div class="text-[10px] opacity-60 whitespace-nowrap" data-field="age"></div>
    </div>
  </button>
</template>
