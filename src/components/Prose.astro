---
/**
 * Prose.astro — typography wrapper for rendered markdown.
 *
 * Dark-first design (matches landing-page-live-v2 language). High contrast
 * body text, accent-color heading underlines, gradient-header tables.
 */
---

<div class="prose-pun">
  <slot />
</div>

<style is:global>
  .prose-pun {
    color: var(--color-base-content);
    font-size: 1.0625rem;
    line-height: 1.8;
    max-width: 70ch;
  }

  .prose-pun > * + * {
    margin-top: 1.25em;
  }

  /* H2 — section headings with coral underline accent */
  .prose-pun h2 {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 2.6vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-top: 2.75em;
    margin-bottom: 0.75em;
    line-height: 1.2;
    scroll-margin-top: 5rem;
    color: var(--color-base-content);
    position: relative;
    padding-bottom: 0.4em;
  }
  .prose-pun h2::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 3rem;
    height: 3px;
    background: var(--color-secondary);
    border-radius: 2px;
  }

  .prose-pun h3 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    margin-top: 2.25em;
    margin-bottom: 0.6em;
    line-height: 1.35;
    scroll-margin-top: 5rem;
    color: var(--color-base-content);
  }

  .prose-pun h4 {
    font-weight: 700;
    margin-top: 1.6em;
    margin-bottom: 0.4em;
    color: var(--color-base-content);
  }

  /* Paragraphs — first one is the article lede */
  .prose-pun p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    color: oklch(from var(--color-base-content) calc(l * 0.92) c h);
  }

  .prose-pun p:first-child {
    font-size: 1.2em;
    line-height: 1.7;
    color: var(--color-base-content);
    font-weight: 500;
  }

  .prose-pun a {
    color: var(--color-secondary);
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in oklch, var(--color-secondary) 45%, transparent);
    transition: text-decoration-color 0.15s, color 0.15s;
  }
  .prose-pun a:hover {
    color: oklch(from var(--color-secondary) calc(l * 1.1) c h);
    text-decoration-color: var(--color-secondary);
  }

  .prose-pun strong {
    font-weight: 700;
    color: var(--color-base-content);
  }

  .prose-pun em {
    font-style: italic;
  }

  /* Lists with coral arrow markers */
  .prose-pun ul,
  .prose-pun ol {
    padding-left: 1.5em;
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose-pun ul {
    list-style: none;
  }
  .prose-pun ul > li {
    position: relative;
    padding-left: 1.5em;
  }
  .prose-pun ul > li::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0.05em;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .prose-pun ol {
    list-style: decimal;
    counter-reset: ol-counter;
  }
  .prose-pun ol > li {
    padding-left: 0.5em;
  }
  .prose-pun ol > li::marker {
    color: var(--color-secondary);
    font-weight: 700;
  }

  .prose-pun li + li {
    margin-top: 0.6em;
  }

  /* Blockquote — coral border-l + gradient-bg per landing-page-live-v2 */
  .prose-pun blockquote {
    border-left: 4px solid var(--color-secondary);
    padding: 1em 1.5em;
    margin: 2em 0;
    background: linear-gradient(
      90deg,
      color-mix(in oklch, var(--color-secondary) 12%, transparent),
      transparent 80%
    );
    border-radius: 0 0.75rem 0.75rem 0;
    font-style: normal;
    color: var(--color-base-content);
  }
  .prose-pun blockquote p {
    margin: 0;
    color: inherit;
  }
  .prose-pun blockquote p:first-child {
    font-size: 1.05em;
    color: inherit;
    font-weight: 500;
  }

  /* Code */
  .prose-pun code {
    background: color-mix(in oklch, var(--color-secondary) 12%, transparent);
    padding: 0.18em 0.45em;
    border-radius: 0.3em;
    font-size: 0.9em;
    color: oklch(from var(--color-secondary) calc(l * 1.1) c h);
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }

  .prose-pun pre {
    background: oklch(8% 0.012 250);
    color: oklch(95% 0.005 90);
    padding: 1.25em 1.5em;
    border: 1px solid color-mix(in oklch, var(--color-base-content) 10%, transparent);
    border-radius: 0.75em;
    overflow-x: auto;
    margin: 2em 0;
    font-size: 0.9em;
    line-height: 1.6;
  }
  .prose-pun pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Horizontal rule — gradient line */
  .prose-pun hr {
    border: none;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in oklch, var(--color-base-content) 25%, transparent),
      transparent
    );
    margin: 3em 0;
  }

  /* Tables — gradient header + zebra rows + better spacing */
  .prose-pun table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 2em 0;
    font-size: 0.95em;
    border: 1px solid color-mix(in oklch, var(--color-base-content) 12%, transparent);
    border-radius: 0.75em;
    overflow: hidden;
  }
  .prose-pun thead {
    background: linear-gradient(
      135deg,
      color-mix(in oklch, var(--color-secondary) 15%, transparent),
      color-mix(in oklch, var(--color-primary) 12%, transparent)
    );
  }
  .prose-pun th {
    text-align: left;
    padding: 0.85em 1.15em;
    font-weight: 700;
    color: var(--color-base-content);
    font-size: 0.95em;
    letter-spacing: 0.01em;
    border-bottom: 1px solid color-mix(in oklch, var(--color-base-content) 20%, transparent);
  }
  .prose-pun td {
    text-align: left;
    padding: 0.85em 1.15em;
    border-bottom: 1px solid color-mix(in oklch, var(--color-base-content) 8%, transparent);
    color: var(--color-base-content);
  }
  .prose-pun tbody tr:nth-child(even) {
    background: color-mix(in oklch, var(--color-base-content) 3%, transparent);
  }
  .prose-pun tbody tr:last-child td {
    border-bottom: none;
  }

  .prose-pun img {
    border-radius: 0.75em;
    margin: 2em auto;
  }

  /* Scrollbar for tables/code on overflow */
  .prose-pun pre,
  .prose-pun .table-wrapper {
    scrollbar-width: thin;
    scrollbar-color: color-mix(in oklch, var(--color-secondary) 50%, transparent) transparent;
  }

  /* Wrap tables responsively without breaking layout */
  .prose-pun > table {
    display: block;
    overflow-x: auto;
  }
  @media (min-width: 768px) {
    .prose-pun > table {
      display: table;
      overflow-x: visible;
    }
  }
</style>
