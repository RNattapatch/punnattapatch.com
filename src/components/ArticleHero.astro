---
interface Props {
  title: string;
  description?: string;
  published: Date;
  updated?: Date;
  readingMinutes?: number;
  pillar?: string;
  tags?: readonly string[];
}

const { title, description, published, updated, readingMinutes, pillar, tags = [] } = Astro.props;

const formatDate = (d: Date): string =>
  d.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });

const PILLAR_LABEL: Record<string, string> = {
  'sales-consulting': 'Sales Consulting',
  'ai-transformation': 'AI Transformation',
  'agentic-ai-sales': 'Agentic AI for Sales',
};
---

<header class="border-b border-base-content/10 bg-base-200/30 px-4 py-12 lg:px-8 lg:py-16">
  <div class="mx-auto max-w-3xl">
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-base-content/60">
      <a href="/" class="hover:text-secondary">หน้าแรก</a>
      <span class="mx-2">›</span>
      <a href="/insights" class="hover:text-secondary">Insights</a>
      {pillar && (
        <>
          <span class="mx-2">›</span>
          <span class="text-base-content/80">{PILLAR_LABEL[pillar] ?? pillar}</span>
        </>
      )}
    </nav>

    <h1 class="font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-5xl">
      {title}
    </h1>

    {description && (
      <p class="mt-5 text-lg leading-relaxed text-base-content/75">
        {description}
      </p>
    )}

    <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-base-content/60">
      <span>
        เผยแพร่ <time datetime={published.toISOString()}>{formatDate(published)}</time>
      </span>
      {updated && updated.getTime() !== published.getTime() && (
        <span>
          อัปเดตล่าสุด <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
        </span>
      )}
      {readingMinutes && <span>· อ่าน {readingMinutes} นาที</span>}
    </div>

    {tags.length > 0 && (
      <ul class="mt-5 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li class="rounded-full border border-base-content/15 px-3 py-1 text-xs text-base-content/70">
            #{tag}
          </li>
        ))}
      </ul>
    )}
  </div>
</header>
