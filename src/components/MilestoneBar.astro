---
/**
 * MilestoneBar · 3-column DONE / NOW / NEXT trajectory band.
 * Lifted pattern from @ar.ngoon p.19 + Doctor Rule 16 Outcome Bucket.
 * Data lives in src/data/site.ts MILESTONES — quarterly update.
 * Reuse across hub + about + services pages.
 */
import { MILESTONES } from '../data/site';

interface Props {
  /** Section eyebrow above the band. Default: "Trajectory" */
  eyebrow?: string;
  /** Section headline. Default: "ผมเดินมาถึงไหน · กำลังทำอะไร · กำลังจะไปไหน" */
  headline?: string;
}

const {
  eyebrow = 'Trajectory',
  headline = 'ผมเดินมาถึงไหน · กำลังทำอะไร · กำลังจะไปไหน',
} = Astro.props;

const columns = [
  { ...MILESTONES.done, accent: 'var(--color-pun-cyan, #22d3ee)' },
  { ...MILESTONES.now, accent: 'var(--color-secondary, #dd4155)' },
  { ...MILESTONES.next, accent: 'var(--color-pun-violet, #7c3aed)' },
];
---

<section class="border-y border-base-content/10 bg-base-200/40 px-4 py-12 lg:py-16">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">{eyebrow}</p>
      <h2 class="mt-2 font-display text-2xl font-black md:text-3xl">{headline}</h2>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {columns.map((col) => (
        <div
          class="rounded-2xl border bg-base-100/60 p-5 backdrop-blur-sm transition hover:border-[color:var(--accent)]"
          style={`--accent: ${col.accent}; border-color: color-mix(in oklch, ${col.accent} 25%, transparent);`}
        >
          <div class="flex items-center justify-between">
            <span
              class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-bold uppercase tracking-widest"
              style={`background: color-mix(in oklch, ${col.accent} 15%, transparent); color: ${col.accent};`}
            >
              <span aria-hidden="true">{col.icon}</span>
              {col.status}
            </span>
            <span class="font-display text-sm font-bold text-base-content/70">{col.quarter}</span>
          </div>

          <ul class="mt-4 space-y-2 text-sm text-base-content/85">
            {col.items.map((item) => (
              <li class="flex gap-2 leading-relaxed">
                <span aria-hidden="true" class="shrink-0" style={`color: ${col.accent};`}>•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
