---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

const accent = 'var(--color-pun-coral)';
const accentHex = '#dd4155';

---

<BaseLayout
  title="AI Workshop In-house — ปัน ณัฐพัชร์ สอนที่บริษัทคุณ"
  description="ผมไปที่ออฟฟิศของคุณ อบรมการสร้าง AI Agent สำหรับทีมคุณโดยตรง จับมือทำจนกว่าจะเป็น · 1 วันเต็ม · สำหรับทีมขนาด 5-20 คน · เริ่มต้น ฿29,800 · On-site ที่บริษัทของคุณ ไม่คิดค่าเดินทางในเขตกรุงเทพฯ และปริมณฑล"
  noindex={false}
>
  <div class="min-h-screen px-4 py-12 lg:py-20">
    <div class="mx-auto max-w-xl">

      {/* Badge */}
      <div class="flex justify-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-bold uppercase tracking-widest"
          style={`border-color: color-mix(in oklch, ${accent} 40%, transparent); background: color-mix(in oklch, ${accent} 10%, transparent); color: ${accent};`}
        >
          In-house Workshop · On-site Only · กรุงเทพฯ และปริมณฑล
        </span>
      </div>

      {/* Headline */}
      <h1 class="mt-6 text-center font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl">
        อยากสร้างทีม AI มาทำงานช่วย<span style={`color: ${accent};`}>บริษัทคุณ</span>ไหม?
        <br />
        ผมไปสร้างให้ถึงที่ พร้อมกับทีมของคุณ
      </h1>

      <p class="mt-4 text-center text-base leading-relaxed text-base-content/75">
        1 วันเต็มที่บริษัทคุณ ทีม 5-20 คนจะได้ลงมือสร้าง AI Agent ของจริง
        <br class="hidden sm:block" />
        ที่แก้ปัญหาธุรกิจคุณได้ทันที — เริ่มต้น
        <strong style={`color: ${accent};`}>฿29,800</strong>
        <span class="text-base-content/50"> ไม่มีบวกเพิ่ม</span>
      </p>

      {/* Value props */}
      <div class="mt-8 space-y-3">
        {[
          { icon: '🏢', title: 'ทีมคุณไม่ต้องเดินทาง', body: 'ผมนำทีมไปถึงที่ พร้อม setup อุปกรณ์ทุกอย่างเอง — คุณแค่เตรียมห้องประชุม' },
          { icon: '🎯', title: 'AI ที่ build มา แก้ปัญหาธุรกิจคุณโดยตรง', body: 'ไม่ใช่ demo กว้างๆ — ผมดู workflow จริงของคุณก่อน แล้ว build AI Agent ที่ใช้งานได้ทันทีตั้งแต่วันถัดมา' },
          { icon: '👥', title: 'ทั้งทีมเรียนพร้อมกันในราคาเดียว', body: 'ทีม 5-20 คน ฿29,800 ก้อนเดียว ส่งทีละคนไปคอร์ส public ได้ แต่ต้องจ่ายคูณจำนวนคน' },
          { icon: '🚀', title: 'ผ่าน P1 มาแล้ว? ราคาพิเศษสำหรับ Alumni', body: 'ถ้าคุณเคยมาเรียน P1 กับผมแล้ว ราคา in-house ลดเหลือ ฿25,330' },
        ].map((p) => (
          <div
            class="flex items-start gap-4 rounded-2xl border p-4"
            style={`border-color: color-mix(in oklch, ${accent} 18%, transparent); background: color-mix(in oklch, ${accent} 3%, transparent);`}
          >
            <span class="text-2xl">{p.icon}</span>
            <div>
              <p class="font-display text-sm font-bold">{p.title}</p>
              <p class="mt-0.5 text-sm leading-relaxed text-base-content/70">{p.body}</p>
            </div>
          </div>
        ))}
      </div>

      {/* Scarcity */}
      <div
        class="mt-6 rounded-2xl border p-4 text-center"
        style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 5%, transparent);`}
      >
        <p class="text-xs font-bold uppercase tracking-widest text-base-content/55">Slot ว่างเดือนนี้</p>
        <p class="mt-1 font-display text-3xl font-black" style={`color: ${accent};`}>2 วัน</p>
        <p class="mt-1 text-xs text-base-content/55">รับสูงสุด 4 งาน/เดือน · Slot เต็มถี่มากช่วงนี้</p>
      </div>

      {/* Testimonial */}
      <div
        class="mt-6 overflow-hidden rounded-2xl border"
        style={`border-color: color-mix(in oklch, ${accent} 20%, transparent);`}
      >
        <img
          src="/advance-ai-course/testimonial7.JPG"
          alt="บรรยากาศ AI Workshop in-house ทีมขนาดใหญ่"
          class="w-full object-cover max-h-52"
          loading="lazy"
        />
        <div
          class="px-5 py-4"
          style={`background: color-mix(in oklch, ${accent} 5%, transparent);`}
        >
          <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${accent};`}>
            ผมช่วย SME รายได้ ฿30-200M สร้าง AI Agents ลดต้นทุนและเพิ่มยอดขายมาแล้ว
          </p>
          <blockquote class="mt-3 text-sm leading-relaxed text-base-content/85 md:text-base">
            "ค่าซอฟต์แวร์ลดไป 97% รายงานที่เคยทำ 2 ชั่วโมงเหลือแค่ 15 นาที
            ยอดขายขึ้น 30% ใน 3 เดือน — ทีมจัดการเองได้เลย ไม่ต้องรอ dev"
          </blockquote>
          <p class="mt-3 text-xs text-base-content/55">
            — เจ้าของธุรกิจ B2B (นามแฝง ตาม NDA) · ผู้จัดจำหน่ายอุปกรณ์อุตสาหกรรม · ทีม 8 คน
          </p>
        </div>
      </div>

      {/* CTA */}
      <div class="mt-6 rounded-2xl border border-base-content/10 bg-base-100 p-6 text-center space-y-4">
        <p class="font-display text-base font-bold">นัดคุยรายละเอียด — ฟรี ไม่มีผูกมัด</p>
        <p class="text-sm text-base-content/60">ผมจะ reply ภายใน 24 ชม. เพื่อนัดคุยและประเมิน scope ให้</p>
        <a
          href="https://punnattapatch.com/booking?package=ai-workshop"
          class="inline-block w-full rounded-full px-6 py-3.5 font-display text-base font-bold shadow-lg transition-all hover:scale-[1.02]"
          style={`background: ${accent}; color: white;`}
        >
          ส่งข้อมูล — ผมจะติดต่อกลับภายใน 24 ชม.
        </a>
        <p class="text-center text-xs text-base-content/45">
          เวิร์คช็อปนี้จัดที่บริษัทของคุณ (กรุงเทพฯ และปริมณฑล) ชำระหลังคุยรายละเอียดและยืนยันวันครับ
        </p>
      </div>

      {/* Secondary CTAs */}
      <div class="mt-6 space-y-3">
        <a
          href="/services/ai-workshop"
          class="group flex w-full items-center justify-between gap-4 rounded-2xl border-2 px-6 py-5 transition-all hover:scale-[1.01]"
          style={`border-color: color-mix(in oklch, ${accent} 35%, transparent); background: color-mix(in oklch, ${accent} 6%, transparent);`}
        >
          <div>
            <p class="font-display text-base font-bold leading-snug" style={`color: ${accent};`}>
              อยากเห็นภาพรวมก่อนคุย?
            </p>
            <p class="mt-1 text-sm text-base-content/65">
              ดู scope งาน ราคาจริง และเคสลูกค้า SME ที่เคยจัดไป →
            </p>
          </div>
          <span
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-lg font-bold transition-transform group-hover:translate-x-1"
            style={`background: color-mix(in oklch, ${accent} 15%, transparent); color: ${accent};`}
          >
            →
          </span>
        </a>

        <a
          href="/waitlist"
          class="group flex w-full items-center justify-between gap-4 rounded-2xl border px-6 py-5 transition-all hover:scale-[1.01]"
          style="border-color: color-mix(in oklch, var(--color-pun-cyan) 30%, transparent); background: color-mix(in oklch, var(--color-pun-cyan) 4%, transparent);"
        >
          <div>
            <p class="font-display text-base font-bold leading-snug" style="color: var(--color-pun-cyan);">
              ยังไม่พร้อมจัด In-house หรืออยากลองก่อน?
            </p>
            <p class="mt-1 text-sm text-base-content/65">
              มาเรียนคอร์ส P1 คนเดียวก่อนได้ครับ 20 ที่นั่ง ฿12,900 →
            </p>
          </div>
          <span
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-lg font-bold transition-transform group-hover:translate-x-1"
            style="background: color-mix(in oklch, var(--color-pun-cyan) 15%, transparent); color: var(--color-pun-cyan);"
          >
            →
          </span>
        </a>
      </div>

    </div>
  </div>

  <script is:inline define:vars={{ accentHex }}>
    (function () {
      if (window.ttq && typeof window.ttq.track === 'function') {
        try { window.ttq.track('ViewContent', { contents: [{ content_id: 'inhouse-workshop', content_type: 'service', content_name: 'AI Workshop In-house' }], value: 29800, currency: 'THB' }); } catch (_) {}
      }
    })();
  </script>
</BaseLayout>
