---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prose from '../../components/Prose.astro';
import { SITE } from '../../data/site';

export async function getStaticPaths() {
  const cases = await getCollection(
    'case-analysis',
    ({ data }: CollectionEntry<'case-analysis'>) => !data.draft
  );
  return cases.map((c) => ({ params: { slug: c.id }, props: { entry: c } }));
}

interface Props {
  entry: CollectionEntry<'case-analysis'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title = entry.data.title;
const description = entry.data.description;
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'Article', 'BreadcrumbList'],
    title,
    description,
    article: {
      headline: title,
      datePublished: entry.data.published.toISOString(),
      dateModified: (entry.data.updated ?? entry.data.published).toISOString(),
    },
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Case Studies', url: `${SITE.url}/case-studies` },
      { name: entry.data.title, url: `${SITE.url}/case-studies/${entry.id}` },
    ],
  }}
>
  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <nav class="mb-6 flex items-center gap-2 text-sm text-base-content/60">
        <a href="/case-studies" class="hover:text-secondary">Case Studies</a>
        <span>→</span>
        <span>{entry.data.industry ?? 'Client Case'}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-2 text-xs">
        {
          entry.data.industry && (
            <span class="rounded-full border border-secondary/30 bg-secondary/10 px-3 py-1 font-semibold text-secondary">
              {entry.data.industry}
            </span>
          )
        }
        {
          entry.data.companySize && (
            <span class="rounded-full border border-base-content/15 bg-base-200/50 px-3 py-1 text-base-content/75">
              {entry.data.companySize}
            </span>
          )
        }
        {
          entry.data.anonymized && (
            <span class="rounded-full border border-base-content/15 bg-base-200/50 px-3 py-1 text-base-content/55">
              Anonymized
            </span>
          )
        }
      </div>

      <h1 class="mt-5 font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-5xl">
        {entry.data.title}
      </h1>

      {
        entry.data.outcome && (
          <div class="mt-6 rounded-2xl border border-secondary/30 bg-secondary/[0.08] p-6">
            <p class="text-xs font-bold uppercase tracking-widest text-secondary">Outcome</p>
            <p class="mt-2 font-display text-lg font-semibold leading-snug">
              {entry.data.outcome}
            </p>
          </div>
        )
      }
    </div>
  </section>

  <article class="border-t border-base-content/10 bg-base-200/20 px-4 py-10 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <Prose>
        <Content />
      </Prose>
    </div>
  </article>

  <section class="px-4 py-20 lg:px-8">
    <div
      class="mx-auto max-w-4xl rounded-3xl bg-primary px-6 py-12 text-primary-content md:px-12"
    >
      <h2 class="font-display text-2xl font-bold leading-tight md:text-3xl">
        อยากได้ผลลัพธ์แบบ case นี้ไหม?
      </h2>
      <p class="mt-4 max-w-2xl text-primary-content/80">
        ตอบแบบประเมิน 3 นาที ผมอ่านแล้วบอกว่าเคสคุณ match กับ case นี้แค่ไหน + ควรเริ่มจาก package ไหน
      </p>
      <div class="mt-7 flex flex-wrap gap-4">
        <a
          href="/intake-form"
          class="btn btn-lg bg-secondary text-secondary-content shadow-lg shadow-secondary/30 hover:bg-secondary/90"
        >
          ประเมินเคสของคุณ
        </a>
        <a
          href="/services"
          class="btn btn-lg btn-outline text-primary-content hover:bg-primary-content hover:text-primary"
        >
          ดูทุก package
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
