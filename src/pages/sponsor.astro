  </style>

  <script>
    const WEBHOOK = 'https://rnat.app.n8n.cloud/webhook/intake-form-v2';

    const form = document.getElementById('sponsorForm') as HTMLFormElement | null;
    const reveal = document.getElementById('sponsorReveal');
    const errorEl = document.getElementById('sponsorError');
    const submitBtn = form?.querySelector<HTMLButtonElement>('.sponsor-submit');
    const submitIdle = submitBtn?.querySelector<HTMLElement>('.sponsor-submit-idle');
    const submitLoading = submitBtn?.querySelector<HTMLElement>('.sponsor-submit-loading');

    function setLoading(loading: boolean) {
      if (!submitBtn || !submitIdle || !submitLoading) return;
      submitBtn.disabled = loading;
      submitIdle.hidden = loading;
      submitLoading.hidden = !loading;
    }

    function showError() {
      if (errorEl) errorEl.hidden = false;
    }
    function hideError() {
      if (errorEl) errorEl.hidden = true;
    }

    function reveal_() {
      if (!form || !reveal) return;
      form.hidden = true;
      reveal.hidden = false;
      // Scroll reveal into view
      reveal.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      // Basic client-side validation for required fields
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const fd = new FormData(form);
      const payload: Record<string, unknown> = {
        source: 'sponsor-form',
        submittedAt: new Date().toISOString(),
        pageUrl: window.location.href,
      };
      fd.forEach((value, key) => {
        payload[key] = value;
      });

      setLoading(true);

      try {
        const res = await fetch(WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok && res.status !== 0) {
          throw new Error(`webhook ${res.status}`);
        }

        // Fire Plausible custom event
        (window as unknown as { plausible?: (...args: unknown[]) => void }).plausible?.(
          'Sponsor Submit',
          { props: { brand: String(payload.brandName ?? 'unknown') } }
        );

        reveal_();
      } catch (err) {
        console.error('Sponsor form submit failed:', err);
        showError();
      } finally {
        setLoading(false);
      }
    });
  </script>
</BaseLayout>
