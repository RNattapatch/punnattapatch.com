---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SERVICES } from '../data/site';

const title = 'บริการ — 4 Package ตามปัญหาทีมขาย';
const description =
  'AI Day Workshop (฿30k) · Workshop + Follow-up 30 วัน (฿50k) · Sales System Sprint 1 เดือน (฿65k) · Sale Training Bundle (฿42.5k) — ทุก package 100% upfront, ส่งระบบจริงไม่ใช่สไลด์';

const comparison = [
  {
    situation: 'ต้องการเห็น AI ใช้จริงกับทีม ก่อนลงทุนหนัก',
    service: 'AI Workshop (฿30k / 1 วัน)',
  },
  {
    situation: 'เคยจ่าย workshop แล้วทีมเลิกใช้ 2 สัปดาห์',
    service: 'Workshop + Follow-up 30 วัน (฿50k)',
  },
  {
    situation: 'ทีม 5-20 คน แต่ยอดขาย 80% มาจากเจ้าของคนเดียว',
    service: 'Sales System Sprint (฿65k / 1 เดือน)',
  },
  {
    situation: 'ทีมขายปิดด้วยลดราคาเป็นหลัก margin หาย',
    service: 'Sale Training Bundle (฿42.5k / 2 วัน)',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'ServiceList', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'บริการ', url: `${SITE.url}/services` },
    ],
  }}
>
  <!-- ===== HEADER ===== -->
  <section class="px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Services</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight md:text-5xl">
        4 Package ตามปัญหาทีมขาย
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        เลือกตามปัญหาจริง ไม่ใช่ตามว่ามีอะไรใน catalog — ทุก package 100% upfront ส่งระบบที่ใช้ได้จริงไม่ใช่สไลด์
      </p>
    </div>
  </section>

  <!-- ===== QUICK MATCH ===== -->
  <section class="border-y border-base-content/10 bg-base-200/30 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2 class="font-display text-lg font-bold tracking-tight">
        เลือกไม่ถูก? ดูว่าคุณตรงกับสถานการณ์ไหน
      </h2>
      <ul class="mt-6 space-y-3">
        {
          comparison.map((item) => (
            <li class="flex flex-col gap-2 border-b border-base-content/10 pb-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="text-base text-base-content/80">→ {item.situation}</span>
              <span class="font-display text-sm font-bold text-secondary">{item.service}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ===== INDIVIDUAL PACKAGES ===== -->
  <section class="px-4 py-16 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-5xl space-y-20">
      {
        SERVICES.map((svc, idx) => (
          <article
            id={svc.slug}
            class="scroll-mt-24 rounded-3xl border border-base-content/10 bg-base-100 p-6 shadow-sm md:p-10"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs uppercase tracking-widest text-base-content/50">
                  Package 0{idx + 1}
                </p>
                <h2 class="mt-2 font-display text-2xl font-bold tracking-tight md:text-3xl">
                  {svc.title}
                </h2>
                <p class="mt-1 text-base font-medium text-secondary">{svc.subtitle}</p>
              </div>
              <span class="flex-shrink-0 rounded-full bg-secondary/10 px-4 py-2 font-display text-sm font-bold text-secondary">
                {svc.priceLabel}
              </span>
            </div>

            <p class="mt-6 rounded-xl bg-base-200/50 p-5 text-lg italic leading-relaxed text-base-content/85">
              “{svc.hook}”
            </p>

            <div class="mt-8 grid gap-8 md:grid-cols-2">
              <div>
                <p class="text-xs uppercase tracking-widest text-base-content/50">เหมาะกับ</p>
                <p class="mt-2 text-base leading-relaxed text-base-content/80">
                  {svc.audience}
                </p>
              </div>
              <div>
                <p class="text-xs uppercase tracking-widest text-base-content/50">รูปแบบ</p>
                <ul class="mt-2 space-y-1 text-base text-base-content/80">
                  <li>• ระยะเวลา: {svc.duration}</li>
                  <li>• รูปแบบ: {svc.format}</li>
                  <li>• ชำระเงิน: 100% ก่อนเริ่มงาน</li>
                </ul>
              </div>
            </div>

            <div class="mt-8">
              <p class="text-xs uppercase tracking-widest text-base-content/50">
                ผลลัพธ์ที่ได้
              </p>
              <ul class="mt-3 grid gap-2 md:grid-cols-2">
                {svc.outcome.map((o) => (
                  <li class="flex items-start gap-3 rounded-lg bg-base-200/30 p-3 text-sm leading-relaxed">
                    <span class="mt-1 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-secondary" />
                    <span>{o}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-10 flex flex-wrap gap-3 border-t border-base-content/10 pt-6">
              <a
                href="/intake-form"
                class="btn bg-secondary text-secondary-content hover:bg-secondary/90"
              >
                ประเมินว่าเคสนี้เหมาะกับคุณ
              </a>
              <a
                href={SITE.social.line}
                rel="noopener"
                target="_blank"
                class="btn btn-ghost border border-base-content/20"
              >
                คุยกับปันใน LINE OA
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ===== PAYMENT TERMS ===== -->
  <section class="bg-base-200/40 px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-2xl font-bold tracking-tight">เงื่อนไขร่วมกันทุก package</h2>
      <dl class="mt-8 space-y-5">
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">ชำระเงิน</dt>
          <dd class="text-base-content/80">100% upfront — ไม่มีข้อยกเว้น ทั้งสองฝ่าย commit เต็มที่ตั้งแต่วันแรก</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">สัญญา</dt>
          <dd class="text-base-content/80">ไม่มี lock-in ยาว — จบงานจบสัญญา ใช้ระบบที่ส่งมอบต่อเองได้</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">Technology stack</dt>
          <dd class="text-base-content/80">Claude Code + n8n + Google Apps Script / Sheets — ไม่มี vendor lock-in</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">Handover</dt>
          <dd class="text-base-content/80">ทีมฝ่ายลูกค้า maintain ต่อเองได้ — มี documentation + training ให้</dd>
        </div>
        <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">ค่าเดินทาง (on-site ต่างจังหวัด)</dt>
          <dd class="text-base-content/80">คำนวณแยกตามจริง แจ้งก่อนรับงาน</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ===== ROI COMPARISON — Public courses vs In-house with Pun ===== -->
  <section class="border-y border-base-content/10 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Why In-House</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        ทำไมผมไม่จัดคอร์สเปิดทั่วไป
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/75">
        ลูกค้าของผมต้องได้มากกว่าที่จ่ายมาเสมอ ไม่ใช่แค่ได้ฟังบรรยาย
      </p>

      <div class="mt-10 overflow-x-auto rounded-2xl border border-base-content/15">
        <table class="w-full text-sm md:text-base">
          <thead>
            <tr class="border-b border-base-content/15">
              <th class="px-4 py-4 text-left font-medium text-base-content/65 md:px-6"></th>
              <th class="px-4 py-4 text-center font-semibold text-base-content/75 md:px-6">
                คอร์สทั่วไป (Public)
              </th>
              <th
                class="bg-secondary/10 px-4 py-4 text-center font-bold text-secondary md:px-6"
              >
                เรียนกับปัน (In-house)
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-content/10">
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">รูปแบบ</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                พูดเร็ว ข้ามเร็ว ตามไม่ทันก็ช่างมัน
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                ไม่ปล่อยกลับบ้านถ้ายังไม่เข้าใจ
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">Workshop</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ดูสไลด์แล้วจบ
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                จับมือทำทุกขั้นตอน
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">กลับไปแล้ว</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ทำเองไม่ได้
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                พนักงานใช้งานได้จริงทันที
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">ค่า Software</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                จ่ายรายเดือนไปเรื่อยๆ
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                เขียน App ใช้เองได้เลย
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">ทีมขาย</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ท่องสเปคไปขอส่วนลด
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                คุยกับลูกค้าได้ลึก เข้าใจ pain จริงๆ
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div
        class="mt-8 rounded-2xl border border-secondary/30 bg-secondary/[0.06] p-8 text-center"
      >
        <p class="font-display text-xl font-bold leading-tight md:text-2xl">
          จบ Workshop แล้ว ทีมคุณต้องเอาไปใช้งานได้จริง
        </p>
        <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-base-content/75">
          ผมไม่ได้มาสอนแค่ให้ฟังแล้วจบ ทุกคนที่เข้า Workshop ต้องลงมือทำจริงในห้อง
          กลับไปวันรุ่งขึ้นเปิดเครื่องมือที่สร้างไว้ใช้งานได้เลย ไม่ต้องรอใคร
        </p>
      </div>
    </div>
  </section>

  <!-- ===== COUNTER POSITIONING (vs online courses) ===== -->
  <section class="border-y border-base-content/10 bg-base-100 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">
        ที่ปรึกษาแบบนี้เหมาะกับใคร
      </p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        ไม่ดีกว่าคอร์สออนไลน์ แค่เป็นคนละแบบ สำหรับคนละกลุ่ม
      </h2>
      <p class="mt-4 max-w-2xl text-base-content/75">
        ลูกค้าผมส่วนใหญ่เคยซื้อคอร์สออนไลน์มาก่อน แล้วยังไม่ติด พอมาเจอบริการแบบ live ที่เน้นลงระบบจริง 30 วัน เลยเห็นความต่าง
      </p>

      <div class="mt-10 overflow-x-auto rounded-2xl border border-base-content/10">
        <table class="w-full text-sm md:text-base">
          <thead>
            <tr class="bg-base-200/60">
              <th class="px-4 py-4 text-left font-semibold text-base-content/70 md:px-6">
                เปรียบเทียบ
              </th>
              <th class="px-4 py-4 text-left font-semibold text-base-content/70 md:px-6">
                คอร์สออนไลน์ทั่วไป
              </th>
              <th class="px-4 py-4 text-left font-semibold text-secondary md:px-6">
                บริการของปัน
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-content/10">
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">รูปแบบ</td>
              <td class="px-4 py-4 text-base-content/70 md:px-6">วิดีโอ self-paced ดูคนเดียว</td>
              <td class="px-4 py-4 text-base-content md:px-6">Live workshop 1:1 + ทีมคุณเข้ามาด้วย</td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">สิ่งที่ได้กลับไป</td>
              <td class="px-4 py-4 text-base-content/70 md:px-6">Framework + tool list + การบ้าน</td>
              <td class="px-4 py-4 text-base-content md:px-6">ระบบ AI workflow ที่รันได้จริงใน 30 วัน</td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">ราคา</td>
              <td class="px-4 py-4 text-base-content/70 md:px-6">฿590-฿3,900</td>
              <td class="px-4 py-4 text-base-content md:px-6">฿30,000-฿65,000</td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">เหมาะกับ</td>
              <td class="px-4 py-4 text-base-content/70 md:px-6">คนที่อยากลองทำเอง มีเวลาเรียน</td>
              <td class="px-4 py-4 text-base-content md:px-6">Owner ที่ต้องการระบบรันจริง ไม่มีเวลาเรียนเอง</td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">หลังจบ</td>
              <td class="px-4 py-4 text-base-content/70 md:px-6">ดูซ้ำคนเดียว ถามใครไม่ได้</td>
              <td class="px-4 py-4 text-base-content md:px-6">ทีมใช้ระบบจริง มี LINE support 30 วัน</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="mt-6 text-sm text-base-content/65">
        ถ้าทีมคุณมีเวลาเรียนเองและชอบลองทำ คอร์สออนไลน์คุ้มกว่า
        ถ้าต้องการระบบที่รันได้ภายในเดือน ไม่มีเวลาฝึกเอง ปันคุ้มกว่า
      </p>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-3xl bg-primary px-6 py-12 text-primary-content md:px-12">
      <h2 class="font-display text-2xl font-bold leading-tight md:text-3xl">
        ไม่แน่ใจว่าเริ่มจาก package ไหน?
      </h2>
      <p class="mt-4 max-w-2xl text-primary-content/80">
        ตอบแบบประเมิน 3 นาที บอก context ทีมขายของคุณ — ผมตอบกลับภายใน 2 วันทำการว่าเคสคุณตรงกับ package ไหนที่สุด
      </p>
      <div class="mt-7 flex flex-wrap gap-4">
        <a
          href="/intake-form"
          class="btn btn-lg bg-secondary text-secondary-content shadow-lg shadow-secondary/30 hover:bg-secondary/90"
        >
          ประเมินปัญหาทีมขาย
        </a>
        <a
          href={SITE.social.line}
          rel="noopener"
          target="_blank"
          class="btn btn-lg btn-outline text-primary-content hover:bg-primary-content hover:text-primary"
        >
          ทักมาคุยใน LINE OA
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
