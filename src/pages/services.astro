---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SERVICES } from '../data/site';

const title = 'บริการ — 2 Path สำหรับ SME + Special TikTok Workshop';
const description =
  'Path A — AI Transformation: Advance AI Workshop ฿24,900 + Bundle Workshop + Consult 30 วัน ฿44,900. Path B — ปั้นทีมขาย: Sale Training Bundle ฿50K (Early Bird ฿44,900) + Sales System Sprint ฿65,000. Plus: Trust Content Workshop TikTok ฿39,900.';

const svcBySlug = (slug: string) => SERVICES.find((s) => s.slug === slug)!;

const aiDay = svcBySlug('ai-workshop');
const saleBundle = svcBySlug('sale-training-bundle');
const saleSprint = svcBySlug('sales-system-sprint');
const tiktokWorkshop = svcBySlug('trust-content-tiktok-workshop');

type PathCardProps = {
  svc: (typeof SERVICES)[number];
  durationLabel: string;
  featured?: boolean;
  badgeText?: string;
  bullets: string[];
};

const pathAPackages: PathCardProps[] = [
  {
    svc: aiDay,
    durationLabel: '1 Day',
    featured: true,
    badgeText: 'ราคาพิเศษเดือนนี้',
    bullets: [
      'Build AI Agent ตัวแรก ใช้ได้จริงในห้อง',
      'n8n workflow + 30 Prompts tested',
      'Team lead maintain เองได้หลัง handover',
      '30-day async LINE support',
      'Bundle option: + Consult 30 วัน = ฿44,900 (save ฿25K)',
    ],
  },
];

const pathBPackages: PathCardProps[] = [
  {
    svc: saleBundle,
    durationLabel: '2 Days',
    bullets: [
      'Day 1: Value-Based Selling',
      'Day 2: Consultative Closing',
      'Role-play + Real Case Practice',
      'Post-training KPI tracking',
    ],
  },
  {
    svc: saleSprint,
    durationLabel: '1 Month',
    featured: true,
    badgeText: 'ครบจบ',
    bullets: [
      'Discovery → Design → Build → Training',
      'KPI Dashboard + Commission Calculator',
      'n8n workflow + AI tools สำหรับทีม',
      'Async LINE support 30 วัน',
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'ServiceList', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'บริการ', url: `${SITE.url}/services` },
    ],
  }}
>
  <!-- ===== HEADER ===== -->
  <section class="px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Services</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl">
        เลือกทางที่เหมาะกับธุรกิจคุณที่สุด
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        ผมมี 2 แนวทางให้เลือกตามเป้าหมายของธุรกิจคุณตอนนี้ ทุก package 100% upfront ส่งระบบที่รันได้จริงไม่ใช่สไลด์
      </p>
    </div>
  </section>

  <!-- ===== 2-PATH PRICING ===== -->
  <section class="px-4 pb-16 lg:px-8 lg:pb-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 lg:grid-cols-2">
        <!-- PATH A: AI Transformation (cyan) -->
        <div
          class="rounded-2xl border p-6 lg:p-8"
          style="border-color: color-mix(in oklch, var(--color-pun-cyan) 25%, transparent); background: color-mix(in oklch, var(--color-pun-cyan) 4%, transparent);"
        >
          <div class="mb-2 flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-lg"
              style="background: color-mix(in oklch, var(--color-pun-cyan) 12%, transparent);"
            >
              <span
                class="font-display text-lg font-bold"
                style="color: var(--color-pun-cyan);">A</span
              >
            </div>
            <p
              class="text-xs font-bold uppercase tracking-widest"
              style="color: var(--color-pun-cyan);"
            >
              Path A
            </p>
          </div>
          <h2 class="font-display text-2xl font-bold">AI Transformation</h2>
          <p class="mt-2 text-sm text-base-content/65">
            ปลดล็อกเวลาทีมขายด้วย AI ลดงานซ้ำซ้อน สร้าง Workflow อัตโนมัติ
          </p>

          <div class="mt-6 space-y-4">
            {
              pathAPackages.map((p) => (
                <div
                  id={p.svc.slug}
                  class:list={[
                    'scroll-mt-24 rounded-xl border p-5 transition-all',
                    p.featured ? 'shadow-lg' : '',
                  ]}
                  style={
                    p.featured
                      ? 'border-color: color-mix(in oklch, var(--color-pun-cyan) 45%, transparent); background: color-mix(in oklch, var(--color-pun-cyan) 3%, transparent); box-shadow: 0 10px 30px -15px color-mix(in oklch, var(--color-pun-cyan) 30%, transparent);'
                      : 'border-color: rgb(255 255 255 / 0.1); background: rgb(255 255 255 / 0.02);'
                  }
                >
                  {p.badgeText && (
                    <div
                      class="mb-3 inline-block rounded-full px-2.5 py-0.5 text-[10px] font-bold"
                      style="background: color-mix(in oklch, var(--color-pun-cyan) 18%, transparent); color: var(--color-pun-cyan); border: 1px solid color-mix(in oklch, var(--color-pun-cyan) 40%, transparent);"
                    >
                      {p.badgeText}
                    </div>
                  )}
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div>
                      <span class="text-xs uppercase tracking-widest text-base-content/45">
                        {p.durationLabel}
                      </span>
                      <h3 class="font-display text-lg font-bold">
                        <a
                          href={`/services/${p.svc.slug}`}
                          class="transition-colors hover:text-[var(--color-pun-cyan)]"
                        >
                          Advance AI & Business Automation
                        </a>
                      </h3>
                    </div>
                    <div class="font-display text-xl font-bold text-secondary">
                      {p.svc.priceLabel.replace(/\s*\/.*$/, '')}
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-base-content/65">"{p.svc.hook}"</p>
                  <ul class="mb-4 space-y-1.5 text-sm text-base-content/75">
                    {p.bullets.map((b) => (
                      <li class="flex items-start gap-2">
                        <span
                          class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                          style="background: var(--color-pun-cyan);"
                        />
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                  <a
                    href={`/booking?package=${p.svc.slug}`}
                    class="btn btn-lg mt-2 w-full border-none text-base font-bold shadow-xl transition-all hover:scale-[1.02]"
                    style={
                      p.featured
                        ? 'background: var(--color-pun-cyan); color: #0a1020; box-shadow: 0 14px 32px -10px color-mix(in oklch, var(--color-pun-cyan) 55%, transparent);'
                        : 'background: color-mix(in oklch, var(--color-pun-cyan) 18%, transparent); color: var(--color-pun-cyan); border: 1px solid color-mix(in oklch, var(--color-pun-cyan) 45%, transparent);'
                    }
                  >
                    จองเลย {p.svc.priceLabel.replace(/\s*\/.*$/, '')} →
                  </a>
                  <a
                    href={`/services/${p.svc.slug}`}
                    class="mt-1.5 block text-center text-xs transition-colors hover:text-[var(--color-pun-cyan)]"
                    style="color: color-mix(in oklch, var(--color-pun-cyan) 70%, transparent);"
                  >
                    ดูรายละเอียดเพิ่มเติม →
                  </a>
                </div>
              ))
            }
          </div>

          <p class="mt-5 text-center text-xs text-base-content/45">
            เริ่มจาก Workshop ฿24,900 → ต่อ Bundle Consult 30 วัน ได้เลย (save ฿25K)
          </p>
        </div>

        <!-- PATH B: ปั้นทีมขาย (coral) -->
        <div
          class="rounded-2xl border p-6 lg:p-8"
          style="border-color: color-mix(in oklch, var(--color-pun-coral) 25%, transparent); background: color-mix(in oklch, var(--color-pun-coral) 4%, transparent);"
        >
          <div class="mb-2 flex items-center gap-3">
            <div
              class="flex h-10 w-10 items-center justify-center rounded-lg"
              style="background: color-mix(in oklch, var(--color-pun-coral) 12%, transparent);"
            >
              <span
                class="font-display text-lg font-bold"
                style="color: var(--color-pun-coral);">B</span
              >
            </div>
            <p
              class="text-xs font-bold uppercase tracking-widest"
              style="color: var(--color-pun-coral);"
            >
              Path B
            </p>
          </div>
          <h2 class="font-display text-2xl font-bold">ปั้นทีมขาย</h2>
          <p class="mt-2 text-sm text-base-content/65">
            วางโครงสร้างทีมขาย ทั้งระบบ KPI, Commission และ Training
          </p>

          <div class="mt-6 space-y-4">
            {
              pathBPackages.map((p) => (
                <div
                  id={p.svc.slug}
                  class:list={[
                    'scroll-mt-24 rounded-xl border p-5 transition-all',
                    p.featured ? 'shadow-lg' : '',
                  ]}
                  style={
                    p.featured
                      ? 'border-color: color-mix(in oklch, var(--color-pun-coral) 45%, transparent); background: color-mix(in oklch, var(--color-pun-coral) 3%, transparent); box-shadow: 0 10px 30px -15px color-mix(in oklch, var(--color-pun-coral) 30%, transparent);'
                      : 'border-color: rgb(255 255 255 / 0.1); background: rgb(255 255 255 / 0.02);'
                  }
                >
                  {p.badgeText && (
                    <div
                      class="mb-3 inline-block rounded-full px-2.5 py-0.5 text-[10px] font-bold"
                      style="background: color-mix(in oklch, var(--color-pun-coral) 18%, transparent); color: var(--color-pun-coral); border: 1px solid color-mix(in oklch, var(--color-pun-coral) 40%, transparent);"
                    >
                      {p.badgeText}
                    </div>
                  )}
                  <div class="mb-3 flex items-start justify-between gap-3">
                    <div>
                      <span class="text-xs uppercase tracking-widest text-base-content/45">
                        {p.durationLabel}
                      </span>
                      <h3 class="font-display text-lg font-bold">
                        <a
                          href={`/services/${p.svc.slug}`}
                          class="transition-colors hover:text-secondary"
                        >
                          {p.svc.title}
                        </a>
                      </h3>
                    </div>
                    <div class="font-display text-xl font-bold text-secondary">
                      {p.svc.priceLabel.replace(/\s*\/.*$/, '')}
                    </div>
                  </div>
                  <p class="mb-3 text-sm text-base-content/65">"{p.svc.hook}"</p>
                  <ul class="mb-4 space-y-1.5 text-sm text-base-content/75">
                    {p.bullets.map((b) => (
                      <li class="flex items-start gap-2">
                        <span
                          class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                          style="background: var(--color-pun-coral);"
                        />
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                  <a
                    href={`/booking?package=${p.svc.slug}`}
                    class="btn btn-lg mt-2 w-full border-none text-base font-bold shadow-xl transition-all hover:scale-[1.02]"
                    style={
                      p.featured
                        ? 'background: var(--color-pun-coral); color: white; box-shadow: 0 14px 32px -10px color-mix(in oklch, var(--color-pun-coral) 55%, transparent);'
                        : 'background: color-mix(in oklch, var(--color-pun-coral) 18%, transparent); color: var(--color-pun-coral); border: 1px solid color-mix(in oklch, var(--color-pun-coral) 45%, transparent);'
                    }
                  >
                    จองเลย {p.svc.priceLabel.replace(/\s*\/.*$/, '')} →
                  </a>
                  <a
                    href={`/services/${p.svc.slug}`}
                    class="mt-1.5 block text-center text-xs transition-colors hover:text-secondary"
                    style="color: color-mix(in oklch, var(--color-pun-coral) 70%, transparent);"
                  >
                    ดูรายละเอียดเพิ่มเติม →
                  </a>
                </div>
              ))
            }
          </div>

          <p class="mt-5 text-center text-xs text-base-content/45">
            ไม่แน่ใจ? เริ่มจาก Training 2 วัน → ต่อ Sprint ได้ภายหลัง
          </p>
        </div>
      </div>

      <div class="mt-10 text-center">
        <div
          class="inline-flex items-center gap-3 rounded-full border border-base-content/15 bg-base-200/40 px-6 py-3"
        >
          <span class="text-base" aria-hidden="true">✦</span>
          <span class="text-sm text-base-content/75">
            <strong class="text-base-content">ทำได้ทั้งสองทาง</strong> ลูกค้าหลายเจ้าเริ่มจาก AI Workshop แล้วค่อยต่อด้วย Sales System Sprint
          </span>
        </div>
      </div>

      <!-- ===== SPECIAL WORKSHOP: Trust Content TikTok (violet) ===== -->
      <div
        id={tiktokWorkshop.slug}
        class="relative mt-12 scroll-mt-24 rounded-2xl border p-6 lg:p-8"
        style="border-color: color-mix(in oklch, var(--color-pun-violet) 25%, transparent); background: color-mix(in oklch, var(--color-pun-violet) 4%, transparent);"
      >
        <div
          class="absolute right-4 top-4 rounded-full px-2.5 py-0.5 text-[10px] font-bold"
          style="background: color-mix(in oklch, var(--color-pun-violet) 18%, transparent); color: var(--color-pun-violet); border: 1px solid color-mix(in oklch, var(--color-pun-violet) 40%, transparent);"
        >
          Special Workshop
        </div>
        <div class="flex flex-col items-start gap-8 lg:flex-row">
          <div class="flex-1">
            <div class="mb-2 flex items-center gap-3">
              <div
                class="flex h-10 w-10 items-center justify-center rounded-lg"
                style="background: color-mix(in oklch, var(--color-pun-violet) 12%, transparent);"
              >
                <span
                  class="font-display text-lg font-bold"
                  style="color: var(--color-pun-violet);">★</span
                >
              </div>
              <p
                class="text-xs font-bold uppercase tracking-widest"
                style="color: var(--color-pun-violet);"
              >
                New
              </p>
            </div>
            <h3 class="font-display text-2xl font-bold">{tiktokWorkshop.title}</h3>
            <p class="mt-2 text-sm text-base-content/65">
              เปลี่ยนมือถือเครื่องเดียวให้เป็นเครื่องจักรสร้างลูกค้า B2B ผ่าน TikTok — content ที่ปิดการขาย ไม่ใช่แค่ได้ยอดวิว
            </p>

            <div class="mt-4 flex flex-wrap gap-2">
              {
                [
                  '3 คลิปถ่ายเสร็จ',
                  'Content Calendar 30 วัน',
                  'Trust Framework PDF',
                  'Script Template Kit',
                ].map((chip) => (
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-base-content/15 bg-base-200/50 px-3 py-1 text-xs text-base-content/70">
                    {chip}
                  </span>
                ))
              }
            </div>
          </div>

          <div
            class="w-full rounded-xl border p-5 text-center lg:w-64 lg:flex-shrink-0"
            style="border-color: color-mix(in oklch, var(--color-pun-violet) 25%, transparent); background: rgb(255 255 255 / 0.02);"
          >
            <span class="text-xs uppercase tracking-widest text-base-content/45">
              1 Day In-House
            </span>
            <p class="mt-2 text-sm text-base-content/40 line-through">฿50,000</p>
            <div
              class="font-display text-3xl font-bold"
              style="color: var(--color-pun-violet);"
            >
              ฿39,900
            </div>
            <span
              class="mb-3 mt-1 inline-block rounded-full border border-secondary/30 bg-secondary/10 px-2.5 py-0.5 text-xs font-bold text-secondary"
            >
              5 ธุรกิจแรก
            </span>
            <a
              href={`/booking?package=${tiktokWorkshop.slug}`}
              class="btn btn-lg w-full border-none text-base font-bold text-white shadow-xl transition-all hover:scale-[1.02]"
              style="background: var(--color-pun-violet); box-shadow: 0 14px 32px -10px color-mix(in oklch, var(--color-pun-violet) 55%, transparent);"
            >
              จอง Workshop ฿39,900 →
            </a>
            <a
              href={`/services/${tiktokWorkshop.slug}`}
              class="mt-1.5 block text-xs text-base-content/45 hover:text-[var(--color-pun-violet)]"
            >
              ดูรายละเอียดเพิ่มเติม →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PAYMENT TERMS ===== -->
  <section class="border-y border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-2xl font-bold tracking-tight">เงื่อนไขร่วมกันทุก package</h2>
      <dl class="mt-8 space-y-5">
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">ชำระเงิน</dt>
          <dd class="text-base-content/80">100% upfront ไม่มีข้อยกเว้น ทั้งสองฝ่าย commit เต็มที่ตั้งแต่วันแรก</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">สัญญา</dt>
          <dd class="text-base-content/80">ไม่มี lock-in ยาว จบงานจบสัญญา ใช้ระบบที่ส่งมอบต่อเองได้</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">Technology stack</dt>
          <dd class="text-base-content/80">Claude Code + n8n + Google Apps Script / Sheets — ไม่มี vendor lock-in</dd>
        </div>
        <div class="flex flex-col gap-1 border-b border-base-content/10 pb-4 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">Handover</dt>
          <dd class="text-base-content/80">ทีมฝ่ายลูกค้า maintain ต่อเองได้ — มี documentation + training ให้</dd>
        </div>
        <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
          <dt class="font-semibold">ค่าเดินทาง (on-site ต่างจังหวัด)</dt>
          <dd class="text-base-content/80">คำนวณแยกตามจริง แจ้งก่อนรับงาน</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ===== ROI COMPARISON — Public vs In-house ===== -->
  <section class="border-b border-base-content/10 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Why In-House</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        ทำไมผมไม่จัดคอร์สเปิดทั่วไป
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/75">
        ลูกค้าของผมต้องได้มากกว่าที่จ่ายมาเสมอ ไม่ใช่แค่ได้ฟังบรรยาย
      </p>

      <div class="mt-10 overflow-x-auto rounded-2xl border border-base-content/15">
        <table class="w-full text-sm md:text-base">
          <thead>
            <tr class="border-b border-base-content/15">
              <th class="px-4 py-4 text-left font-medium text-base-content/65 md:px-6"></th>
              <th class="px-4 py-4 text-center font-semibold text-base-content/75 md:px-6">
                คอร์สทั่วไป (Public)
              </th>
              <th
                class="bg-secondary/10 px-4 py-4 text-center font-bold text-secondary md:px-6"
              >
                เรียนกับปัน (In-house)
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-content/10">
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">รูปแบบ</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                พูดเร็ว ข้ามเร็ว ตามไม่ทันก็ช่างมัน
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                ไม่ปล่อยกลับบ้านถ้ายังไม่เข้าใจ
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">Workshop</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ดูสไลด์แล้วจบ
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                จับมือทำทุกขั้นตอน
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">กลับไปแล้ว</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ทำเองไม่ได้
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                พนักงานใช้งานได้จริงทันที
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">ค่า Software</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                จ่ายรายเดือนไปเรื่อยๆ
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                เขียน App ใช้เองได้เลย
              </td>
            </tr>
            <tr>
              <td class="px-4 py-4 font-medium md:px-6">ทีมขาย</td>
              <td class="px-4 py-4 text-center text-base-content/75 md:px-6">
                ท่องสเปคไปขอส่วนลด
              </td>
              <td class="bg-secondary/[0.04] px-4 py-4 text-center text-base-content md:px-6">
                คุยกับลูกค้าได้ลึก เข้าใจ pain จริงๆ
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div
        class="mt-8 rounded-2xl border border-secondary/30 bg-secondary/[0.06] p-8 text-center"
      >
        <p class="font-display text-xl font-bold leading-tight md:text-2xl">
          จบ Workshop แล้ว ทีมคุณต้องเอาไปใช้งานได้จริง
        </p>
        <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-base-content/75">
          ผมไม่ได้มาสอนแค่ให้ฟังแล้วจบ ทุกคนที่เข้า Workshop ต้องลงมือทำจริงในห้อง
          กลับไปวันรุ่งขึ้นเปิดเครื่องมือที่สร้างไว้ใช้งานได้เลย ไม่ต้องรอใคร
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
