---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

const title = 'เกี่ยวกับปัน ณัฐพัชร์';
const description =
  'B2B Sales Consultant & Agentic AI Transformation Specialist สำหรับ SME ไทย — ประสบการณ์ 5 ปี วางระบบทีมขายที่สร้างยอดรวมกว่า 100 ล้านบาท';

const expertise = [
  {
    area: 'B2B Sales Consulting',
    detail:
      'ออกแบบ KPI + Commission structure ที่ fair + วัดได้จริง สำหรับทีมขาย 5-30 คน ทั้ง telesales, chat commerce, field sales',
  },
  {
    area: 'Agentic AI Transformation',
    detail:
      'Build AI workflow ที่เชื่อม Google Sheets / CRM / LINE / Email ด้วย Claude Code + n8n + Apps Script — maintain ได้เอง ไม่ติด vendor',
  },
  {
    area: 'Value-Based Selling',
    detail:
      'เปลี่ยนทีมจากขายของเป็นที่ปรึกษา ใช้ Jobs to be Done framework + จิตวิทยาการตัดสินใจแทน script สำเร็จรูป',
  },
  {
    area: 'Sales Psychology',
    detail:
      'สอนกระบวนการตัดสินใจ Functional / Emotional / Social — ปิด deal ด้วยคุณค่าไม่ใช่ส่วนลด',
  },
];

const principles = [
  {
    title: 'ส่ง finished product เท่านั้น',
    body: 'ไม่ส่งคำว่า "ทีหลัง" หรือ "รอบหน้า" — เอกสารและระบบต้องใช้ได้ตั้งแต่ส่งมอบครั้งแรก',
  },
  {
    title: 'AI ที่ทำงานได้จริง ไม่ใช่ demo',
    body: 'Stack ที่ผมใช้ช่วย client: Claude Code + n8n + Google Apps Script — ไม่มี no-code ราคาแพงให้ติดกับ vendor',
  },
  {
    title: '100% upfront',
    body: 'ไม่มีข้อยกเว้น — ชำระครบก่อนเริ่มงาน ทั้ง 2 ฝ่าย commit เต็มที่ตั้งแต่วันแรก',
  },
  {
    title: 'ทุกเคสได้ workflow อย่างน้อย 1 ตัว',
    body: 'กลับออกจากห้อง client ต้องมี tool ใช้งานได้จริง — วัดผลก่อน-หลังเห็นชัดในวันเดียวกัน',
  },
];

const trackRecord = [
  { metric: '10+', label: 'Active Clients', detail: 'SME รายได้ 30-200M THB ในกลุ่มวัสดุก่อสร้าง, ค้าปลีก, ที่พัก, บริการ' },
  { metric: '100M+', label: 'THB Sales Managed', detail: 'ยอดขายรวมที่ระบบของผมมีส่วน generate ในรอบ 12 เดือน' },
  { metric: '40%+', label: 'Average Sales Uplift', detail: 'ค่าเฉลี่ยที่ client เห็นในเดือน 2-4 หลัง implementation' },
  { metric: '5+', label: 'Years Field Sales', detail: 'ก่อนเปิดที่ปรึกษาเต็มตัวปี 2025' },
];

const projectsShipped = [
  {
    type: 'AI Workflow Automation',
    examples: 'KPI dashboard auto-sync, lead qualifier scoring, follow-up scheduler, quote/proposal generator, n8n integration กับ LINE OA + Google Sheets',
  },
  {
    type: 'Sales System Build',
    examples: 'Commission structure design, KPI ที่ทีม run เองได้, pipeline tracking, sales playbook + role-play training',
  },
  {
    type: 'AI Day Workshop',
    examples: 'On-site 1-day workshop ที่ทีมขายกลับไปพร้อม workflow ใช้งานได้จริง 1 ตัว วัดผลก่อน-หลังในวันเดียวกัน',
  },
  {
    type: 'Sales Training (Value + Psychology)',
    examples: 'In-house training ที่เปลี่ยนทีมจากขายของเป็นที่ปรึกษา ปิด deal โดยไม่ต้องลดราคา',
  },
];

const techStack = [
  { name: 'Claude Code', use: 'AI agent build, code generation, document automation' },
  { name: 'n8n', use: 'Workflow orchestration ที่ทีม non-tech maintain เองได้' },
  { name: 'Google Apps Script', use: 'Logic + scheduling + Sheets integration ระดับองค์กร' },
  { name: 'Google Sheets', use: 'Data layer ที่ทีมใช้เป็นอยู่แล้ว ไม่ต้องเรียนใหม่' },
  { name: 'OpenRouter / Claude API', use: 'AI calls ที่ pricing โปร่งใส ไม่มี vendor lock' },
  { name: 'LINE Messaging API', use: 'Customer interface ที่คนไทยใช้อยู่แล้ว' },
  { name: 'Astro + Tailwind', use: 'Static site + landing page build (เว็บนี้คือตัวอย่าง)' },
];

const bosiLetters = [
  {
    letter: 'B',
    name: 'Builder',
    nameTh: 'ผู้สร้างระบบ',
    color: '#7ec8f0',
    desc: 'คนที่มองเห็นโครงสร้าง วางระบบให้รันเอง ไม่ต้องพึ่งฮีโร่คนเดียว',
  },
  {
    letter: 'O',
    name: 'Opportunist',
    nameTh: 'นักล่าโอกาส',
    color: '#ff8fa3',
    desc: 'คนที่เห็นโอกาสแล้ววิ่งเข้าใส่ ปิดดีลเร็วที่สุดในทีม',
  },
  {
    letter: 'S',
    name: 'Specialist',
    nameTh: 'ผู้เชี่ยวชาญ',
    color: '#64d9f5',
    desc: 'คนที่รู้ลึก technical ลูกค้าถามอะไรก็ตอบได้หมด เป็นที่ปรึกษาในเคสซับซ้อน',
  },
  {
    letter: 'I',
    name: 'Innovator',
    nameTh: 'นักคิดค้น',
    color: '#d98fe0',
    desc: 'คนที่เห็น pattern ที่คนอื่นไม่เห็น เสนอ solution แปลกใหม่แต่ใช้ได้',
  },
];

const faqItems = [
  {
    question: 'ต่างจากเอเจนซี่ AI หรือที่ปรึกษาการขายทั่วไปยังไง',
    answer:
      'เอเจนซี่ส่งสไลด์ ผมส่งระบบ — client ทุกรายออกจากงานพร้อม AI workflow ใช้งานได้จริงอย่างน้อย 1 ตัว ไม่ใช่ roadmap หรือรายงาน 200 หน้า',
  },
  {
    question: 'ต้องมีทีม tech ก่อนไหม',
    answer:
      'ไม่ต้อง — ผมออกแบบให้ maintain ด้วย Google Sheets + n8n + Apps Script ซึ่ง non-tech ดูแลได้หลัง hand-over',
  },
  {
    question: 'เริ่มเล็กได้ไหม',
    answer:
      'ได้ — เริ่มจาก Advance AI Workshop 1 วัน ฿24,900 (ราคาพิเศษเดือนนี้ · ปกติ ฿30,000) เห็นผลจริงก่อนค่อยลงทุนต่อ · ไม่มีสัญญาผูกมัดยาว',
  },
  {
    question: 'ทำในต่างจังหวัดได้ไหม',
    answer:
      'ได้ทั้ง on-site (บวกค่าเดินทาง) และ online — workshop สายที่ต้อง on-site คือ sale training ที่ต้อง role-play',
  },
  {
    question: 'มี case study ให้ดูไหม',
    answer:
      'มี — ขอคุยผ่าน discovery call 15 นาที ผมจะ share case ที่ตรงกับ industry + team size ของคุณ ไม่ public เพราะบาง client ไม่ต้องการเปิดเผย',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['Person', 'ProfilePage', 'FAQPage', 'BreadcrumbList'],
    title,
    description,
    faq: faqItems,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'เกี่ยวกับปัน', url: `${SITE.url}/about` },
    ],
  }}
>
  <!-- ===== HEADER ===== -->
  <section class="px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">About</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight md:text-5xl">
        {title}
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        B2B Sales Consultant & Agentic AI Transformation Specialist · {SITE.author.city}, Thailand
      </p>
    </div>
  </section>

  <!-- ===== ORIGIN STORY ===== -->
  <section class="border-y border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl space-y-5 text-lg leading-relaxed text-base-content/85">
      <p>
        ผมจบ <strong class="text-base-content">วิศวกรรมเครื่องกล ม.เกษตรศาสตร์ บางเขน</strong>
        แต่ตอนเรียนก็รู้ตัวแล้วว่าชอบงานขายมากกว่าวิศวกรรม จบมาเลยไปเป็น Sale Engineer ที่ค่ายรถญี่ปุ่นค่ายหนึ่ง
      </p>
      <p>
        หลังจากนั้นกลับมาทำธุรกิจครอบครัว แล้วต่อมาก็ออกมาทำธุรกิจของตัวเอง ระหว่างทางช่วยเพื่อนนักธุรกิจหลายคนจัดระบบทีมขาย
        วาง Pipeline เพิ่ม Conversion จนตัดสินใจเอาประสบการณ์สะสม 5 ปีมาช่วย SME ไทยเต็มตัวปี 2025
      </p>
      <p>
        วันนี้บริการของผมรวม
        <strong class="text-base-content">ประสบการณ์ขาย + ความเข้าใจธุรกิจ + AI ที่ลงมือ build เอง</strong>
        เข้าด้วยกัน SME ไทยได้ระบบขายที่ทำเงินจริง ทีมวิ่งได้เอง ไม่ต้องพึ่งเซลล์คนเดียวหรือเจ้าของแบกทุกอย่าง
      </p>
      <p>
        ทุก engagement ลูกค้าต้องได้ AI workflow กลับไปใช้งานตั้งแต่วันส่งมอบ
        ไม่ใช่ roadmap หรือ presentation นี่คือ standard ที่ผมตั้งไว้และไม่ประนีประนอม
      </p>
    </div>
  </section>

  <!-- ===== MISSION ===== -->
  <section class="border-b border-base-content/10 px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div
        class="rounded-2xl border-l-4 border-l-secondary border border-base-content/15 bg-primary/40 p-8 text-center md:p-10"
      >
        <p class="text-xs font-bold uppercase tracking-widest text-secondary">Mission</p>
        <h2
          class="mx-auto mt-4 max-w-2xl font-display text-2xl font-bold leading-tight md:text-3xl"
        >
          ผมเชื่อว่า SME ไทยไม่ควรแพ้<br class="hidden md:block" />เพราะ "ไม่มีระบบ"
        </h2>
        <p class="mx-auto mt-5 max-w-xl text-[15px] leading-relaxed text-base-content/80">
          เป้าหมายของผมไม่ใช่แค่ขาย Workshop แล้วจบ ผมอยากเห็นทีมขายของลูกค้า
          <strong class="text-base-content">หลุดจากสงครามราคา</strong>
          แล้วขายด้วยคุณค่าของสินค้าจริงๆ ได้
        </p>
        <div class="mt-8 inline-block rounded-2xl border border-secondary/30 bg-secondary/10 px-8 py-5">
          <p class="text-sm text-base-content/75">เป้าหมายปี 2026</p>
          <p class="mt-1 font-display text-lg font-bold">
            ช่วย SME ไทย <span class="text-2xl text-secondary">50</span> ธุรกิจ ให้มีระบบขายที่ทำเงินได้จริง
          </p>
          <p class="mt-1 text-sm text-base-content/65">
            ตอนนี้เดินมาแล้ว <strong class="text-base-content/85">10 ธุรกิจ</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BOSI DNA Framework ===== -->
  <section class="border-b border-base-content/10 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Framework ที่ใช้ทุก Workshop</p>
      <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl">
        BOSI DNA — ตรวจ DNA นักขาย & ผู้ประกอบการของทีม
      </h2>
      <p class="mt-4 max-w-2xl text-base-content/75">
        BOSI DNA มาจากหนังสือ <em>Entrepreneurial DNA</em> โดย Joe Abraham
        ซึ่งแบ่งผู้ประกอบการและนักขายออกเป็น 4 DNA ผมใช้ Framework นี้ในทุก Workshop
        เพราะมันช่วยให้เจ้าของธุรกิจเข้าใจจุดแข็ง-จุดบอดของตัวเองและทีม ก่อนวางระบบขาย
      </p>

      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {
          bosiLetters.map((b) => (
            <div
              class="rounded-2xl border p-6 transition-all hover:-translate-y-0.5"
              style={`border-color: color-mix(in oklch, ${b.color} 30%, transparent); background: color-mix(in oklch, ${b.color} 4%, transparent);`}
            >
              <div
                class="font-display text-5xl font-black"
                style={`color: ${b.color};`}
              >
                {b.letter}
              </div>
              <h3 class="mt-3 font-display text-lg font-bold">{b.name}</h3>
              <p class="mt-0.5 text-sm text-base-content/65">{b.nameTh}</p>
              <p class="mt-3 text-sm leading-relaxed text-base-content/75">{b.desc}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-10 rounded-2xl border border-secondary/30 bg-secondary/[0.06] p-6 md:p-8">
        <p class="text-base leading-relaxed text-base-content/85">
          <strong class="text-base-content">ทีมขายที่แข็งแกร่งต้องมี DNA ที่หลากหลาย</strong>
          ไม่ใช่หา "Top Sales" ที่เหมือนกันหมด Opportunist ปิดดีลเร็วแต่ follow-up แย่
          Builder สร้างระบบเก่งแต่ชอบ deal ขนาดเล็ก ผมจะช่วยเจ้าของวาง role + commission
          ที่ match กับ DNA จริงของแต่ละคน แทนที่จะบังคับทุกคนให้ขายเหมือนกัน
        </p>
      </div>

      <div class="mt-10 text-center">
        <a
          href="/bosi-dna-quiz"
          class="btn btn-lg bg-secondary px-10 text-base font-bold text-secondary-content shadow-xl shadow-secondary/30 transition-all hover:scale-[1.02] hover:bg-secondary/90"
        >
          ทำแบบทดสอบ BOSI DNA ฟรี →
        </a>
        <p class="mt-3 text-xs text-base-content/55">
          10 ข้อ · 5-10 นาที · ไม่ต้องสมัครสมาชิก · ได้ผลทันที
        </p>
      </div>
    </div>
  </section>

  <!-- ===== EXPERTISE ===== -->
  <section class="px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-3xl font-bold tracking-tight md:text-4xl">
        สิ่งที่ผมลงลึก
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/70">
        4 หมวดหลักที่เวลาเจอปัญหาจริง ผมสามารถ build, train, และ hand over ได้เอง
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          expertise.map((item) => (
            <div class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
              <h3 class="font-display text-xl font-bold text-secondary">{item.area}</h3>
              <p class="mt-3 text-base leading-relaxed text-base-content/80">
                {item.detail}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== PRINCIPLES ===== -->
  <section class="bg-base-200/40 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-3xl font-bold tracking-tight md:text-4xl">
        หลักการทำงาน
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/70">
        4 ข้อที่ผมใช้กับทุก engagement — ไม่มีข้อยกเว้นเพราะเร่งด่วนหรือขนาดงานเล็ก
      </p>

      <ol class="mt-10 space-y-5">
        {
          principles.map((p, i) => (
            <li class="flex gap-5 rounded-2xl bg-base-100 p-6 shadow-sm">
              <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-secondary font-display text-lg font-bold text-secondary-content">
                {i + 1}
              </span>
              <div>
                <h3 class="font-display text-lg font-bold">{p.title}</h3>
                <p class="mt-2 text-base leading-relaxed text-base-content/75">{p.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===== TRACK RECORD (numbers) ===== -->
  <section class="px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Track Record</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        ที่ผ่านมา
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/70">
        ตัวเลขจริงจาก engagement 12 เดือนหลังสุด (เม.ย. 2025 - เม.ย. 2026)
      </p>

      <dl class="mt-10 grid gap-6 md:grid-cols-2">
        {
          trackRecord.map((tr) => (
            <div class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
              <dt class="text-xs uppercase tracking-widest text-base-content/55">{tr.label}</dt>
              <dd class="mt-2 font-display text-4xl font-bold text-secondary md:text-5xl">{tr.metric}</dd>
              <p class="mt-3 text-sm leading-relaxed text-base-content/75">{tr.detail}</p>
            </div>
          ))
        }
      </dl>

      <p class="mt-6 text-sm text-base-content/60">
        Client บางรายไม่ขอเปิดเผย ขอ case study ที่ตรงกับ industry คุณผ่าน discovery call ได้
      </p>
    </div>
  </section>

  <!-- ===== PROJECTS SHIPPED (anonymized types) ===== -->
  <section class="border-y border-base-content/10 bg-base-200/30 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Projects Shipped</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        งานที่ส่งมอบจริง 4 ประเภท
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/70">
        ไม่ใช่บริการบน catalog แต่คือสิ่งที่ลูกค้าได้รับจริงในแต่ละ engagement
      </p>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          projectsShipped.map((p) => (
            <div class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
              <h3 class="font-display text-lg font-bold text-secondary">{p.type}</h3>
              <p class="mt-3 text-sm leading-relaxed text-base-content/80">{p.examples}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== TECH STACK OWNED ===== -->
  <section class="px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Tech Stack</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        เครื่องมือที่ใช้จริงทุกวัน
      </h2>
      <p class="mt-3 max-w-2xl text-base-content/70">
        Stack ที่ผม build ระบบให้ลูกค้า ทุกตัวเลือกเพราะทีม non-tech ของลูกค้า maintain ต่อเองได้
      </p>

      <ul class="mt-10 divide-y divide-base-content/10 rounded-2xl border border-base-content/10 bg-base-100">
        {
          techStack.map((t) => (
            <li class="grid gap-2 p-5 sm:grid-cols-[180px_1fr] sm:items-baseline sm:gap-6">
              <span class="font-display font-bold text-secondary">{t.name}</span>
              <span class="text-sm leading-relaxed text-base-content/75">{t.use}</span>
            </li>
          ))
        }
      </ul>

      <p class="mt-5 text-sm text-base-content/60">
        ห้ามใช้ stack ที่ vendor lock เพราะ client ต้อง maintain ต่อหลังจบ engagement ไม่ใช่ผูกติดกับผมตลอดไป
      </p>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="border-t border-base-content/10 bg-base-200/30 px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-3xl font-bold tracking-tight md:text-4xl">
        คำถามที่เจอบ่อย
      </h2>
      <div class="mt-8 space-y-3">
        {
          faqItems.map((item) => (
            <details class="group rounded-xl border border-base-content/10 bg-base-100 p-5 open:shadow-md">
              <summary class="cursor-pointer list-none text-base font-semibold group-open:text-secondary">
                <span class="mr-2 font-display text-secondary">Q.</span>
                {item.question}
                <span class="float-right text-base-content/40 transition-transform group-open:rotate-180">▾</span>
              </summary>
              <p class="mt-3 text-base leading-relaxed text-base-content/75">
                {item.answer}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="px-4 py-20 lg:px-8">
    <div class="mx-auto max-w-4xl rounded-3xl bg-primary px-6 py-12 text-primary-content md:px-12">
      <h2 class="font-display text-2xl font-bold leading-tight md:text-3xl">
        อ่านถึงตรงนี้ = อาจตรงกับที่คุณมองหา
      </h2>
      <p class="mt-4 max-w-2xl text-primary-content/80">
        ตอบแบบประเมิน 3 นาที ผมอ่านแล้วส่งคำตอบกลับใน 2 วันทำการ บอกว่าเคสคุณเหมาะกับ package ไหน
      </p>
      <div class="mt-7 flex flex-wrap gap-4">
        <a
          href="/intake-form"
          class="btn btn-lg bg-secondary text-secondary-content shadow-lg shadow-secondary/30 hover:bg-secondary/90"
        >
          ประเมินปัญหาทีมขาย
        </a>
        <a
          href="/services"
          class="btn btn-lg btn-outline text-primary-content hover:bg-primary-content hover:text-primary"
        >
          ดูบริการทั้งหมด
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
