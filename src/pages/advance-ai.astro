---
import BaseLayout from '../layouts/BaseLayout.astro';

const accent = 'var(--color-pun-cyan)';
const accentHex = '#00bfbf';
const accentBtnText = '#0a1020';

const pains = [
  {
    emoji: '🔁',
    title: 'AI ช่วยได้ก็จริง แต่ต้องรอคนมาสั่งงานใหม่ทุกครั้ง',
    body: 'ถึงจะใช้ ChatGPT เป็น แต่ก็ยังต้องมานั่ง copy-paste prompt เดิมๆ ซ้ำๆ เพื่อทำงานรูทีน ทำให้เสียเวลาและมีโอกาสผิดพลาดสูง',
  },
  {
    emoji: '🏝',
    title: 'ความรู้ AI อยู่แค่กับคนในทีมไม่กี่คน',
    body: 'มีแค่เจ้าของหรือหัวหน้าทีมไม่กี่คนที่ใช้ AI เป็น ทำให้งานค้างเป็นคอขวด พออยากจะขยายผลให้ทั้งทีมใช้ ก็ไม่รู้จะเริ่มสอนจากตรงไหน',
  },
  {
    emoji: '🔌',
    title: 'ข้อมูลลูกค้าแยกกันอยู่คนละที่',
    body: 'Lead จาก LINE OA, ข้อมูลใน CRM, ออเดอร์ใน Google Sheet ไม่เคยคุยกัน ต้องใช้คน export-import เอง ทำให้ข้อมูลลูกค้าไม่ real-time',
  },
  {
    emoji: '📊',
    title: 'ยังต้องทำรีพอร์ตสรุป KPI ด้วยมือ',
    body: 'ทุกสิ้นวัน สิ้นเดือน ต้องมีคนมานั่งดึงข้อมูลจากหลายๆ ระบบเพื่อทำรีพอร์ตส่งผู้บริหาร ทั้งๆ ที่เป็นงานซ้ำๆ ที่น่าจะ automate ได้',
  },
  {
    emoji: '📨',
    title: 'ทีมขายมานั่งตามข้อมูลลูกค้าด้วยตัวเอง',
    body: 'พอมี lead ใหม่เข้ามา ทีมขายต้องคอยเช็คและ follow-up เอง ทำให้ตอบช้าบ้าง ตกหล่นบ้าง เสียโอกาสการขายไปอย่างน่าเสียดาย',
  },
];

const day1Modules = [
  { title: 'AI Agent พื้นฐาน', body: 'สร้าง AI Agent ตัวแรกที่ตอบและทำงานแทนคุณได้ ไม่ใช่แค่ chat' },
  { title: 'Workflow อัตโนมัติ', body: 'ต่อ trigger ให้ระบบวิ่งเองโดยไม่ต้องรอคนสั่ง งานรูทีนหายไปตั้งแต่วันแรก' },
  { title: 'Sales Automation เบื้องต้น', body: 'Lead เข้า → qualify → notify ทีมขาย อัตโนมัติทั้งกระบวนการ' },
  { title: 'Team Handover SOP', body: 'คู่มือส่งมอบระบบให้ทีม ทุกคนใช้ได้ ไม่ผูกกับคนคนเดียว' },
];

const day2Modules = [
  { title: 'Multi-Step Trigger Chain', body: 'Workflow ซ้อนกันหลายขั้น วิ่งเองตั้งแต่ lead เข้าจนปิดดีล ไม่ต้องสั่งระหว่างทาง' },
  { title: 'LINE OA + CRM + Sheet Integration', body: 'ข้อมูลจากทุก platform ไหลหากัน real-time ไม่มีใครต้อง copy-paste อีก' },
  { title: 'Multi-Agent Orchestration', body: 'AI หลายตัวทำงานร่วมกัน แบ่ง role ชัดเจน ระบบที่ scale ได้จริง' },
  { title: 'Auto-Report + Governance', body: 'KPI ส่งทุกเช้าอัตโนมัติ + คู่มือดูแลระบบให้หัวหน้าทีมขยายต่อเองได้' },
];

const whyPodItems = [
  {
    title: 'สอนโดยคนทำธุรกิจจริงๆ ไม่ใช่โปรแกรมเมอร์',
    body: 'ผมทำ B2B Sales มา 5 ปี ปิดดีลเอง เจอปัญหาหน้างานมาเหมือนกับทีมของคุณทุกอย่าง workflow ในเวิร์กชอปนี้เลยมาจากประสบการณ์จริง ไม่ได้มาจากตำราเล่มไหน',
  },
  {
    title: 'เวิร์กชอปส่วนตัวที่บริษัทคุณ ใช้โจทย์จริงของคุณ',
    body: 'ผมเข้าไปจัดที่ออฟฟิศของคุณเลย เราเอาปัญหาและข้อมูลจริงๆ ของคุณมาเป็นโจทย์ตั้งต้น ทีมคุณจึงได้เครื่องมือที่แก้ปัญหาตัวเองกลับไปใช้โดยตรง',
  },
  {
    title: 'สร้างระบบที่ทำงานเองได้ ไม่ใช่แค่ผู้ช่วยตอบคำถาม',
    body: 'เราเน้นสร้าง AI Agent ที่ trigger ตัวเอง ทำงาน และสรุปผลได้โดยที่ทีมไม่ต้องเข้าไปสั่งทุกครั้ง ทีม non-tech ดูแลต่อได้',
  },
  {
    title: 'วัดผล ROI ได้ตั้งแต่วันแรกที่เรียน',
    body: 'เราคำนวณเวลาและต้นทุนที่ประหยัดได้จาก workflow ที่สร้างเสร็จในห้องเรียนวันนั้นเลย คุณเห็นตัวเลข Before/After ก่อนกลับบ้าน',
  },
  {
    title: 'สร้างระบบให้เป็นของบริษัท ไม่ใช่ของที่ปรึกษา',
    body: 'ผมสอนให้หัวหน้าทีมสามารถดูแล ปรับปรุง และต่อยอด workflow ได้ด้วยตัวเอง ระบบทั้งหมดกลายเป็นทรัพย์สินของบริษัทคุณจริงๆ',
  },
];

const faqs = [
  {
    q: 'ทีมต้องเตรียมตัวอะไรบ้างก่อนวันเวิร์กชอป',
    a: 'ผมจะส่ง checklist ให้ล่วงหน้า 1 สัปดาห์ครับ สิ่งที่ต้องเตรียมหลักๆ คือ Google account, permission เข้าถึงข้อมูลที่อยากเอามาทำ automation และเตรียม workflow จริงๆ 2-3 เคสมาเล่าให้ฟังในวันงาน นอกนั้นไม่ต้องเตรียมอะไรด้านเทคนิคเลยครับ',
  },
  {
    q: 'ถ้าทีมไม่เก่งเทคโนโลยีเลย จะเรียนทันไหม',
    a: 'ทันแน่นอนครับ เวิร์กชอปนี้ออกแบบมาสำหรับ non-tech โดยเฉพาะ ลูกค้าของผม 8 ใน 10 ทีมก็ไม่มีใครเขียนโค้ดเป็น เครื่องมือที่เราใช้ถูกเลือกมาแล้วว่าคนที่ไม่ใช่โปรแกรมเมอร์ดูแลและแก้ไขเองได้ 100%',
  },
  {
    q: 'Basic Workshop (Day 1) ต่างจาก Advance Workshop (Day 2) ยังไง',
    a: 'Day 1 เน้นสร้าง AI Agent ตัวแรกให้สำเร็จ เพื่อให้ทีมเห็นภาพและลงมือทำเป็นก่อน Day 2 คือการนำ Agent ที่สร้างในวันแรกมาเชื่อมต่อกับระบบอื่น เช่น LINE OA, CRM, Google Sheets ให้ทำงานเชื่อมกันเป็น pipeline อัตโนมัติ',
  },
  {
    q: 'ต้องผ่าน Day 1 ก่อนถึงจะเรียน Day 2 ได้ไหม',
    a: 'ถ้าทีมยังไม่มีพื้นฐาน AI เลย ผมแนะนำ Bundle Day 1+2 ครับ แต่ถ้าองค์กรของคุณใช้ AI ในการทำงานอยู่แล้ว ทักมาคุยกับผมก่อนได้เลย ผมช่วยประเมินให้ว่าเริ่มจาก Day ไหนถึงจะคุ้มที่สุด',
  },
  {
    q: 'Bundle Day 1+2 จัดสองวันติดกันหรือแยก',
    a: 'แยกครับ ห่างกัน 2-4 สัปดาห์ตามที่แนะนำ เพราะต้องการให้ทีมนำ workflow ไปใช้จริงก่อน แล้วค่อย build ต่อใน Day 2 ตาม learning จากหน้างาน ถ้าซื้อ Bundle จอง Day 2 ล่วงหน้าแล้วยืนยันวันทีหลังได้',
  },
  {
    q: 'ทีมต้อง tech background ไหม',
    a: 'ไม่จำเป็นครับ stack ที่ใช้ (AI Automation Platform + Claude + Google Sheets) ออกแบบให้ non-tech ดูแลต่อเองได้ Module สุดท้ายของทุก Day สอนหัวหน้าทีมโดยเฉพาะให้ maintain และขยาย workflow ได้เอง',
  },
  {
    q: 'หลังจบเวิร์กชอป ถ้าเจอปัญหาหรือมีคำถาม ปรึกษาได้ไหม',
    a: 'ได้ครับ ในแพ็กเกจรวม 30-day LINE support อยู่แล้ว ส่งคำถามทิ้งไว้ได้เลย ผมตอบกลับภายใน 24 ชม. (จันทร์-ศุกร์) ถ้าต้องการดูแลต่อเนื่อง คุยเรื่อง Monthly Consulting เพิ่มเติมได้ครับ',
  },
];

const galleryImages = [
  { src: '/advance-ai-course/IMG_5218.JPG', alt: 'บรรยากาศ workshop in-house' },
  { src: '/advance-ai-course/testimonial5.png', alt: 'ผลลัพธ์ testimonial workshop' },
  { src: '/advance-ai-course/testimonial6.JPG', alt: 'testimonial workshop' },
  { src: '/advance-ai-course/testimonial7.JPG', alt: 'testimonial workshop' },
  { src: '/testimonial/testimonial1.jpg', alt: 'testimonial ผู้เข้าร่วม' },
  { src: '/testimonial/testimonial2.jpg', alt: 'testimonial ผู้เข้าร่วม' },
  { src: '/testimonial/testimonial3.jpg', alt: 'testimonial ผู้เข้าร่วม' },
  { src: '/testimonial/testimonial4.jpg', alt: 'testimonial ผู้เข้าร่วม' },
];
---

<BaseLayout
  title="Advance AI Workshop — สร้าง AI Agent ที่วิ่งเองได้ทั้งองค์กร · ปัน ณัฐพัชร์"
  description="In-house Workshop สอนสร้าง AI Agent แบบที่เห็นในคลิป · 1 วันเต็ม · ทีมคุณ build จริง ใช้ได้วันถัดมา · Bundle Day1+2 ฿48,900 หรือ Advance Only ฿35,800 · On-site กรุงเทพฯ และปริมณฑล"
  noindex={false}
>
  <div class="min-h-screen px-4 py-12 lg:py-20">
    <div class="mx-auto max-w-xl">

      {/* Badge */}
      <div class="flex justify-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-bold uppercase tracking-widest"
          style={`border-color: color-mix(in oklch, ${accent} 40%, transparent); background: color-mix(in oklch, ${accent} 10%, transparent); color: ${accent};`}
        >
          สร้าง AI Agent แบบที่เห็นในคลิป · In-house Workshop · กรุงเทพฯ และปริมณฑล
        </span>
      </div>

      {/* Headline */}
      <h1 class="mt-6 text-center font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl">
        อยากสร้าง AI Agent แบบในคลิป<br />
        <span style={`color: ${accent};`}>แต่ไม่รู้จะเริ่มตรงไหน?</span>
      </h1>

      <p class="mt-4 text-center text-base leading-relaxed text-base-content/75">
        ผมจะไปสอนทีมคุณถึงออฟฟิศแบบ In-house ให้สร้าง AI Agent ของตัวเองได้ใน 1 วันเต็ม
        ด้วยงบเริ่มต้นแค่หลักหมื่น ที่จะเปลี่ยนวิธีทำงานของทั้งบริษัทไปเลย
      </p>

      {/* Credential Strip */}
      <div
        class="mt-5 rounded-2xl border px-5 py-3 text-center text-sm font-semibold"
        style={`border-color: color-mix(in oklch, ${accent} 25%, transparent); background: color-mix(in oklch, ${accent} 6%, transparent); color: ${accent};`}
      >
        ที่ปรึกษา AI ด้าน Business Automation ให้กับเจ้าของธุรกิจ SME (รายได้ ฿30-200M) โดยเฉพาะ
      </div>

      {/* Path Selector */}
      <div class="mt-10">
        <p class="text-center text-base font-bold text-base-content/85">
          ตอนนี้ทีมของคุณมีพื้นฐานการใช้ AI แล้วหรือยังครับ?
        </p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">

          {/* Bundle — RECOMMENDED */}
          <div
            class="relative flex flex-col rounded-2xl border-2 p-6"
            style={`border-color: ${accent}; background: color-mix(in oklch, ${accent} 6%, transparent);`}
          >
            <span
              class="absolute -top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider"
              style={`background: ${accent}; color: ${accentBtnText};`}
            >
              ⭐ RECOMMENDED
            </span>
            <p class="mt-2 font-display text-lg font-bold" style={`color: ${accent};`}>ยังไม่มีพื้นฐาน AI</p>
            <p class="mt-1 text-xs leading-relaxed text-base-content/60">
              สำหรับทีมที่ต้องการปูพื้นฐาน AI for Business ใหม่ทั้งหมด ก่อนลงมือสร้าง Advance AI Agent ของตัวเอง
            </p>
            <div class="mt-4">
              <p class="font-display text-2xl font-bold" style={`color: ${accent};`}>฿48,900</p>
              <p class="text-xs text-base-content/55">Bundle Day 1+2 · ประหยัด ฿16,700</p>
            </div>
            <a
              href="/booking?package=ai-workshop&bundle=day1-day2"
              class="btn mt-5 w-full border-none font-bold shadow-lg"
              style={`background: ${accent}; color: ${accentBtnText};`}
            >
              จอง Bundle →
            </a>
          </div>

          {/* Advance Only */}
          <div
            class="flex flex-col rounded-2xl border p-6"
            style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 3%, transparent);`}
          >
            <p class="font-display text-lg font-bold" style={`color: ${accent};`}>มีพื้นฐาน AI แล้ว</p>
            <p class="mt-1 text-xs leading-relaxed text-base-content/60">
              สำหรับทีมที่ใช้ AI เป็นแล้ว และอยากข้ามไปสร้าง AI Agent ที่เชื่อมต่อกับระบบหลังบ้านได้ทันที
            </p>
            <div class="mt-4">
              <p class="font-display text-2xl font-bold" style={`color: ${accent};`}>฿35,800</p>
              <p class="text-xs text-base-content/55">Advance Workshop เท่านั้น</p>
            </div>
            <a
              href="/booking?package=ai-workshop-advance"
              class="btn mt-5 w-full font-bold"
              style={`border-color: color-mix(in oklch, ${accent} 50%, transparent); color: ${accent};`}
            >
              จอง Advance →
            </a>
          </div>

        </div>

        {/* Intake CTA — under path selector */}
        <a
          href="/intake-form"
          class="mt-4 flex w-full items-center justify-center gap-2 rounded-2xl border px-5 py-4 text-center text-sm transition-all hover:scale-[1.01]"
          style={`border-color: color-mix(in oklch, ${accent} 20%, transparent); background: color-mix(in oklch, ${accent} 3%, transparent);`}
        >
          <span class="text-base-content/70">หากยังไม่แน่ใจ อยากนัดคุยกับผมก่อน</span>
          <span class="font-bold" style={`color: ${accent};`}>กดที่ปุ่มนี้เลยครับ →</span>
        </a>
      </div>

      {/* Pain Points */}
      <div class="mt-12">
        <p class="text-center text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
          ปัญหาที่ AI Agent จะเข้ามาแก้
        </p>
        <div class="mt-4 space-y-3">
          {pains.map((p) => (
            <div
              class="flex items-start gap-4 rounded-2xl border p-4"
              style={`border-color: color-mix(in oklch, ${accent} 15%, transparent); background: color-mix(in oklch, ${accent} 3%, transparent);`}
            >
              <span class="mt-0.5 shrink-0 text-2xl">{p.emoji}</span>
              <div>
                <p class="font-display text-sm font-bold">{p.title}</p>
                <p class="mt-0.5 text-sm leading-relaxed text-base-content/65">{p.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Why Pun */}
      <div class="mt-14">
        <p class="text-center text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
          ทำไมต้องเรียน AI กับผม
        </p>
        <h2 class="mt-3 text-center font-display text-2xl font-bold tracking-tight">
          ผมไม่ได้แค่มาสอนคุณใช้ AI
        </h2>
        <p class="mt-2 text-center text-sm text-base-content/60">
          แต่ผมจะจับมือคุณสร้าง AI Agent ตัวแรก ให้ธุรกิจของคุณ
        </p>

        {/* 3 Stat Cards */}
        <div class="mt-6 grid grid-cols-3 gap-3">
          {[
            { stat: '5 ปี', body: 'ฟิลด์ sales B2B ปิดดีลด้วยมือตัวเอง ไม่ใช่ academic trainer' },
            { stat: '฿100M+', body: 'มูลค่าธุรกิจลูกค้า SME 10+ ราย (฿30-200M) ที่ดูแลตั้งแต่ 2025' },
            { stat: '2.29M', body: 'TikTok views organic · proof ว่าเจ้าของ SME ฟังผม' },
          ].map((item) => (
            <div
              class="rounded-2xl border p-4 text-center"
              style={`border-color: color-mix(in oklch, ${accent} 20%, transparent); background: color-mix(in oklch, ${accent} 4%, transparent);`}
            >
              <p class="font-display text-xl font-black" style={`color: ${accent};`}>{item.stat}</p>
              <p class="mt-1 text-[11px] leading-relaxed text-base-content/60">{item.body}</p>
            </div>
          ))}
        </div>

        {/* Position statement */}
        <div
          class="mt-5 rounded-2xl border-l-4 px-5 py-4"
          style={`border-left-color: ${accent}; background: color-mix(in oklch, ${accent} 5%, transparent);`}
        >
          <p class="text-sm leading-relaxed text-base-content/85">
            💡 Workshop ของผมเติมช่องว่างที่คอร์ส AI ทั่วไปทำไม่ได้: <strong>AI Workshop สำหรับทีมขาย B2B ของ SME ไทยโดยเฉพาะ</strong> ที่เน้นสร้างระบบที่ใช้ได้จริง ไม่ใช่แค่ความรู้ลอยๆ
          </p>
        </div>

