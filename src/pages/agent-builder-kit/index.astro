---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MilestoneBar from '../../components/MilestoneBar.astro';
import ManifestoBlock from '../../components/ManifestoBlock.astro';
import { SITE } from '../../data/site';

const title = 'AI Agent Builder Kit — สร้างทีม AI ที่ทำงานจริงในธุรกิจ';
const description =
  'Kit ฟรี (form-gated) สำหรับเจ้าของ SME ฿30M+ ที่อยากสร้าง AI Agent ใช้งานจริง — Manual 50pp + 5 setup files + 20+ prompts + bonus stack มูลค่ารวม ฿29,900';

const eras = [
  {
    label: 'ยุค 1',
    title: 'ใช้ AI Random ถามตอบ',
    note: 'SME ส่วนใหญ่อยู่ตรงนี้',
    accent: 'var(--color-base-content)',
  },
  {
    label: 'ยุค 2',
    title: 'มี Agent ทำงานเฉพาะทาง 1-2 ตัว',
    note: 'early adopter',
    accent: 'var(--color-pun-cyan, #22d3ee)',
  },
  {
    label: 'ยุค 3',
    title: 'ทีม AI รู้จักธุรกิจ ทำงานเป็นระบบ',
    note: 'Kit นี้พาคุณไปที่นี่',
    accent: 'var(--color-secondary, #dd4155)',
  },
];

const tiers = [
  {
    tier: 'TIER 1',
    label: 'เริ่มต้น (1 agent · ใช้แค่คุณคนเดียว)',
    math: 'Save 5 ชม./สัปดาห์ × 50 สัปดาห์ × labor ฿500/ชม.',
    save: '฿125,000 / ปี',
    outcome: '⏰ คุณได้คืนเวลา 1 วันต่อสัปดาห์',
    accent: 'var(--color-pun-cyan, #22d3ee)',
  },
  {
    tier: 'TIER 2',
    label: 'ทีมเริ่มใช้ (5 agents · ทั้ง sales team ใช้)',
    math: 'Save 80 ชม./สัปดาห์ × 50 × ฿500',
    save: '฿2,000,000 / ปี',
    outcome: '💰 เท่ากับเงินเดือนพนักงานเพิ่ม 1 คนแบบไม่ต้องจ้าง',
    accent: 'var(--color-secondary, #dd4155)',
  },
  {
    tier: 'TIER 3',
    label: 'ระบบเต็ม (15 agents · operating system)',
    math: 'Save 240 ชม./สัปดาห์ × 50 × ฿500',
    save: '฿6,000,000 / ปี',
    outcome: '🛡 ลด headcount cost ฿120k/เดือน + คืนเวลาเจ้าของ 1 วัน/สัปดาห์',
    accent: 'var(--color-pun-violet, #7c3aed)',
  },
];

const programs = [
  {
    icon: '🤖',
    badge: 'Training',
    name: 'Program 1 — Agent Operating System Manual',
    spec: '50pp Hybrid Beauty+Workbook',
    value: '฿4,900',
    bullets: [
      ['คู่มือสร้าง AI Agent ตั้งแต่ 0 → ระบบใช้งานจริง', 'คุณรู้ว่าเริ่มที่ไหน ทำอะไรลำดับใด ใช้เวลาเท่าไร'],
      ['4-phase journey × 8 modules + worksheet ทุกบท', 'ทำตามได้โดยไม่ต้องคิดเอง'],
      ['7-rule audit checklist (Step 0)', 'คัด business problem ที่ AI ติดได้จริง ไม่ใช่ติดเสียเวลา'],
    ],
  },
  {
    icon: '🛠',
    badge: 'Implementation',
    name: 'Program 2 — Setup Toolkit (5 ไฟล์ .md)',
    spec: 'Drop-in Files',
    value: '฿2,400',
    bullets: [
      ['the-architect.md → AI ที่ดูแล project structure ของคุณ', 'ไม่ต้องตั้งระบบเองทุกครั้งที่เปิด project ใหม่'],
      ['skill-business-context.md → ระบบสัมภาษณ์อัตโนมัติ', 'Claude รู้จักธุรกิจคุณภายใน 15 นาที'],
      ['skill-build-agent-team.md + skill-prompt-library.md', 'ทีม agent ที่ตั้งให้กันเอง ไม่ต้องคิดทีละคน'],
    ],
  },
  {
    icon: '📋',
    badge: 'AI Build',
    name: 'Program 3 — Prompt Library 20+',
    spec: 'Phase × Tier organized',
    value: '฿3,900',
    bullets: [
      ['20 prompt สำเร็จรูปติดตั้งใน 5 นาที', 'จาก "อ่าน manual" → "agent ทำงานจริง" ใช้เวลาแค่ copy/paste'],
      ['แต่ละ prompt มี CHECK gate + worked example', 'รู้ทันทีว่าใช้ได้กับธุรกิจคุณไหม ก่อนเสียเวลา'],
      ['แบ่งตาม Phase 1-4 + Tier 🟢🟡🔴', 'เริ่มที่ระดับที่คุณพร้อม ไม่ต้องเรียนทั้งหมดก่อน'],
    ],
  },
];

const bonuses = [
  {
    name: 'Custom GPT "Pun\'s Sales OS"',
    value: '฿9,900',
    delivery: 'ส่งทาง LINE ภายใน 7 วันหลังกรอกฟอร์ม',
    why: 'AI ที่เทรนจาก closed-won deal 100+ รายของลูกค้าปัน',
  },
  {
    name: '30-day LINE OA support during install',
    value: '฿4,900',
    delivery: 'ตอบคำถาม install ภายใน 24 ชม. (Mon-Fri)',
    why: 'ไม่ติดอยู่กับ "ลองเอง" ที่อาจหลงทาง',
  },
  {
    name: 'Free entry: monthly "Office Hours" group call',
    value: '฿3,900',
    delivery: 'ฟัง Q&A ของเจ้าของ SME คนอื่นที่ install kit เดียวกัน',
    why: 'เห็น pattern จากธุรกิจอื่นที่เจอปัญหาคล้ายคุณ',
  },
  {
    name: '🔥 FAST ACTION (50 คนแรก): 30-min strategy call กับปัน',
    value: 'นับจาก form submit timestamp · เต็มเมื่อเต็ม',
    delivery: 'audit business เฉพาะคุณ + แนะ wedge แรก',
    why: 'รู้ว่าควรเริ่ม agent ตัวแรกที่ตรงไหนก่อนกดเริ่ม',
    fastAction: true,
  },
];

const auditRules = [
  'ธุรกิจคุณรายได้ ฿30M+ ต่อปี (มี cash flow รองรับ AI tool ฿1,500-3,000/เดือน)',
  'คุณมีทีมงาน 5+ คน (agent มีคนใช้ ไม่ใช่ install แล้วใช้เอง)',
  'คุณมี Google Workspace + คอม Mac/Windows ใช้งาน (ไม่ใช่ทำธุรกิจจาก iPad อย่างเดียว)',
  'คุณพร้อมลงเวลา 4-6 ชม. ใน 30 วันแรก (อ่าน manual + ทำ worksheet + setup agent)',
  'คุณยอมรับว่า "AI ใช้แล้วต้อง iterate" — install เสร็จต้องปรับให้เก่งขึ้นเรื่อยๆ',
];

const phases = [
  {
    num: '1',
    name: 'Setup',
    do: 'ติดตั้ง Claude Code + business context + 1 agent แรก',
    time: '2-3 ชม.',
    prompts: '4 prompts',
  },
  {
    num: '2',
    name: 'Build',
    do: 'สร้าง agent team (sales / content / ops) ตามรูปแบบธุรกิจ',
    time: '3-4 ชม.',
    prompts: '8 prompts',
  },
  {
    num: '3',
    name: 'Operate',
    do: 'ใช้งานจริง วัดผล before/after ปรับ prompt ให้คม',
    time: '30 วัน',
    prompts: '5 prompts',
  },
  {
    num: '4',
    name: 'Scale',
    do: 'ขยาย agent team + handoff ให้พนักงาน maintain เอง',
    time: '60-90 วัน',
    prompts: '3 prompts',
  },
];

const faqs = [
  {
    q: 'Kit นี้ฟรีจริงไหม?',
    a: 'ฟรีจริง · ไม่มี trial · ไม่มี upsell บังคับ · ไฟล์ทั้งหมด 12 MB ดาวน์โหลดเสร็จเป็นของคุณ',
  },
  {
    q: 'ใช้กับ ChatGPT / Gemini ได้ไหม (แทน Claude Code)?',
    a: 'ได้ · prompt 20 ตัวออกแบบให้ portable · setup files (.md) ทำงานบน Claude Code ดีที่สุด แต่ adapt ใช้กับ ChatGPT Custom GPT / Gemini Gem ได้',
  },
  {
    q: 'ต้องเขียนโค้ดเป็นไหม?',
    a: 'ไม่ต้อง · ทุก prompt มี CHECK gate + worked example · copy/paste แล้วเริ่มได้',
  },
  {
    q: 'Workshop กับ Kit ต่างกันยังไง?',
    a: 'Kit = TIER 1 ทำเองได้ (1 agent ใช้คนเดียว) · Workshop = TIER 2-3 ติดตั้งทั้งทีม + ปันลงไปจูง 1 วัน on-site',
  },
  {
    q: 'รับเงินคืนไหม?',
    a: 'ไม่มีนโยบายคืนเงิน — รับเฉพาะ qualified prospect เพื่อให้ผลลัพธ์จริง',
  },
  {
    q: 'มีคอร์สออนไลน์ไหม?',
    a: 'ไม่มี · ทุก service ของผม on-site เท่านั้น · in-house workshop ไปที่ออฟฟิศคุณ · public training (P1) ในห้องเรียน',
  },
  {
    q: 'ติดตั้งที่บริษัทเราได้ไหม?',
    a: 'ได้ · นั่นคือ in-house workshop · ดู /services/ai-workshop หรือกรอก intake-form',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{ type: 'WebPage' }}
>
  <main>
    {/* 3.1 — Wow Hero (Time-arbitrage hook) */}
    <section class="relative overflow-hidden border-b border-base-content/10 bg-base-100 px-4 py-20 lg:py-28">
      <div class="mx-auto max-w-4xl">
        <p class="text-xs font-bold uppercase tracking-widest text-secondary">
          AI Agent Builder Kit · Free (form-gated)
        </p>

        <h1 class="mt-4 font-display text-3xl font-black leading-tight md:text-5xl lg:text-6xl">
          งาน 80% ของพนักงานออฟฟิศคุณ ทำได้ด้วย AI Agent ที่เซ็ตอัพภายใน 1 ชั่วโมง
        </h1>

        <p class="mt-6 font-display text-xl font-bold leading-relaxed text-base-content/85 md:text-2xl">
          ที่เหลือ 20% เป็นงานที่ต้องการมนุษย์จริงๆ — และนั่นคือคนที่คุณควรจ้างเพิ่ม
        </p>

        <p class="mt-6 text-base leading-relaxed text-base-content/75 md:text-lg">
          Kit นี้คือคู่มือแยก 80/20 + prompt 20+ ตัว ที่ผมใช้กับลูกค้า ฿30M-200M revenue
        </p>

        <p class="mt-4 text-sm text-base-content/60">
          Free Kit — Manual 50pp + 5 setup files + 20+ prompts (12 MB .zip)
        </p>

        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-secondary/30 bg-secondary/5 px-4 py-1.5 text-xs font-bold text-secondary">
          💼 Corporate Tax-Deductible 200% available (in-house track)
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="#form"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-6 py-3 font-display text-base font-bold text-white shadow-lg transition hover:bg-secondary/90"
            data-persona="owner"
          >
            🏢 ผมเป็นเจ้าของธุรกิจ
          </a>
          <a
            href="#form"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-base-content/20 bg-base-100 px-6 py-3 font-display text-base font-bold text-base-content transition hover:border-secondary/40"
            data-persona="manager"
          >
            👨‍💼 ผมเป็น Manager / Dept Head
          </a>
        </div>
      </div>
    </section>

    {/* 3.2 — Status Bar (DONE / NOW / NEXT) */}
    <MilestoneBar />

    {/* 3.3 — The Truth manifesto */}
    <ManifestoBlock />

    {/* 3.4 — 3-Question Self-Diagnostic */}
    <section class="bg-base-200/30 px-4 py-16 lg:py-20">
      <div class="mx-auto max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
          Self-diagnostic
        </p>
        <h2 class="mt-2 font-display text-2xl font-black leading-tight md:text-3xl">
          นี่คือความจริงที่เจ้าของ SME ส่วนใหญ่ไม่ยอมยอมรับ — ลองตอบ 3 คำถามนี้ก่อนกรอกฟอร์ม
        </h2>

        <ol class="mt-8 space-y-6">
          <li class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
            <p class="font-display text-lg font-bold">1️⃣ คุณใช้ ChatGPT ตอบคำถามวันละ 5-10 ครั้ง ใช่มั้ย?</p>
            <p class="mt-3 text-base leading-relaxed text-base-content/80">
              เพราะคุณยังไม่ได้ตั้ง agent ที่รู้จักธุรกิจคุณ — ทุกครั้งคือคุยจากศูนย์<br />
              เปิด → อธิบาย context → ตรวจคำตอบ → ปรับใหม่ → คัดลอกไปใช้
            </p>
          </li>
          <li class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
            <p class="font-display text-lg font-bold">2️⃣ ทุก task คุณยังต้อง prompt ใหม่ ใช่มั้ย?</p>
            <p class="mt-3 text-base leading-relaxed text-base-content/80">
              เปิด ChatGPT → คิด context → คิด instruction → ตรวจคำตอบ → ปรับใหม่<br />
              งาน 30 นาทีกินเวลา 2 ชม. เพราะ AI ไม่จำเรื่องที่คุณบอกเมื่อวาน
            </p>
          </li>
          <li class="rounded-2xl border border-base-content/10 bg-base-100 p-6">
            <p class="font-display text-lg font-bold">3️⃣ คุณยังเชื่อว่า "AI ใช้ดีต้อง prompt เก่ง" ใช่มั้ย?</p>
            <p class="mt-3 text-base leading-relaxed text-base-content/80">
              รอเรียน prompt engineering · รอ AI เก่งขึ้น · รอจังหวะลงตัว<br />
              แต่ทีมคู่แข่งติดตั้ง agent ระบบทำงานแล้วมา 6 เดือน
            </p>
          </li>
        </ol>

        <p class="mt-8 text-center font-display text-lg font-bold text-secondary">
          ถ้าตอบ "ใช่" ทั้ง 3 ข้อ — Kit ในหน้านี้ออกแบบมาให้คุณ
        </p>
      </div>
    </section>

    {/* 3.5 — PROBLEM Section (Doctor 70:20:10) */}
    <section class="bg-base-100 px-4 py-20 lg:py-24">
      <div class="mx-auto max-w-4xl">
        <p class="text-xs font-bold uppercase tracking-widest text-secondary">
          The Problem
        </p>
        <h2 class="mt-2 font-display text-3xl font-black leading-tight md:text-4xl">
          ทำไม AI ในธุรกิจคุณยังทำงานไม่เป็นระบบ
        </h2>

        {/* Block A — SYMPTOM */}
        <div class="mt-12">
          <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
            อาการที่เจอ
          </p>
          <blockquote class="mt-3 rounded-2xl border-l-4 border-secondary bg-base-200/40 p-6 font-display text-base italic leading-relaxed md:text-lg">
            <p>"พนักงาน admin คนเดียวลาออก ทุกอย่างหยุดหมด"</p>
            <p class="mt-2">"ลูกน้องเปิด ChatGPT แล้วค้างคิดว่าจะพิมพ์อะไร"</p>
            <p class="mt-2">"ทำ quote template ใช้เวลาเป็นชั่วโมง · งานซ้ำกินเวลา 4-6 ชม./วัน"</p>
            <p class="mt-2">"ส่งทีมไปเรียน AI · ตื่นเต้น 3 วัน · สัปดาห์ที่ 2 ลืมหมด"</p>
            <footer class="mt-4 text-sm not-italic text-base-content/60">
              — เจ้าของ SME ที่ปันคุยใน 6 เดือนล่าสุด
            </footer>
          </blockquote>
        </div>

        {/* Block B — ROOT CAUSE */}
        <div class="mt-12">
          <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
            รากของปัญหา
          </p>
          <div class="mt-3 rounded-2xl border border-base-content/10 bg-base-100 p-6">
            <p class="font-display text-lg font-bold">รากของปัญหาอยู่ที่ระบบ ไม่ใช่ AI หรือทีม</p>
            <div class="mt-4 space-y-2 text-base leading-relaxed text-base-content/85">
              <p>AI ดีพอแล้วในปี 2026 ทีมก็พร้อมเรียนรู้</p>
              <p>แต่ไม่มีใครจัดเก็บความรู้ของธุรกิจคุณให้ AI เข้าใจตลอดไป</p>
              <p>ทุกวันที่ผ่านไป = คุณ + ทีม คุยกับ AI ใหม่จากศูนย์</p>
              <p>งาน 30 นาทีจึงกินเวลา 2 ชม. เพราะอธิบาย context ใหม่ทุกครั้ง</p>
            </div>
          </div>
        </div>

        {/* Block C — IMPACT */}
        <div class="mt-12">
          <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
            Impact (สำหรับ SME ทีมขาย 5-10 คน)
          </p>
          <div class="mt-3 grid gap-4 md:grid-cols-3">
            <div class="rounded-2xl border border-base-content/10 bg-base-200/40 p-5">
              <p class="text-2xl">⏰</p>
              <p class="mt-2 font-display font-bold">Time Lost</p>
              <p class="mt-2 text-sm leading-relaxed text-base-content/80">
                พนักงาน 5 คน × 3 ชม./วัน อธิบาย context ให้ AI ใหม่<br />
                <span class="font-bold">= 15 ชม./วัน × 250 วัน = 3,750 ชม./ปี</span>
              </p>
            </div>
            <div class="rounded-2xl border border-base-content/10 bg-base-200/40 p-5">
              <p class="text-2xl">💰</p>
              <p class="mt-2 font-display font-bold">Money Lost</p>
              <p class="mt-2 text-sm leading-relaxed text-base-content/80">
                3,750 ชม. × labor cost ฿500/ชม.<br />
                <span class="font-bold">= ฿1,875,000 / ปี</span> ที่หายไปกับงานที่ AI ทำได้ใน 5 นาทีถ้ามี context
              </p>
            </div>
            <div class="rounded-2xl border border-base-content/10 bg-base-200/40 p-5">
              <p class="text-2xl">🛡</p>
              <p class="mt-2 font-display font-bold">Risk Accumulated</p>
              <p class="mt-2 text-sm leading-relaxed text-base-content/80">
                พนักงาน 1 คน = single point of failure<br />
                เขาลาออก = AI ของบริษัทคุณก็ลาออกตามไปด้วย (เพราะ context อยู่ในหัวเขา ไม่ใช่ในระบบ)
              </p>
            </div>
          </div>
        </div>

        {/* Block D — COST OF INACTION */}
        <div class="mt-12 rounded-2xl border-2 border-secondary/30 bg-secondary/5 p-6 md:p-8">
          <p class="text-xs font-bold uppercase tracking-widest text-secondary">
            Cost of Inaction (6 เดือน)
          </p>
          <ul class="mt-4 space-y-2 text-base leading-relaxed text-base-content/90">
            <li>• Time loss: 3,750 ชม./2 = <span class="font-bold">1,875 ชม.</span> ที่ทีมเสีย</li>
            <li>• Money loss: <span class="font-bold">฿937,500</span> ที่ไม่ควรจ่าย</li>
