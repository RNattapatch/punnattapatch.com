              </span>
            </label>

            <label class="mt-2 flex cursor-pointer items-start gap-3 rounded-xl p-3 hover:bg-base-100">
              <input
                type="checkbox"
                name="interest_intake"
                value="1"
                class="mt-1 size-5 rounded border-base-content/30 accent-secondary"
              />
