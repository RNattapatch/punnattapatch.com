    <script is:inline>
      (function () {
        const N8N_WEBHOOK = 'https://rnat.app.n8n.cloud/webhook/kit-leads-v1';
        const form = document.getElementById('kit-form');
        const btn = document.getElementById('kit-submit-btn');
        const errEl = document.getElementById('kit-form-error');
        if (!form || !btn || !errEl) return;

        function genRef() {
          const ts = Date.now().toString(36);
          const rnd = Math.random().toString(36).slice(2, 7);
          return `PN-KIT-${ts}-${rnd}`.toUpperCase();
        }

        function showError(msg) {
          errEl.textContent = msg;
          errEl.classList.remove('hidden');
        }

        form.addEventListener('submit', async function (ev) {
          ev.preventDefault();
          errEl.classList.add('hidden');

          if (!form.checkValidity()) {
            form.reportValidity();
            return;
          }

          btn.disabled = true;
          btn.textContent = 'กำลังส่ง...';

          const fd = new FormData(form);
          const ref = genRef();
          const payload = { _meta: { reference: ref, page: location.pathname } };
          fd.forEach((v, k) => { payload[k] = v; });

          // Plausible event
          if (typeof window.plausible === 'function') {
            try { window.plausible('Kit Form Submit', { props: { ref } }); } catch (_) {}
          }
          // Meta Pixel — conditional, fires only if loaded
          if (typeof window.fbq === 'function') {
            try { window.fbq('track', 'Lead', { event_id: ref }); } catch (_) {}
          }
          // TikTok Pixel — conditional, fires only if loaded
          if (typeof window.ttq === 'object' && window.ttq && typeof window.ttq.track === 'function') {
            try { window.ttq.track('CompleteRegistration', { event_id: ref }); } catch (_) {}
          }

          let webhookOk = false;
          try {
            const ctrl = new AbortController();
            const t = setTimeout(() => ctrl.abort(), 8000);
            const res = await fetch(N8N_WEBHOOK, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
              signal: ctrl.signal,
            });
            clearTimeout(t);
            webhookOk = res.ok;
          } catch (e) {
            console.error('[kit-form] webhook error', e);
          }

          // Redirect regardless of webhook (download is the contract; lead capture is best-effort)
          const interests = [];
          if (fd.get('interest_inhouse')) interests.push('inhouse');
          if (fd.get('interest_p1')) interests.push('p1');
          if (fd.get('interest_intake')) interests.push('intake');

          const url = new URL('/agent-builder-kit/thank-you', location.origin);
          url.searchParams.set('ref', ref);
          if (interests.length) url.searchParams.set('interests', interests.join(','));
          ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'fbclid', 'ttclid'].forEach((k) => {
            const v = fd.get(k);
            if (v) url.searchParams.set(k, String(v));
          });
          if (!webhookOk) url.searchParams.set('webhook', 'failed');

          location.assign(url.toString());
        });
      })();
    </script>

    {/* 3.15 — Pre-registration Screening CTA */}
