---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'placeholder' }, props: { title: 'Placeholder prompt' } },
  ];
}

interface Props {
  title: string;
}

const { slug } = Astro.params;
const { title } = Astro.props;
const description = `Prompt ${slug} — Agent Builder Kit prompt library`;
---

<BaseLayout
  title={title}
  description={description}
  schema={{ type: 'WebPage' }}
>
  <main class="mx-auto max-w-3xl px-4 py-16">
    <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
      Prompt Library
    </p>
    <h1 class="mt-2 font-display text-4xl font-bold">{title}</h1>
    <p class="mt-4 text-base-content/70">
      Phase B1 scaffold (slug: <code>{slug}</code>). Content collection schema +
      20 prompt MDs จะถูก wire ใน B7
    </p>
  </main>
</BaseLayout>
