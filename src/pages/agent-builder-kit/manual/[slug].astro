---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('manual', ({ data }: CollectionEntry<'manual'>) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'manual'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const allParts = await getCollection('manual', ({ data }: CollectionEntry<'manual'>) => !data.draft);
const sorted = allParts.sort((a, b) => a.data.part - b.data.part);
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prevPart = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextPart = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const url = `${SITE.url}/agent-builder-kit/manual/${entry.id}`;
---

<BaseLayout
  title={`Part ${data.part}: ${data.partTitle} | Agent Builder Kit Manual`}
  description={data.description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title: `Part ${data.part}: ${data.partTitle}`,
    description: data.description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Agent Builder Kit', url: `${SITE.url}/agent-builder-kit` },
      { name: `Part ${data.part}`, url },
    ],
  }}
>
  <main>
    {/* Part header */}
    <section class="border-b border-base-content/10 bg-base-100 px-4 py-10 lg:py-14">
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-secondary/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-secondary">
            Manual · Part {data.part} / 4
          </span>
          <span class="rounded-full bg-base-200/80 px-3 py-1 text-xs text-base-content/60">
            ⏱ {data.readingTime} นาที
          </span>
        </div>

        <h1 class="mt-4 font-display text-2xl font-black leading-tight md:text-4xl">
          Part {data.part}: {data.partTitle}
        </h1>

        <p class="mt-4 text-base leading-relaxed text-base-content/70 md:text-lg">
          {data.description}
        </p>
      </div>
    </section>

    {/* Part nav strip */}
    <section class="border-b border-base-content/10 bg-base-200/30 px-4 py-3">
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-wrap gap-2">
          {sorted.map((part) => (
            <a
              href={`/agent-builder-kit/manual/${part.id}`}
              class={`rounded-full px-3 py-1 text-xs font-bold transition ${
                part.id === entry.id
                  ? 'bg-secondary text-white'
                  : 'bg-base-100 text-base-content/60 hover:text-base-content border border-base-content/10'
              }`}
            >
              Part {part.data.part}
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* Markdown content */}
    <section class="bg-base-100 px-4 py-12">
      <div class="prose prose-base mx-auto max-w-3xl prose-headings:font-display prose-headings:font-black prose-pre:bg-base-200 prose-pre:text-base-content prose-code:rounded prose-code:bg-base-200/80 prose-code:px-1.5 prose-code:py-0.5 prose-table:text-sm prose-blockquote:border-secondary prose-blockquote:bg-secondary/5 prose-blockquote:not-italic prose-blockquote:rounded-xl prose-blockquote:px-5 prose-blockquote:py-1">
        <Content />
      </div>
    </section>

    {/* Prev / Next navigation */}
    <section class="border-t border-base-content/10 bg-base-200/40 px-4 py-10">
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col gap-4 sm:flex-row sm:justify-between">
          {prevPart ? (
            <a
              href={`/agent-builder-kit/manual/${prevPart.id}`}
              class="flex items-center gap-3 rounded-xl border border-base-content/10 bg-base-100 p-4 transition hover:border-secondary/30"
            >
              <span class="text-base-content/40 text-lg">←</span>
              <div>
                <p class="text-xs text-base-content/50 uppercase tracking-widest font-bold">Part {prevPart.data.part}</p>
                <p class="font-display font-bold text-sm mt-0.5">{prevPart.data.partTitle}</p>
              </div>
            </a>
          ) : <div />}

          {nextPart ? (
            <a
              href={`/agent-builder-kit/manual/${nextPart.id}`}
              class="flex items-center justify-end gap-3 rounded-xl border border-base-content/10 bg-base-100 p-4 transition hover:border-secondary/30 sm:text-right"
            >
              <div>
                <p class="text-xs text-base-content/50 uppercase tracking-widest font-bold">Part {nextPart.data.part}</p>
                <p class="font-display font-bold text-sm mt-0.5">{nextPart.data.partTitle}</p>
              </div>
              <span class="text-base-content/40 text-lg">→</span>
            </a>
          ) : <div />}
        </div>
      </div>
    </section>

    {/* Back to Kit */}
    <section class="border-t border-base-content/10 bg-base-200/20 px-4 py-8">
      <div class="mx-auto max-w-3xl text-center">
        <a
          href="/agent-builder-kit"
          class="inline-flex items-center gap-2 rounded-full border border-base-content/20 bg-base-100 px-5 py-2.5 font-display text-sm font-bold text-base-content transition hover:border-secondary/40"
        >
          ← กลับไป Agent Builder Kit
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
