---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

type Article = CollectionEntry<'pillar'> | CollectionEntry<'cluster'>;

const pillars = await getCollection('pillar', ({ data }: CollectionEntry<'pillar'>) => !data.draft);
const clusters = await getCollection('cluster', ({ data }: CollectionEntry<'cluster'>) => !data.draft);

const all: Article[] = [...pillars, ...clusters].sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime()
);

const PILLAR_LABEL: Record<string, { name: string; tagline: string }> = {
  'sales-consulting': {
    name: 'Sales Consulting',
    tagline: 'KPI, Commission, ทีมขาย — ระบบที่รันเองได้',
  },
  'ai-transformation': {
    name: 'AI Transformation',
    tagline: 'AI ที่เปลี่ยนงาน manual ทีมขายให้รันเอง',
  },
  'agentic-ai-sales': {
    name: 'Agentic AI for Sales',
    tagline: 'Agent + workflow ที่ลูกค้าเห็นว่าทำงานจริง',
  },
};

const groupedByPillar = new Map<string, Article[]>();
for (const article of all) {
  const data = article.data as { pillar?: string; parentPillar?: string };
  const pillar = data.pillar ?? data.parentPillar ?? 'misc';
  if (!groupedByPillar.has(pillar)) groupedByPillar.set(pillar, []);
  groupedByPillar.get(pillar)!.push(article);
}

const formatDate = (d: Date): string =>
  d.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });

const title = 'Insights — บทความและคู่มือ';
const description =
  'รวมบทความและคู่มือเรื่องการสร้างทีมขาย B2B + Agentic AI Transformation สำหรับ SME ไทย';
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Insights', url: `${SITE.url}/insights` },
    ],
  }}
>
  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Insights</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight md:text-5xl">
        บทความและคู่มือ
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        รวมประสบการณ์จริงจากการวางระบบขายให้ SME ไทย — เอามาเขียนเป็นบทความที่อ่านแล้วเอาไปใช้ได้
      </p>
    </div>
  </section>

  {all.length === 0 ? (
    <section class="px-4 pb-20 lg:px-8">
      <div class="mx-auto max-w-2xl rounded-2xl border border-dashed border-base-content/20 bg-base-200/30 p-10 text-center">
        <p class="font-display text-xl font-bold">บทความแรกกำลังเขียน</p>
        <p class="mt-3 text-base-content/70">
          ระหว่างรอ ลองดู
          <a href="/services" class="text-secondary underline">บริการ 4 packages</a>
          หรือ
          <a href="/about" class="text-secondary underline">ประวัติของปัน</a>
          ไปก่อน
        </p>
      </div>
    </section>
  ) : (
    <section class="border-t border-base-content/10 bg-base-200/20 px-4 py-16 lg:px-8">
      <div class="mx-auto max-w-5xl space-y-16">
        {Array.from(groupedByPillar.entries()).map(([pillarKey, articles]) => {
          const meta = PILLAR_LABEL[pillarKey];
          return (
            <div>
              <header class="mb-8">
                <h2 class="font-display text-2xl font-bold tracking-tight md:text-3xl">
                  {meta?.name ?? pillarKey}
                </h2>
                {meta && <p class="mt-2 text-base-content/70">{meta.tagline}</p>}
              </header>
              <ul class="grid gap-5 md:grid-cols-2">
                {articles.map((article) => (
                  <li>
                    <a
                      href={`/insights/${article.id}`}
                      class="group block h-full rounded-2xl border border-base-content/10 bg-base-100 p-6 transition hover:border-secondary/50 hover:shadow-md"
                    >
                      <p class="text-xs uppercase tracking-widest text-base-content/50">
                        {formatDate(article.data.published)}
                      </p>
                      <h3 class="mt-2 font-display text-xl font-bold leading-tight group-hover:text-secondary">
                        {article.data.title}
                      </h3>
                      <p class="mt-3 text-sm leading-relaxed text-base-content/75">
                        {article.data.description}
                      </p>
                      {article.data.tags.length > 0 && (
                        <ul class="mt-4 flex flex-wrap gap-2">
                          {article.data.tags.slice(0, 3).map((tag: string) => (
                            <li class="rounded-full border border-base-content/10 px-2 py-0.5 text-xs text-base-content/60">
                              #{tag}
                            </li>
                          ))}
                        </ul>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
