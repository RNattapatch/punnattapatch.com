---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

type Article = CollectionEntry<'pillar'> | CollectionEntry<'cluster'>;

const pillars = await getCollection('pillar', ({ data }: CollectionEntry<'pillar'>) => !data.draft);
const clusters = await getCollection('cluster', ({ data }: CollectionEntry<'cluster'>) => !data.draft);

const all: Article[] = [...pillars, ...clusters].sort(
  (a, b) => b.data.published.getTime() - a.data.published.getTime()
);

// Color per pillar (violet reserved for Marketing/Content — see ArticleHero.astro)
type PillarAccent = 'cyan' | 'coral' | 'violet' | 'emerald';
const PILLAR_LABEL: Record<string, { name: string; tagline: string; accent: PillarAccent }> = {
  'sales-consulting': {
    name: 'Sales Consulting',
    tagline: 'KPI, Commission, ทีมขาย ระบบที่รันเองได้',
    accent: 'coral',
  },
  'ai-transformation': {
    name: 'AI Transformation',
    tagline: 'AI ที่เปลี่ยนงาน manual ทีมขายให้รันเอง',
    accent: 'cyan',
  },
  'agentic-ai-sales': {
    name: 'Agentic AI Agent',
    tagline: 'Agent + workflow ที่ลูกค้าเห็นว่าทำงานจริง',
    accent: 'emerald',
  },
};

function accentVar(accent: PillarAccent): string {
  switch (accent) {
    case 'cyan':
      return 'var(--color-pun-cyan)';
    case 'violet':
      return 'var(--color-pun-violet)';
    case 'emerald':
      return 'var(--color-pun-emerald)';
    default:
      return 'var(--color-pun-coral)';
  }
}

const groupedByPillar = new Map<string, Article[]>();
for (const article of all) {
  const data = article.data as { pillar?: string; parentPillar?: string };
  const pillar = data.pillar ?? data.parentPillar ?? 'misc';
  if (!groupedByPillar.has(pillar)) groupedByPillar.set(pillar, []);
  groupedByPillar.get(pillar)!.push(article);
}

const formatDate = (d: Date): string =>
  d.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });

const title = 'บทเรียน 100 ล้าน — บทความจากประสบการณ์จริง';
const description =
  'บทความจากประสบการณ์ 5 ปี สร้างทีมขายให้ SME ไทยปิดยอดรวม 100M+ THB — ทั้ง Sales Consulting, AI Transformation, และ Agentic AI สำหรับทีมขาย';
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Insights', url: `${SITE.url}/insights` },
    ],
  }}
>
  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Lessons from the Field</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl">
        บทเรียนจาก 100+ ล้านบาท<br class="hidden md:block" />ที่ผมช่วย SME ไทยปิดยอด
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        ไม่ใช่ทฤษฎีจาก MBA — เคสจริง ตัวเลขจริง จาก client ที่ผมเข้าไปวางระบบเอง
        เอาไปใช้ได้ทันทีไม่ต้องรอผม
      </p>
    </div>
  </section>

  {all.length === 0 ? (
    <section class="px-4 pb-20 lg:px-8">
      <div class="mx-auto max-w-2xl rounded-2xl border border-dashed border-base-content/20 bg-base-200/30 p-10 text-center">
        <p class="font-display text-xl font-bold">บทความแรกกำลังเขียน</p>
        <p class="mt-3 text-base-content/70">
          ระหว่างรอ ลองดู
          <a href="/services" class="text-secondary underline">บริการ 4 packages</a>
          หรือ
          <a href="/about" class="text-secondary underline">ประวัติของปัน</a>
          ไปก่อน
        </p>
      </div>
    </section>
  ) : (
    <section class="border-t border-base-content/10 bg-base-200/20 px-4 py-16 lg:px-8">
      <div class="mx-auto max-w-5xl space-y-16">
        {Array.from(groupedByPillar.entries()).map(([pillarKey, articles]) => {
          const meta = PILLAR_LABEL[pillarKey];
          const accent = meta ? accentVar(meta.accent) : 'var(--color-pun-coral)';
          return (
            <div>
              <header class="mb-8 border-l-4 pl-4" style={`border-color: ${accent}`}>
                <p class="text-xs uppercase tracking-widest" style={`color: ${accent}`}>
                  Pillar
                </p>
                <h2 class="mt-1 font-display text-2xl font-bold tracking-tight md:text-3xl">
                  {meta?.name ?? pillarKey}
                </h2>
                {meta && <p class="mt-2 text-base-content/75">{meta.tagline}</p>}
              </header>
              <ul class="grid gap-5 md:grid-cols-2">
                {articles.map((article) => (
                  <li>
                    <a
                      href={`/insights/${article.id}`}
                      class="group relative block h-full overflow-hidden rounded-2xl border border-base-content/10 bg-base-200 p-6 transition hover:-translate-y-0.5 hover:shadow-lg"
                      style={`--card-accent: ${accent};`}
                    >
                      <div
                        class="absolute inset-x-0 top-0 h-[2px] opacity-60 transition group-hover:opacity-100"
                        style="background: linear-gradient(to right, transparent, var(--card-accent), transparent);"
                      ></div>
                      <p class="text-xs uppercase tracking-widest text-base-content/55">
                        {formatDate(article.data.published)}
                      </p>
                      <h3
                        class="mt-2 font-display text-xl font-bold leading-tight transition"
                        style="color: var(--color-base-content);"
                      >
                        {article.data.title}
                      </h3>
                      <p class="mt-3 text-sm leading-relaxed text-base-content/80">
                        {article.data.description}
                      </p>
                      {article.data.tags.length > 0 && (
                        <ul class="mt-4 flex flex-wrap gap-2">
                          {article.data.tags.slice(0, 3).map((tag: string) => (
                            <li
                              class="rounded-full border px-2 py-0.5 text-xs text-base-content/70"
                              style="border-color: color-mix(in oklch, var(--card-accent) 25%, transparent);"
                            >
                              #{tag}
                            </li>
                          ))}
                        </ul>
                      )}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>
    </section>
  )}
</BaseLayout>
