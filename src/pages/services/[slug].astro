---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import WhyMeSection from '../../components/WhyMeSection.astro';
import { SITE, SERVICES } from '../../data/site';
import { SERVICE_DETAILS, type AccentToken } from '../../data/serviceDetails';

export function getStaticPaths() {
  return SERVICES.map((svc) => ({ params: { slug: svc.slug } }));
}

const { slug } = Astro.params;
const svc = SERVICES.find((s) => s.slug === slug)!;
const detail = SERVICE_DETAILS[slug as string]!;

// Bundle upsell offer per service — Pakorn-style "level up" CTA (if configured)
interface BundleUpsell {
  eyebrow: string;
  headline: string;
  tagline: string;
  timeline: { step: string; label: string; body: string }[];
  compareTitle: string;
  compareLines: { item: string; price: string; muted?: boolean }[];
  totalSeparate: string;
  totalBundle: string;
  savings: string;
  includes: string[];
  ctaLabel: string;
  ctaHref: string;
}
const BUNDLE_MAP: Record<string, BundleUpsell> = {
  'ai-workshop': {
    eyebrow: 'Level Up · ต่อยอดอีกนิด',
    headline: 'เรียน 1 วันไม่พอ — ให้ผมคุมระบบต่อให้ 30 วัน',
    tagline: 'Workshop + Consult 30 วัน · ทำเป็น เข้าใจ เห็นผล · ทีมไม่ล้มเลิกกลางทาง',
    timeline: [
      { step: 'Day 1',    label: 'Workshop',     body: 'Build AI Agent ตัวแรก ในห้อง' },
      { step: 'Week 1-2', label: 'Iterate',      body: 'Weekly 1:1 · ปรับระบบตาม pain หน้างาน' },
      { step: 'Week 3',   label: 'Expand',       body: 'Build workflow ตัวที่ 2 · ขยาย scope' },
      { step: 'Week 4',   label: 'Handover',     body: 'Team lead ดูแลต่อ · ผมออก · ระบบยัง run' },
    ],
    compareTitle: 'ถ้าซื้อแยก vs bundle',
    compareLines: [
      { item: 'Advance AI & Business Automation (1 วัน)', price: '฿24,900' },
      { item: 'Monthly Consulting Retainer (30 วัน)',     price: '฿45,000' },
    ],
    totalSeparate: '฿69,900',
    totalBundle:   '฿44,900',
    savings:       'ประหยัด ฿25,000',
    includes: [
      'Workshop 1 วันเต็ม ครบเนื้อหา 8 modules (เหมือนแพ็กเกจปกติ)',
      'Private Consult 1:1 กับ Pun 4 ครั้ง · สัปดาห์ละครั้ง ตลอด 30 วัน',
      'สร้าง AI Agent เพิ่มอย่างน้อย 1 ตัว ตามโจทย์ของลูกค้า',
      'ถาม-ตอบผ่าน LINE ได้ไม่จำกัด · ตอบใน 24 ชม. วันทำการ',
      'คู่มือดูแลระบบ + วิดีโออัดหน้าจอทุก session',
    ],
    ctaLabel: 'จอง Bundle · ฿44,900 (Early Bird ถึง 30 เม.ย.)',
    ctaHref:  '/booking?package=ai-workshop&bundle=consult-30',
  },
};
const bundle = BUNDLE_MAP[slug as string];

// ROI benefit cards per service — concrete before/after numbers per Pun's calculation (2026-04-20)
interface RoiCard {
  label: string;
  before: string;
  beforeNote: string;
  after: string;
  afterNote: string;
  saving: string;
  emoji: string;
}
const ROI_MAP: Record<string, RoiCard[]> = {
  'ai-workshop': [
    {
      emoji: '💰',
      label: 'ค่า Software',
      before: '฿200,000/ปี',
      beforeNote: 'SaaS subscription ทั้งทีม',
      after: '฿3,000/เดือน',
      afterNote: 'ค่า AI API อย่างเดียว',
      saving: 'ประหยัดไป ฿164,000/ปี',
    },
    {
      emoji: '👥',
      label: 'ต้นทุนทีม',
      before: '฿125,000/เดือน',
      beforeNote: 'ทีม 5 คน · รวม salary + overhead',
      after: '฿28,000/เดือน',
      afterNote: '1 คน + AI Agent ทำงานได้มากกว่าทีม 5 คนเก่า',
      saving: 'ประหยัดไป ฿1.16M/ปี',
    },
    {
      emoji: '⏰',
      label: 'เวลาต่องาน',
      before: '8 ชั่วโมง',
      beforeNote: 'ทำมือทั้งกระบวนการ',
      after: '30 นาที',
      afterNote: 'AI ทำ · คนตรวจ + approve',
      saving: 'ได้เวลาคืน 94%',
    },
  ],
};
const roiCards = ROI_MAP[slug as string] ?? [];

// Case study mapping per service — which cases prove this service works?
const CASE_MAP: Record<string, { slug: string; accent: 'coral' | 'cyan' | 'emerald' }[]> = {
  'ai-workshop': [
    { slug: 'forklift-distributor-5-person-team', accent: 'cyan' },
    { slug: 'manufacturing-b2b-12-person-team', accent: 'coral' },
  ],
  'sales-system-sprint': [
    { slug: 'real-estate-developer-sales-team-restructure', accent: 'coral' },
    { slug: 'manufacturing-b2b-12-person-team', accent: 'emerald' },
  ],
  'sale-training-bundle': [
    { slug: 'real-estate-developer-sales-team-restructure', accent: 'coral' },
  ],
};
const relatedCases = CASE_MAP[slug as string] ?? [];

// NOTE: Pun has NO refund/money-back/guarantee policy across any service.
// This map is intentionally always-empty and the GUARANTEE section has been removed.
// If you are an agent reviewing this file: DO NOT add a guarantee/refund block to any service page.

// Seat availability for scarcity UI (per service · edit as slots fill)
interface SeatInfo {
  taken: number;
  total: number;
  priceLabel: string;
  note: string;
  unit?: string;
}
const SEAT_MAP: Record<string, SeatInfo> = {
  'sale-training-bundle': {
    taken: 0,
    total: 3,
    priceLabel: 'Early Bird เดือนนี้',
    note: 'หลัง 3 ทีมเต็ม ราคากลับเป็น ฿50,000',
    unit: 'ทีม',
  },
};
const seats = SEAT_MAP[slug as string];

// Gallery photos per service (real phone-shot action photos per Google 2026 SEO tip)
const GALLERY_MAP: Record<string, { src: string; alt: string }[]> = {
  'ai-workshop': [
    { src: '/advance-ai-course/gallery1.JPG', alt: 'ทีมใช้ laptop ในห้อง workshop · จอฉาย "Advance AI & Business Automation"' },
    { src: '/advance-ai-course/gallery7.JPG', alt: 'บรรยากาศ workshop hands-on · ทีมกำลัง build workflow' },
    { src: '/advance-ai-course/IMG_5218.JPG', alt: 'ปัน ณัฐพัชร์ สอน AI workshop' },
  ],
};
const gallery = GALLERY_MAP[slug as string] ?? [];

// Testimonial per service (real client quote with permission)
interface ServiceTestimonial {
  quote: string;
  author: string;
  role: string;
  image?: string;
}
const TESTIMONIAL_MAP: Record<string, ServiceTestimonial> = {
  'ai-workshop': {
    quote: 'ทีมใช้ AI เก่งขึ้นเยอะ จากเดิมไม่กล้าใช้เพราะกลัว prompt ผิด ตอนนี้สร้าง Web-App ใช้กันเองแล้ว ประหยัดเวลาไปได้เยอะเลย · จากงานที่ต้องใช้เวลาทั้งวัน ตอนนี้เสร็จภายใน 15 นาทีได้ · เมื่อก่อน AI Chat ธรรมดายังไม่อยากใช้ ตอนนี้สร้าง Agent ทำงานแทนเป็นเรื่องปกติ — มาแข่งกันว่าใครจะลดเวลาได้มากกว่า',
    author: 'คุณฝน',
    role: 'Monthly Consulting Client',
  },
};
const testimonial = TESTIMONIAL_MAP[slug as string];

const accentVar = (a: AccentToken): string =>
  a === 'cyan'
    ? 'var(--color-pun-cyan)'
    : a === 'violet'
      ? 'var(--color-pun-violet)'
      : 'var(--color-pun-coral)';

const accent = accentVar(detail.accent);
const accentButtonText = detail.accent === 'cyan' ? '#0a1020' : 'white';

const title = `${svc.title} — ${detail.priceHeadline}`;
const description = detail.subhead;
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'Service', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'บริการ', url: `${SITE.url}/services` },
      { name: svc.title, url: `${SITE.url}/services/${svc.slug}` },
    ],
  }}
>
  <!-- ===== HERO ===== -->
  <section
    class="relative overflow-hidden px-4 py-16 lg:px-8 lg:py-24"
    style={`background: linear-gradient(180deg, color-mix(in oklch, ${accent} 6%, transparent), transparent 60%);`}
  >
    <div class="mx-auto max-w-4xl">
      <div class="mb-6 flex items-center gap-2 text-sm">
        <a href="/services" class="text-base-content/60 hover:text-secondary">บริการ</a>
        <span class="text-base-content/40">/</span>
        <span class="text-base-content/80">{svc.title}</span>
      </div>

      <div class="mb-6 flex flex-wrap items-center gap-3">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold tracking-wide"
          style={`border-color: color-mix(in oklch, ${accent} 35%, transparent); background: color-mix(in oklch, ${accent} 10%, transparent); color: ${accent};`}
        >
          {detail.eyebrow}
        </div>
        {
          seats && (
            <div class="inline-flex items-center gap-2 rounded-full border-2 border-rose-500/50 bg-rose-500/15 px-4 py-1.5 text-xs font-bold text-rose-700 dark:text-rose-300">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-500 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"></span>
              </span>
              🔥 เหลือ {seats.total - seats.taken} {seats.unit ?? 'ที่'} จาก {seats.total} {seats.unit ?? 'ที่'} · {seats.priceLabel}
            </div>
          )
        }
      </div>

      <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
        {detail.headline}
        <br class="hidden md:block" />
        <span class="md:whitespace-nowrap" style={`color: ${accent};`}>{detail.headlineAccent}</span>
        {detail.headlineTail && <><br class="hidden md:block" />{detail.headlineTail}</>}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-base-content/80 md:text-xl">
        {detail.subhead}
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={`/booking?package=${svc.slug}`}
          class="btn btn-lg border-none font-bold shadow-xl transition-all hover:scale-105"
          style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 15px 40px -15px color-mix(in oklch, ${accent} 50%, transparent);`}
        >
          จองเลย — {detail.priceHeadline}
        </a>
        <a
          href="/intake-form"
          class="btn btn-lg btn-ghost border border-base-content/25 hover:bg-base-200"
        >
          ไม่แน่ใจ? นัดคุยกับปันก่อน →
        </a>
      </div>
    </div>
  </section>

  {/* ===== PRICE URGENCY + CTA — above Problem section · only for ai-workshop ===== */}
  {slug === 'ai-workshop' && (
    <section class="border-t border-base-content/10 px-4 py-12 lg:px-8 lg:py-14">
      <div class="mx-auto max-w-4xl">
        <div
          class="overflow-hidden rounded-3xl border-2 p-8 shadow-2xl md:p-10"
          style={`border-color: color-mix(in oklch, ${accent} 45%, transparent); background: linear-gradient(135deg, color-mix(in oklch, ${accent} 8%, transparent) 0%, color-mix(in oklch, ${accent} 3%, transparent) 60%, transparent 100%); box-shadow: 0 25px 60px -20px color-mix(in oklch, ${accent} 30%, transparent);`}
          data-countdown-wrap
        >
          <div data-countdown-visible>
            {/* Top row: badge + price pivot notice */}
            <div class="flex flex-col items-center gap-3 text-center">
              <div
                class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-bold uppercase tracking-widest"
                style={`border-color: color-mix(in oklch, ${accent} 45%, transparent); background: color-mix(in oklch, ${accent} 12%, transparent); color: ${accent};`}
              >
                <span class="relative flex h-2 w-2">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style={`background: ${accent};`}></span>
                  <span class="relative inline-flex h-2 w-2 rounded-full" style={`background: ${accent};`}></span>
                </span>
                ⏰ Early Bird ปิดใน
              </div>

              {/* Countdown digits — reuses [data-cd-*] targets from inline script at bottom of page */}
              <div class="mt-2 grid grid-cols-4 gap-3 md:gap-5">
                <div
                  class="min-w-[64px] rounded-xl border px-3 py-3 md:min-w-[80px] md:px-4 md:py-4"
                  style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 8%, transparent);`}
                >
                  <div data-cd-days class="font-display text-3xl font-black tabular-nums md:text-4xl" style={`color: ${accent};`}>--</div>
                  <div class="mt-1 text-[10px] uppercase tracking-wider text-base-content/60 md:text-xs">วัน</div>
                </div>
                <div
                  class="min-w-[64px] rounded-xl border px-3 py-3 md:min-w-[80px] md:px-4 md:py-4"
                  style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 8%, transparent);`}
                >
                  <div data-cd-hours class="font-display text-3xl font-black tabular-nums md:text-4xl" style={`color: ${accent};`}>--</div>
                  <div class="mt-1 text-[10px] uppercase tracking-wider text-base-content/60 md:text-xs">ชั่วโมง</div>
                </div>
                <div
                  class="min-w-[64px] rounded-xl border px-3 py-3 md:min-w-[80px] md:px-4 md:py-4"
                  style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 8%, transparent);`}
                >
                  <div data-cd-mins class="font-display text-3xl font-black tabular-nums md:text-4xl" style={`color: ${accent};`}>--</div>
                  <div class="mt-1 text-[10px] uppercase tracking-wider text-base-content/60 md:text-xs">นาที</div>
                </div>
                <div
                  class="min-w-[64px] rounded-xl border px-3 py-3 md:min-w-[80px] md:px-4 md:py-4"
                  style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 8%, transparent);`}
                >
                  <div data-cd-secs class="font-display text-3xl font-black tabular-nums md:text-4xl" style={`color: ${accent};`}>--</div>
                  <div class="mt-1 text-[10px] uppercase tracking-wider text-base-content/60 md:text-xs">วินาที</div>
                </div>
              </div>

              {/* Price pivot message */}
              <p class="mt-4 text-sm leading-relaxed text-base-content/75 md:text-base">
                ราคา <strong class="font-display text-base md:text-lg" style={`color: ${accent};`}>฿24,900</strong>
                เปิดถึง <strong>30 เมษายน 2026</strong>
                <span class="mx-2 text-base-content/40">·</span>
                <strong>1 พฤษภาคม</strong> ปรับเป็น <strong class="line-through decoration-rose-500/70 decoration-2">฿29,900</strong>
              </p>
              <p class="max-w-xl text-xs leading-relaxed text-base-content/60 md:text-sm">
                จองวันนี้ lock ราคาเดิม · ยืนยันวันอบรมได้ภายใน 30 วัน
              </p>
            </div>

            {/* CTAs */}
            <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center">
              <a
                href={`/booking?package=${svc.slug}`}
                class="btn btn-lg border-none font-bold shadow-xl transition-all hover:scale-105"
                style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 15px 40px -15px color-mix(in oklch, ${accent} 50%, transparent);`}
              >
                จอง ฿24,900 เลย →
              </a>
              <a
                href="/intake-form"
                class="btn btn-lg btn-ghost border border-base-content/25 hover:bg-base-200"
              >
                ไม่แน่ใจ? นัดคุยกับปันก่อน
              </a>
            </div>
          </div>

          {/* Expired state — shown after 30 Apr 2026 23:59 ICT */}
          <div class="hidden text-center" data-countdown-expired>
            <p class="font-display text-2xl font-bold md:text-3xl" style={`color: ${accent};`}>
              ⏰ Early Bird ปิดแล้ว
            </p>
            <p class="mt-3 text-base text-base-content/75">
              ราคาปัจจุบัน <strong style={`color: ${accent};`}>฿29,900</strong> · ยังจองได้ตามสิทธิ์ปกติ
            </p>
            <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
              <a
                href={`/booking?package=${svc.slug}`}
                class="btn btn-lg border-none font-bold"
                style={`background: ${accent}; color: ${accentButtonText};`}
              >
                จอง ฿29,900 →
              </a>
              <a href="/intake-form" class="btn btn-lg btn-ghost border border-base-content/25">
                นัดคุยกับปันก่อน
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ===== PAIN POINTS — high-impact "ขยี้แผล" visual treatment ===== -->
  <section class="relative overflow-hidden border-t border-base-content/10 px-4 py-20 lg:px-8 lg:py-24">
    {/* Dramatic dark gradient bg — creates "weight" for pain section */}
    <div
      class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse at 50% 30%, rgba(244,63,94,0.08), transparent 60%), linear-gradient(180deg, rgba(0,0,0,0.02), rgba(244,63,94,0.04) 50%, rgba(0,0,0,0.02));"
    ></div>

    <div class="mx-auto max-w-6xl">
      {/* Eyebrow + headline — larger, emotional */}
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-rose-500/40 bg-rose-500/10 px-4 py-1.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-500 opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"></span>
          </span>
          <p class="text-xs font-bold uppercase tracking-widest text-rose-600 dark:text-rose-400">
            Problem · ถ้าใช่ · อ่านต่อ
          </p>
        </div>

        <h2 class="mx-auto mt-5 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
          เจอปัญหาแบบนี้อยู่ไหม?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base text-base-content/70 md:text-lg">
          6 pain ที่ผมเจอซ้ำๆ จาก SME เกือบทุกราย · ถ้าคุณตอบ "ใช่" แม้แค่ 1 ข้อ — workshop นี้จะแก้ให้ได้จริงใน 1 วัน
        </p>
      </div>

      {/* Pain cards — bigger emoji · rose left-border · stronger contrast */}
      <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          detail.pains.map((p, i) => (
            <div
              class="group relative overflow-hidden rounded-2xl border border-base-content/10 bg-base-100/90 p-7 shadow-md backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl md:p-8"
            >
              {/* Rose-accent left border (pain signal) */}
              <div
                class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-rose-500 via-rose-500/70 to-rose-500/30 transition-all duration-300 group-hover:w-1.5"
              ></div>

              {/* Pain number badge (top-right) */}
              <span class="absolute right-4 top-4 font-display text-xs font-bold text-base-content/25 md:text-sm">
                {String(i + 1).padStart(2, '0')}
              </span>

              {/* Big emoji */}
              <div class="text-4xl md:text-5xl">{p.emoji}</div>

              {/* Title — bigger, heavier */}
              <h3 class="mt-5 font-display text-lg font-bold leading-snug md:text-xl">
                {p.title}
              </h3>

              {/* Body */}
              <p class="mt-3 text-sm leading-relaxed text-base-content/80 md:text-[15px]">
                {p.body}
              </p>
            </div>
          ))
        }
      </div>

      {/* Bridge to solution — "ขยี้แผล" then "ให้ยา" */}
      <div class="mx-auto mt-14 max-w-2xl text-center">
        <p class="font-display text-lg font-bold md:text-xl">
          ถ้าตอบ "ใช่" ≥ 1 ข้อ
        </p>
        <p class="mt-2 text-base text-base-content/75">
          คุณไม่ได้อยู่คนเดียว · และนี่คือสิ่งที่ workshop 1 วัน แก้ให้ได้จริง ↓
        </p>
      </div>
    </div>
  </section>

  <!-- ===== AUDIENCE ===== -->
  <section class="border-t border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">เหมาะกับ</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
