---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseCard from '../../components/CaseCard.astro';
import { SITE, SERVICES } from '../../data/site';
import { SERVICE_DETAILS, type AccentToken } from '../../data/serviceDetails';

export function getStaticPaths() {
  return SERVICES.map((svc) => ({ params: { slug: svc.slug } }));
}

const { slug } = Astro.params;
const svc = SERVICES.find((s) => s.slug === slug)!;
const detail = SERVICE_DETAILS[slug as string]!;

// Bundle upsell offer per service — Pakorn-style "level up" CTA (if configured)
interface BundleUpsell {
  eyebrow: string;
  headline: string;
  tagline: string;
  timeline: { step: string; label: string; body: string }[];
  compareTitle: string;
  compareLines: { item: string; price: string; muted?: boolean }[];
  totalSeparate: string;
  totalBundle: string;
  savings: string;
  includes: string[];
  ctaLabel: string;
  ctaHref: string;
}
const BUNDLE_MAP: Record<string, BundleUpsell> = {
  'ai-workshop': {
    eyebrow: 'Level Up · ต่อยอดอีกนิด',
    headline: 'เรียน 1 วันไม่พอ — ให้ผมคุมระบบต่อให้ 30 วัน',
    tagline: 'Workshop + Consult 30 วัน · ทำเป็น เข้าใจ เห็นผล · ทีมไม่ล้มเลิกกลางทาง',
    timeline: [
      { step: 'Day 1',    label: 'Workshop',     body: 'Build AI Agent ตัวแรก ในห้อง' },
      { step: 'Week 1-2', label: 'Iterate',      body: 'Weekly 1:1 · ปรับระบบตาม pain หน้างาน' },
      { step: 'Week 3',   label: 'Expand',       body: 'Build workflow ตัวที่ 2 · ขยาย scope' },
      { step: 'Week 4',   label: 'Handover',     body: 'Team lead ดูแลต่อ · ผมออก · ระบบยัง run' },
    ],
    compareTitle: 'ถ้าซื้อแยก vs bundle',
    compareLines: [
      { item: 'Advance AI & Business Automation (1 วัน)', price: '฿24,900' },
      { item: 'Monthly Consulting Retainer (30 วัน)',     price: '฿45,000' },
    ],
    totalSeparate: '฿69,900',
    totalBundle:   '฿44,900',
    savings:       'ประหยัด ฿25,000',
    includes: [
      'Workshop 1 วันเต็ม ครบเนื้อหา 8 modules (เหมือนแพ็กเกจปกติ)',
      'Private Consult 1:1 กับ Pun 4 ครั้ง · สัปดาห์ละครั้ง ตลอด 30 วัน',
      'สร้าง AI Agent เพิ่มอย่างน้อย 1 ตัว ตามโจทย์ของลูกค้า',
      'ถาม-ตอบผ่าน LINE ได้ไม่จำกัด · ตอบใน 24 ชม. วันทำการ',
      'คู่มือดูแลระบบ + วิดีโออัดหน้าจอทุก session',
    ],
    ctaLabel: 'จอง Bundle · ฿44,900',
    ctaHref:  '/booking?package=ai-workshop&bundle=consult-30',
  },
};
const bundle = BUNDLE_MAP[slug as string];

// ROI benefit cards per service — concrete before/after numbers per Pun's calculation (2026-04-20)
interface RoiCard {
  label: string;
  before: string;
  beforeNote: string;
  after: string;
  afterNote: string;
  saving: string;
  emoji: string;
}
const ROI_MAP: Record<string, RoiCard[]> = {
  'ai-workshop': [
    {
      emoji: '💰',
      label: 'ค่า Software',
      before: '฿200,000/ปี',
      beforeNote: 'SaaS subscription ทั้งทีม',
      after: '฿3,000/เดือน',
      afterNote: 'ค่า AI API อย่างเดียว',
      saving: 'ประหยัดไป ฿164,000/ปี',
    },
    {
      emoji: '👥',
      label: 'ต้นทุนทีม',
      before: '฿125,000/เดือน',
      beforeNote: 'ทีม 5 คน · รวม salary + overhead',
      after: '฿28,000/เดือน',
      afterNote: '1 คน + AI Agent ทำงานได้มากกว่าทีม 5 คนเก่า',
      saving: 'ประหยัดไป ฿1.16M/ปี',
    },
    {
      emoji: '⏰',
      label: 'เวลาต่องาน',
      before: '8 ชั่วโมง',
      beforeNote: 'ทำมือทั้งกระบวนการ',
      after: '30 นาที',
      afterNote: 'AI ทำ · คนตรวจ + approve',
      saving: 'ได้เวลาคืน 94%',
    },
  ],
};
const roiCards = ROI_MAP[slug as string] ?? [];

// Case study mapping per service — which cases prove this service works?
const CASE_MAP: Record<string, { slug: string; accent: 'coral' | 'cyan' | 'emerald' }[]> = {
  'ai-workshop': [
    { slug: 'forklift-distributor-5-person-team', accent: 'cyan' },
    { slug: 'manufacturing-b2b-12-person-team', accent: 'coral' },
  ],
  'sales-system-sprint': [
    { slug: 'real-estate-developer-sales-team-restructure', accent: 'coral' },
    { slug: 'manufacturing-b2b-12-person-team', accent: 'emerald' },
  ],
  'sale-training-bundle': [
    { slug: 'real-estate-developer-sales-team-restructure', accent: 'coral' },
  ],
};
const relatedCases = CASE_MAP[slug as string] ?? [];

// Guarantee text per service (single-line summary) — only for services that have explicit guarantee policy
const GUARANTEE_MAP: Record<string, string> = {
  // Intentionally empty for now · ai-workshop doesn't have a refund-guarantee policy
};
const guarantee = GUARANTEE_MAP[slug as string];

// Seat availability for scarcity UI (per service · edit as slots fill)
interface SeatInfo {
  taken: number;
  total: number;
  priceLabel: string;
  note: string;
}
const SEAT_MAP: Record<string, SeatInfo> = {
  'ai-workshop': {
    taken: 3,
    total: 5,
    priceLabel: 'ราคาพิเศษเดือนนี้',
    note: 'หลังที่นั่งเต็ม ราคากลับเป็น ฿30,000',
  },
};
const seats = SEAT_MAP[slug as string];

// Gallery photos per service (real phone-shot action photos per Google 2026 SEO tip)
const GALLERY_MAP: Record<string, { src: string; alt: string }[]> = {
  'ai-workshop': [
    { src: '/advance-ai-course/gallery1.JPG', alt: 'ทีมใช้ laptop ในห้อง workshop · จอฉาย "Advance AI & Business Automation"' },
    { src: '/advance-ai-course/gallery7.JPG', alt: 'บรรยากาศ workshop hands-on · ทีมกำลัง build workflow' },
    { src: '/advance-ai-course/IMG_5218.JPG', alt: 'ปัน ณัฐพัชร์ สอน AI workshop' },
  ],
};
const gallery = GALLERY_MAP[slug as string] ?? [];

// Testimonial per service (real client quote with permission)
interface ServiceTestimonial {
  quote: string;
  author: string;
  role: string;
  image?: string;
}
const TESTIMONIAL_MAP: Record<string, ServiceTestimonial> = {
  'ai-workshop': {
    quote: 'ทีมใช้ AI เก่งขึ้นเยอะ จากเดิมไม่กล้าใช้เพราะกลัว prompt ผิด ตอนนี้สร้าง Web-App ใช้กันเองแล้ว ประหยัดเวลาไปได้เยอะเลย · จากงานที่ต้องใช้เวลาทั้งวัน ตอนนี้เสร็จภายใน 15 นาทีได้ · เมื่อก่อน AI Chat ธรรมดายังไม่อยากใช้ ตอนนี้สร้าง Agent ทำงานแทนเป็นเรื่องปกติ — มาแข่งกันว่าใครจะลดเวลาได้มากกว่า',
    author: 'คุณฝน',
    role: 'Monthly Consulting Client',
  },
};
const testimonial = TESTIMONIAL_MAP[slug as string];

const accentVar = (a: AccentToken): string =>
  a === 'cyan'
    ? 'var(--color-pun-cyan)'
    : a === 'violet'
      ? 'var(--color-pun-violet)'
      : 'var(--color-pun-coral)';

const accent = accentVar(detail.accent);
const accentButtonText = detail.accent === 'cyan' ? '#0a1020' : 'white';

const title = `${svc.title} — ${detail.priceHeadline}`;
const description = detail.subhead;
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'Service', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'บริการ', url: `${SITE.url}/services` },
      { name: svc.title, url: `${SITE.url}/services/${svc.slug}` },
    ],
  }}
>
  <!-- ===== HERO ===== -->
  <section
    class="relative overflow-hidden px-4 py-16 lg:px-8 lg:py-24"
    style={`background: linear-gradient(180deg, color-mix(in oklch, ${accent} 6%, transparent), transparent 60%);`}
  >
    <div class="mx-auto max-w-4xl">
      <div class="mb-6 flex items-center gap-2 text-sm">
        <a href="/services" class="text-base-content/60 hover:text-secondary">บริการ</a>
        <span class="text-base-content/40">/</span>
        <span class="text-base-content/80">{svc.title}</span>
      </div>

      <div class="mb-6 flex flex-wrap items-center gap-3">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold tracking-wide"
          style={`border-color: color-mix(in oklch, ${accent} 35%, transparent); background: color-mix(in oklch, ${accent} 10%, transparent); color: ${accent};`}
        >
          {detail.eyebrow}
        </div>
        {
          seats && (
            <div class="inline-flex items-center gap-2 rounded-full border-2 border-rose-500/50 bg-rose-500/15 px-4 py-1.5 text-xs font-bold text-rose-700 dark:text-rose-300">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-500 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-rose-500"></span>
              </span>
              🔥 เหลือ {seats.total - seats.taken} ที่ จาก {seats.total} ที่ · {seats.priceLabel}
            </div>
          )
        }
      </div>

      <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
        {detail.headline}{' '}
        <span style={`color: ${accent};`}>{detail.headlineAccent}</span>
        {detail.headlineTail && <><br class="hidden md:block" />{detail.headlineTail}</>}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-base-content/80 md:text-xl">
        {detail.subhead}
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={`/booking?package=${svc.slug}`}
          class="btn btn-lg border-none font-bold shadow-xl transition-all hover:scale-105"
          style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 15px 40px -15px color-mix(in oklch, ${accent} 50%, transparent);`}
        >
          จองเลย — {detail.priceHeadline}
        </a>
        <a
          href="/intake-form"
          class="btn btn-lg btn-ghost border border-base-content/25 hover:bg-base-200"
        >
          ไม่แน่ใจ? นัดคุยกับปันก่อน →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== PAIN POINTS ===== -->
  <section class="border-t border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-5xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Problem</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        เจอปัญหาแบบนี้อยู่ไหม?
      </h2>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
          detail.pains.map((p) => (
            <div
              class="rounded-2xl border border-base-content/15 bg-base-200/40 p-6 transition hover:-translate-y-0.5"
              style={`--hover-border: ${accent};`}
              onmouseenter={`this.style.borderColor = this.style.getPropertyValue('--hover-border').concat(' / 0.4')`}
            >
              <div class="text-3xl">{p.emoji}</div>
              <h3 class="mt-4 font-display text-base font-bold">{p.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-base-content/75">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== AUDIENCE ===== -->
  <section class="border-t border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">เหมาะกับ</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
        ใครที่ควรเข้า package นี้
      </h2>

      <ul class="mt-8 space-y-4">
        {
          detail.audience.map((a) => (
            <li
              class="flex items-start gap-3 rounded-xl border border-base-content/10 bg-base-100/60 p-5"
            >
              <span
                class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full text-sm font-bold"
                style={`background: color-mix(in oklch, ${accent} 20%, transparent); color: ${accent};`}
              >
                ✓
              </span>
              <span class="text-base leading-relaxed text-base-content/85">{a}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== PREPARATION — gear + AI tools taught (conditional per service) ===== */}
  {
    detail.preparation && (
      <section class="border-t border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
        <div class="mx-auto max-w-5xl">
          <p class="text-xs font-bold uppercase tracking-widest text-secondary">Prep + Tools</p>
          <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
            เตรียมอะไร · เรียนเครื่องมืออะไร
          </h2>

          <div class="mt-10 grid gap-8 md:grid-cols-2">
            {/* Left: Requirements */}
            <div>
              <h3 class="font-display text-xl font-bold" style={`color: ${accent};`}>
                💻 สิ่งที่ต้องเตรียม
              </h3>
              <ul class="mt-5 space-y-4">
                {detail.preparation.requirements.map((r) => (
                  <li class="flex items-start gap-3 rounded-xl border border-base-content/10 bg-base-100/60 p-5">
                    <span
                      class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full text-sm font-bold"
                      style={`background: color-mix(in oklch, ${accent} 20%, transparent); color: ${accent};`}
                    >
                      ✓
                    </span>
                    <div>
                      <p class="font-display font-bold text-base-content">{r.title}</p>
                      {r.detail && (
                        <p class="mt-1 text-sm leading-relaxed text-base-content/70">{r.detail}</p>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>

            {/* Right: AI & Tools taught */}
            <div>
              <h3 class="font-display text-xl font-bold" style={`color: ${accent};`}>
                🤖 AI & Tools ที่จะได้เรียน
              </h3>
              <ul class="mt-5 space-y-3">
                {detail.preparation.tools.map((t) => (
                  <li
                    class="rounded-xl border p-4 transition hover:-translate-y-0.5 hover:shadow-md"
                    style={`border-color: color-mix(in oklch, ${accent} 25%, transparent); background: color-mix(in oklch, ${accent} 4%, transparent);`}
                  >
                    <p class="font-display font-bold" style={`color: ${accent};`}>
                      {t.name}
                    </p>
                    <p class="mt-1.5 text-sm leading-relaxed text-base-content/80">{t.tagline}</p>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== AGENDA ===== -->
  <section class="border-t border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Agenda · 8 modules</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        workshop จะเกิดอะไรบ้าง
      </h2>

      <ol class="mt-10 space-y-5">
        {
          detail.agenda.map((a, i) => (
            <li class="relative flex gap-6 rounded-2xl border border-base-content/10 bg-base-100 p-6 shadow-sm">
              <div class="flex-shrink-0">
                <span
                  class="flex h-12 w-12 items-center justify-center rounded-full font-display text-lg font-bold"
                  style={`background: color-mix(in oklch, ${accent} 15%, transparent); color: ${accent};`}
                >
                  {i + 1}
                </span>
              </div>
              <div class="flex-1">
                <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
                  {a.time}
                </p>
                <h3 class="mt-1 font-display text-lg font-bold">{a.title}</h3>
                <p class="mt-2 text-base leading-relaxed text-base-content/75">{a.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ===== MID CTA (after agenda) ===== -->
  <section class="border-t border-base-content/10 px-4 py-12 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <div
        class="rounded-2xl border-2 p-6 text-center shadow-xl md:p-8"
        style={`border-color: ${accent}; background: color-mix(in oklch, ${accent} 8%, transparent); box-shadow: 0 20px 50px -25px color-mix(in oklch, ${accent} 55%, transparent);`}
      >
        <p class="font-display text-xl font-bold md:text-2xl">
          เห็น agenda แล้ว อยากเริ่มเลยไหม?
        </p>
        <p class="mt-2 text-base text-base-content/75">
          จอง {svc.title} ตอนนี้ ปันล็อควันให้ก่อนคิวเต็ม
        </p>
        <div class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
          <a
            href={`/booking?package=${svc.slug}`}
            class="btn btn-lg border-none text-base font-bold shadow-xl transition-all hover:scale-[1.03]"
            style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 14px 32px -10px color-mix(in oklch, ${accent} 55%, transparent);`}
          >
            จองเลย — {detail.priceHeadline} →
          </a>
          <a
            href="/intake-form"
            class="btn btn-lg btn-ghost border border-base-content/25 text-base hover:bg-base-200"
          >
            นัดคุยก่อน →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUTCOMES ===== -->
  <section class="border-t border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Outcomes</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        ผลลัพธ์ที่ได้
      </h2>

      <ul class="mt-8 grid gap-3 md:grid-cols-2">
        {
          detail.outcomes.map((o) => (
            <li
              class="flex items-start gap-3 rounded-xl border border-base-content/10 bg-base-100/60 p-5"
            >
              <span class="text-2xl" style={`color: ${accent};`}>★</span>
              <span class="text-base leading-relaxed text-base-content/85">{o}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== ROI BENEFIT BOXES — concrete before/after numbers ===== */}
  {
    roiCards.length > 0 && (
      <section
        class="relative overflow-hidden border-t border-base-content/10 px-4 py-20 lg:px-8 lg:py-24"
        style={`background: linear-gradient(180deg, color-mix(in oklch, ${accent} 10%, transparent), transparent 80%);`}
      >
        <div
          class="pointer-events-none absolute inset-0 -z-10 opacity-40"
          style={`background: radial-gradient(circle at 50% 0%, color-mix(in oklch, ${accent} 18%, transparent), transparent 60%);`}
        ></div>

        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
              Real ROI · ตัวเลขจริงจาก client
            </p>
            <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-5xl">
              ลงทุน ฿24,900 · ประหยัดจริง <span style={`color: ${accent};`}>ปีแรก ฿1M+</span>
            </h2>
            <p class="mx-auto mt-4 max-w-2xl text-base text-base-content/75 md:text-lg">
              3 ตัวเลขจริงจาก client ที่ Pun build AI Agent ให้ใน workshop · วัดจาก report บริษัท 6 เดือนหลังส่งมอบ
            </p>
          </div>

          <div class="mt-12 grid gap-6 md:grid-cols-3">
            {
              roiCards.map((card) => (
                <div
                  class="relative overflow-hidden rounded-3xl border-2 bg-base-100/80 p-7 shadow-xl backdrop-blur-sm transition hover:-translate-y-1 hover:shadow-2xl md:p-8"
                  style={`border-color: color-mix(in oklch, ${accent} 25%, transparent);`}
                >
                  {/* Top accent bar */}
                  <div
                    class="absolute inset-x-0 top-0 h-1.5"
                    style={`background: linear-gradient(to right, transparent, ${accent}, transparent);`}
                  ></div>

                  {/* Emoji + label */}
                  <div class="mb-5 flex items-center gap-3">
                    <div
                      class="flex h-12 w-12 items-center justify-center rounded-2xl text-2xl"
                      style={`background: color-mix(in oklch, ${accent} 15%, transparent);`}
                    >
                      {card.emoji}
                    </div>
                    <p class="text-xs font-bold uppercase tracking-widest text-base-content/60">
                      {card.label}
                    </p>
