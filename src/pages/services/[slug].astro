  {slug === 'ai-workshop' && (
    <script is:inline>
      (function () {
        var DEADLINE = new Date('2026-04-30T23:59:59+07:00').getTime();
        function pad(n) { return String(n).padStart(2, '0'); }
        function update() {
          var delta = DEADLINE - Date.now();
          if (delta <= 0) {
            document.querySelectorAll('[data-countdown-wrap]').forEach(function (w) {
              var vis = w.querySelector('[data-countdown-visible]');
              var exp = w.querySelector('[data-countdown-expired]');
              if (vis) vis.classList.add('hidden');
              if (exp) exp.classList.remove('hidden');
            });
            return;
          }
          var d = Math.floor(delta / 86400000);
          var h = Math.floor((delta % 86400000) / 3600000);
          var m = Math.floor((delta % 3600000) / 60000);
          var s = Math.floor((delta % 60000) / 1000);
          document.querySelectorAll('[data-cd-days]').forEach(function (e) { e.textContent = String(d); });
          document.querySelectorAll('[data-cd-hours]').forEach(function (e) { e.textContent = pad(h); });
          document.querySelectorAll('[data-cd-mins]').forEach(function (e) { e.textContent = pad(m); });
          document.querySelectorAll('[data-cd-secs]').forEach(function (e) { e.textContent = pad(s); });
        }
        update();
        setInterval(update, 1000);
      })();
    </script>
  )}
