// Fetch 3 featured articles — one per pillar category for home preview.
// Picks most recent non-draft entry per pillar, falls back to any latest.
type AnyArticle = CollectionEntry<'pillar'> | CollectionEntry<'cluster'>;

async function pickFeatured(): Promise<AnyArticle[]> {
  const pillars = await getCollection('pillar', ({ data }: CollectionEntry<'pillar'>) => !data.draft);
  const clusters = await getCollection('cluster', ({ data }: CollectionEntry<'cluster'>) => !data.draft);
  const all: AnyArticle[] = [...pillars, ...clusters].sort(
    (a, b) => b.data.published.getTime() - a.data.published.getTime()
  );

  const wantedPillars = ['sales-consulting', 'ai-transformation', 'agentic-ai-sales'];
  const picks: AnyArticle[] = [];
  for (const pillarKey of wantedPillars) {
    const match = all.find((a) => {
      const d = a.data as { pillar?: string; parentPillar?: string };
      return (d.pillar ?? d.parentPillar) === pillarKey && !picks.includes(a);
    });
    if (match) picks.push(match);
  }
  // Backfill up to 3 if a pillar has no articles yet
  for (const a of all) {
    if (picks.length >= 3) break;
    if (!picks.includes(a)) picks.push(a);
  }
  return picks.slice(0, 3);
}

const featuredArticles = await pickFeatured();

