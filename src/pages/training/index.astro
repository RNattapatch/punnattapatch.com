---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';

const entries = await getCollection('training', ({ data }: CollectionEntry<'training'>) => !data.draft);
const sorted = [...entries].sort((a, b) => {
  // Sort by closes date ascending (next-to-close first)
  return a.data.closesAt.getTime() - b.data.closesAt.getTime();
});

const formatPrice = (n: number): string => '฿' + n.toLocaleString('en-US');
const formatDate = (d: Date): string =>
  d.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });

const title = 'Public Training — Founding Cohort #1 เปิดรับสมัคร';
const description = 'เรียนกับ Pun Nattapatch · AI Quick Launch + Sales Mastery + Sales Team Builder · Founding pricing สำหรับ cohort แรก · max 8-12 seats ต่อ program';
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Public Training', url: `${SITE.url}/training` },
    ],
  }}
>
  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Public Training</p>
      <h1 class="mt-3 font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl">
        Founding Cohort #1<br class="hidden md:block" />
        <span class="text-secondary">เปิดรับ 8-12 ที่นั่ง</span>ต่อ program
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-base-content/75">
        เรียนกับผมโดยตรง · application-based screening · 1-per-industry-per-cohort · hands-on ลงมือทำจริงในห้อง · Founding alumni ได้ราคาพิเศษเข้า Tier 2 Advisory ต่อ
      </p>
    </div>
  </section>

  {
    sorted.length === 0 ? (
      <section class="px-4 pb-20 lg:px-8">
        <div class="mx-auto max-w-2xl rounded-2xl border border-dashed border-base-content/20 bg-base-200/30 p-10 text-center">
          <p class="font-display text-xl font-bold">Cohort ถัดไปยังไม่ประกาศ</p>
          <p class="mt-3 text-base-content/70">
            ลงชื่อไว้ที่ <a href="/intake-form" class="text-secondary underline">intake form</a> — จะแจ้งทันที cohort ใหม่เปิด
          </p>
        </div>
      </section>
    ) : (
      <section class="border-t border-base-content/10 bg-base-200/20 px-4 py-16 lg:px-8">
        <div class="mx-auto max-w-5xl">
          <ul class="grid gap-6 md:grid-cols-3">
            {sorted.map((entry) => {
              const d = entry.data;
              const hasFounding = Boolean(d.priceThb.founding && d.priceThb.founding < d.priceThb.normal);
              return (
                <li>
                  <a
                    href={`/training/${entry.id}`}
                    class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-base-content/10 bg-base-100 p-6 transition hover:-translate-y-1 hover:shadow-xl"
                  >
                    <div class="mb-4 flex items-center justify-between">
                      <span class="rounded-full bg-secondary/15 px-3 py-1 text-xs font-bold uppercase tracking-widest text-secondary">
                        {d.programCode.toUpperCase()}
                      </span>
                      {hasFounding && (
                        <span class="rounded-full bg-amber-400/20 px-2 py-0.5 text-[10px] font-bold text-amber-700 dark:text-amber-300">
                          Early-bird
                        </span>
                      )}
                    </div>

                    <h2 class="font-display text-xl font-bold leading-tight">{d.title.split('—')[1]?.trim() ?? d.title}</h2>
                    <p class="mt-2 text-sm leading-relaxed text-base-content/75">{d.hook}</p>

                    <dl class="mt-4 grid grid-cols-2 gap-x-3 gap-y-2 text-xs">
                      <div>
                        <dt class="text-base-content/55">Duration</dt>
                        <dd class="mt-0.5 font-semibold">{d.duration}</dd>
                      </div>
                      <div>
                        <dt class="text-base-content/55">Seats</dt>
                        <dd class="mt-0.5 font-semibold">Max {d.seats.total}</dd>
                      </div>
                      <div>
                        <dt class="text-base-content/55">Starts</dt>
                        <dd class="mt-0.5 font-semibold">{formatDate(d.startsAt)}</dd>
                      </div>
                      <div>
                        <dt class="text-base-content/55">Closes</dt>
                        <dd class="mt-0.5 font-semibold text-secondary">{formatDate(d.closesAt)}</dd>
                      </div>
                    </dl>

                    <div class="mt-auto pt-5">
                      <p class="font-display text-2xl font-bold text-secondary">
                        {hasFounding ? formatPrice(d.priceThb.founding!) : formatPrice(d.priceThb.normal)}
                        {hasFounding && (
                          <span class="ml-2 text-sm text-base-content/50 line-through">
                            {formatPrice(d.priceThb.normal)}
                          </span>
                        )}
                      </p>
                      <p class="mt-2 text-xs text-base-content/55">
                        {hasFounding ? 'Founding Cohort #1' : 'Standard enrollment'}
                      </p>
                    </div>

                    <div class="mt-5 border-t border-base-content/10 pt-4 text-xs font-semibold text-secondary group-hover:underline">
                      ดูรายละเอียด + ยื่น Application →
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>

          <div class="mx-auto mt-14 max-w-2xl rounded-2xl border border-secondary/30 bg-secondary/5 p-8 text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-secondary">Alumni Perk</p>
            <p class="mt-3 font-display text-lg font-bold">
              จบ P1/P4/P5 แล้วได้ส่วนลด <span class="text-secondary">15%</span> เข้า Tier 2 Agentic AI Transformation
            </p>
            <p class="mt-2 text-sm text-base-content/70">
              ระบบ 90-day ที่ติดตั้ง AI Agents ให้ทั้งองค์กร · สำหรับคนที่อยากไปต่อหลังเรียนจบ
            </p>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
