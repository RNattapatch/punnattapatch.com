---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Schema from '../../components/Schema.astro';
import Countdown from '../../components/Countdown.astro';
import { SITE, PUN_CORE_BIO } from '../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('training', ({ data }: CollectionEntry<'training'>) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'training'> }
const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const url = `${SITE.url}/training/${entry.id}`;
const hasFounding = Boolean(data.priceThb.founding && data.priceThb.founding < data.priceThb.normal);

const formatPrice = (n: number): string => '฿' + n.toLocaleString('en-US');
const formatDate = (d: Date): string =>
  d.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });

// Accent color system — maps token to Tailwind var (same as services/[slug].astro)
const accent = data.accent === 'cyan'
  ? 'var(--color-pun-cyan)'
  : data.accent === 'violet'
    ? 'var(--color-pun-violet)'
    : 'var(--color-pun-coral)';
const accentButtonText = data.accent === 'cyan' ? '#0a1020' : 'white';
---

<BaseLayout
  title={`${data.title} | ${SITE.name}`}
  description={data.description}
  schema={{
    types: ['Event', 'Course', 'BreadcrumbList'],
    title: data.title,
    description: data.description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'Public Training', url: `${SITE.url}/training` },
      { name: data.title, url },
    ],
    training: {
      name: data.title,
      description: data.description,
      url,
      startDate: data.startsAt,
      endDate: data.endsAt,
      closesAt: data.closesAt,
      priceThb: data.priceThb.normal,
      foundingPriceThb: data.priceThb.founding,
      seatsTotal: data.seats.total,
      locationName: data.location.name,
      locationAddress: data.location.address,
      isVirtual: data.location.virtual,
      audience: data.audience,
    },
  }}
>
  {/* ===== HERO ===== */}
  <section class="relative overflow-hidden border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-24">
    <div
      class="pointer-events-none absolute inset-0 -z-10 opacity-60"
      style={`background: radial-gradient(circle at 30% 20%, color-mix(in oklch, ${accent} 12%, transparent), transparent 60%);`}
    >
    </div>

    <div class="mx-auto max-w-4xl">
      {/* Program badge */}
      <div class="flex flex-wrap items-center gap-3">
        <span
          class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-bold uppercase tracking-widest"
          style={`border-color: color-mix(in oklch, ${accent} 40%, transparent); background: color-mix(in oklch, ${accent} 10%, transparent); color: ${accent};`}
        >
          {data.programCode.toUpperCase()} · Founding Cohort #1
        </span>
        {hasFounding && (
          <span class="rounded-full bg-amber-400/20 px-3 py-1 text-xs font-bold text-amber-600 dark:text-amber-300">
            Early-bird · {data.seats.founding} ที่นั่งเท่านั้น
          </span>
        )}
      </div>

      <h1 class="mt-6 font-display text-4xl font-bold leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
        {data.headline && data.headlineAccent ? (
          <>
            {data.headline}
            <br class="hidden md:block" />
            <span style={`color: ${accent};`}>{data.headlineAccent}</span>
            {data.headlineTail && (
              <>
                <br class="hidden md:block" />
                {data.headlineTail}
              </>
            )}
          </>
        ) : (
          data.title
        )}
      </h1>

      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-base-content/80 md:text-xl">
        {data.subhead ?? data.hook}
      </p>

      {/* Key facts row */}
      <div class="mt-8 grid gap-4 md:grid-cols-4">
        <div>
          <p class="text-xs uppercase tracking-widest text-base-content/55">Duration</p>
          <p class="mt-1 font-display text-base font-semibold">{data.duration}</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-base-content/55">Format</p>
          <p class="mt-1 font-display text-base font-semibold">
            {data.location.virtual ? 'Online' : 'On-site Bangkok'}
          </p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-base-content/55">Seats</p>
          <p class="mt-1 font-display text-base font-semibold">Max {data.seats.total} คน</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-base-content/55">Price</p>
          <p class="mt-1 font-display text-base font-semibold">
            {hasFounding ? (
              <>
                <span style={`color: ${accent};`}>{formatPrice(data.priceThb.founding!)}</span>
                <span class="ml-2 text-sm text-base-content/50 line-through">
                  {formatPrice(data.priceThb.normal)}
                </span>
              </>
            ) : (
              <span style={`color: ${accent};`}>{formatPrice(data.priceThb.normal)}</span>
            )}
          </p>
        </div>
      </div>

      {data.priceCompare && (
        <p class="mt-5 text-sm font-semibold" style={`color: ${accent};`}>{data.priceCompare}</p>
      )}

      {/* Primary CTA */}
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a
          href="#waitlist"
          class="btn btn-lg border-none px-8 font-bold shadow-xl transition-all hover:scale-105"
          style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 15px 40px -15px color-mix(in oklch, ${accent} 50%, transparent);`}
        >
          จองที่นั่ง Waitlist →
        </a>
        <a
          href="#syllabus"
          class="btn btn-lg btn-ghost border border-base-content/20"
        >
          ดูหลักสูตร ก่อน
        </a>
      </div>
    </div>
  </section>

  {/* ===== COUNTDOWN ===== */}
  <section class="border-b border-base-content/10 px-4 py-14 lg:px-8">
    <Countdown targetDate={data.closesAt} />
  </section>

  {/* ===== PAINS (dramatic · pain-first section) ===== */}
  {
    data.pains.length > 0 && (
      <section class="relative overflow-hidden border-b border-base-content/10 px-4 py-20 lg:px-8 lg:py-24">
        <div
          class="pointer-events-none absolute inset-0 -z-10"
          style={`background: radial-gradient(circle at 80% 20%, color-mix(in oklch, ${accent} 8%, transparent), transparent 55%);`}
        />
        <div class="mx-auto max-w-5xl">
          <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>Pain Points</p>
          <h2 class="mt-3 font-display text-3xl font-bold leading-tight tracking-tight md:text-4xl lg:text-5xl">
            ถ้าคุณเจอปัญหาเหล่านี้อยู่ — <span style={`color: ${accent};`}>คอร์สนี้ออกแบบมาเพื่อคุณ</span>
          </h2>
          <div class="mt-12 grid gap-6 md:grid-cols-2 lg:gap-8">
            {data.pains.map((p) => (
              <div
                class="rounded-2xl border p-6 transition-all md:p-8"
                style={`border-color: color-mix(in oklch, ${accent} 20%, transparent); background: color-mix(in oklch, ${accent} 3%, transparent);`}
              >
                <div class="text-4xl md:text-5xl">{p.emoji}</div>
                <h3 class="mt-4 font-display text-lg font-bold md:text-xl">{p.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-base-content/75 md:text-base">{p.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* ===== GALLERY (if present · real phone-shot workshop photos) ===== */}
  {
    data.gallery.length > 0 && (
      <section class="border-b border-base-content/10 bg-base-200/30 px-4 py-14 lg:px-8">
        <div class="mx-auto max-w-5xl">
          <div class="grid gap-4 md:grid-cols-3">
            {data.gallery.map((g) => (
              <figure class="overflow-hidden rounded-2xl border border-base-content/10">
                <img src={g.src} alt={g.alt} loading="lazy" class="h-full w-full object-cover" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* ===== CASE STUDY / CLIENT RESULTS ===== */}
  {data.caseStudy && data.caseStudy.length > 0 && (
    <section class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
      <div class="mx-auto max-w-4xl">
        <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>ผลลัพธ์จริงจากลูกค้า</p>
        <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
          ก่อนมาเรียน — ไม่มี AI ในระบบเลย · หลังจาก 1 workshop
        </h2>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {data.caseStudy.map((c) => (
            <div
              class="rounded-2xl border p-6 md:p-8"
              style={`border-color: color-mix(in oklch, ${accent} 22%, transparent); background: color-mix(in oklch, ${accent} 4%, transparent);`}
            >
              <p class="text-xs font-bold uppercase tracking-widest text-base-content/50">{c.industry}</p>
              <p class="mt-3 font-display text-3xl font-black" style={`color: ${accent};`}>{c.result}</p>
              <p class="mt-2 text-sm font-semibold text-base-content/80">{c.metric}</p>
              {c.detail && <p class="mt-3 text-sm leading-relaxed text-base-content/60">{c.detail}</p>}
            </div>
          ))}
        </div>
        <p class="mt-5 text-xs text-base-content/45">* ข้อมูล anonymized ตาม NDA · ผลลัพธ์แตกต่างตามบริบทของแต่ละธุรกิจ</p>
      </div>
    </section>
  )}

  {/* ===== OUTCOMES ===== */}
  <section class="border-b border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>สิ่งที่ได้กลับบ้าน</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
        จบ {data.title.split('—')[0].trim()} แล้วคุณจะ
      </h2>
      <ul class="mt-8 space-y-4">
        {
          data.outcomes.map((o) => (
            <li class="flex items-start gap-3">
              <span
                class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-sm font-bold"
                style={`background: color-mix(in oklch, ${accent} 18%, transparent); color: ${accent};`}
              >
                ✓
              </span>
              <span class="text-base leading-relaxed text-base-content/85 md:text-lg">{o}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ===== SYLLABUS ===== */}
  <section id="syllabus" class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>Syllabus</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
        {data.syllabus.length} โมดูล · {data.duration}
      </h2>
      <ol class="mt-10 space-y-6">
        {
          data.syllabus.map((m, i) => (
            <li class="rounded-2xl border border-base-content/10 bg-base-100/50 p-6 shadow-sm">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
                    Module {i + 1}
                  </p>
                  <h3 class="mt-2 font-display text-xl font-bold">{m.title}</h3>
                  <p class="mt-3 text-sm leading-relaxed text-base-content/80 md:text-base">{m.body}</p>
                </div>
                {m.duration && (
                  <span class="shrink-0 rounded-full border border-base-content/15 bg-base-200 px-3 py-1 text-xs text-base-content/70">
                    {m.duration}
                  </span>
                )}
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* ===== TESTIMONIAL (if present) ===== */}
  {
    data.testimonial && (
      <section class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
        <div class="mx-auto max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>Alumni Voice</p>
          <figure
            class="mt-6 rounded-3xl border p-8 md:p-10"
            style={`border-color: color-mix(in oklch, ${accent} 25%, transparent); background: color-mix(in oklch, ${accent} 4%, transparent);`}
          >
            <blockquote class="text-base leading-relaxed text-base-content/90 md:text-lg">
              "{data.testimonial.quote}"
            </blockquote>
            <figcaption class="mt-6 flex items-center gap-4">
              {data.testimonial.image && (
                <img src={data.testimonial.image} alt={data.testimonial.author} class="h-12 w-12 rounded-full object-cover" />
              )}
              <div>
                <p class="font-display text-base font-bold">{data.testimonial.author}</p>
                <p class="text-sm text-base-content/65">{data.testimonial.role}</p>
              </div>
            </figcaption>
          </figure>
        </div>
      </section>
    )
  }

  {/* NOTE: Pun has NO refund/money-back policy — do NOT re-add Outcome Guarantee section.
      The `guarantee` field in training schema is deprecated (kept optional for legacy). */}

  {/* ===== FOUNDING PERKS (if applicable) ===== */}
  {
    hasFounding && data.founding_perks.length > 0 && (
      <section class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
        <div class="mx-auto max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-widest text-amber-600 dark:text-amber-400">
            Founding Cohort Only
          </p>
          <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
            สิทธิพิเศษ {data.seats.founding} คนแรกเท่านั้น
          </h2>
          <ul class="mt-8 space-y-3">
            {data.founding_perks.map((p) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 text-amber-500">★</span>
                <span class="text-base leading-relaxed text-base-content/85">{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  {/* ===== QUALIFIES / DISQUALIFIES ===== */}
  <section class="border-b border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>Is this for you?</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
        อ่านก่อนสมัคร — {data.programCode.toUpperCase()} เหมาะกับใคร
      </h2>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-emerald-500/30 bg-emerald-500/5 p-6">
          <p class="font-display text-lg font-bold text-emerald-700 dark:text-emerald-300">✓ เหมาะกับคุณถ้า</p>
          <ul class="mt-4 space-y-2">
            {data.qualifies.map((q) => (
              <li class="flex items-start gap-2 text-sm text-base-content/85">
                <span class="mt-0.5 text-emerald-500">•</span>
                <span>{q}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-2xl border border-rose-500/30 bg-rose-500/5 p-6">
          <p class="font-display text-lg font-bold text-rose-700 dark:text-rose-300">✗ ไม่เหมาะถ้า</p>
          <ul class="mt-4 space-y-2">
            {data.disqualifies.map((q) => (
              <li class="flex items-start gap-2 text-sm text-base-content/85">
                <span class="mt-0.5 text-rose-500">•</span>
                <span>{q}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* ===== LONG-FORM BODY (markdown content) ===== */}
  <section class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
    <div
      class="prose prose-lg mx-auto max-w-3xl font-body text-base-content prose-headings:font-display prose-headings:text-base-content prose-strong:text-base-content"
      style={`--tw-prose-links: ${accent};`}
    >
      <Content />
    </div>
    {/* Inline waitlist CTA — captures readers who finished the long-form section */}
    <div class="mx-auto mt-10 max-w-3xl">
      <div
        class="flex flex-col items-start gap-4 rounded-2xl border p-6 sm:flex-row sm:items-center sm:justify-between"
        style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 6%, transparent);`}
      >
        <div>
          <p class="font-display text-base font-bold">พร้อมแล้ว? ลงชื่อได้เลย — ไม่ต้องจ่ายวันนี้</p>
          <p class="mt-1 text-sm text-base-content/65">20 ที่นั่ง · First Come, First Serve · ปิดเมื่อเต็ม</p>
        </div>
        <a
          href="#waitlist"
          class="btn btn-sm shrink-0 border-none font-bold"
          style={`background: ${accent}; color: ${accentButtonText};`}
        >
          จองสิทธิ์ Waitlist →
        </a>
      </div>
    </div>
  </section>

  {/* ===== FAQ ===== */}
  {
    data.faq.length > 0 && (
      <section class="border-b border-base-content/10 bg-base-200/30 px-4 py-16 lg:px-8 lg:py-20">
        <div class="mx-auto max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>FAQ</p>
          <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">คำถามที่เจอบ่อย</h2>
          <div class="mt-8 space-y-4">
            {data.faq.map((f) => (
              <details class="group rounded-xl border border-base-content/15 bg-base-100/50 p-5">
                <summary
                  class="cursor-pointer font-display text-base font-bold"
                  style={`--open-color: ${accent};`}
                >
                  {f.q}
                </summary>
                <p class="mt-3 text-sm leading-relaxed text-base-content/80">{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* ===== INSTRUCTOR ===== */}
  <section class="border-b border-base-content/10 px-4 py-16 lg:px-8 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>ใครสอน</p>
      <h2 class="mt-3 font-display text-2xl font-bold tracking-tight md:text-3xl">
        ปัน ณัฐพัชร์ — ไม่ใช่ academic trainer ที่สอนจากตำรา
      </h2>
      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {PUN_CORE_BIO.map((item) => (
          <div
            class="rounded-2xl border border-base-content/10 bg-base-100/50 p-6 text-center"
          >
            <p class="font-display text-3xl font-black" style={`color: ${accent};`}>{item.stat}</p>
            <p class="mt-3 text-sm leading-relaxed text-base-content/70">{item.body}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-sm leading-relaxed text-base-content/70">
        ทุก use case ใน {data.programCode.toUpperCase()} มาจาก engagement จริงที่ปันทำกับลูกค้า SME — ไม่ใช่ตัวอย่างในหนังสือ · ปัน build AI workflow ให้ลูกค้าใช้จริงก่อนจะสอนให้ใครทำเอง
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={SITE.social.tiktok}
          target="_blank"
          rel="noopener"
          class="btn btn-sm btn-outline"
        >
          TikTok @pun_nattapatch
        </a>
        <a href="/about" class="btn btn-sm btn-ghost">อ่านประวัติเพิ่มเติม →</a>
      </div>
    </div>
  </section>

  {/* ===== ALUMNI IN-HOUSE CROSS-PROMO ===== */}
  <section class="border-b border-base-content/10 px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div
        class="relative overflow-hidden rounded-3xl border-2 border-dashed bg-base-100/40 p-8 backdrop-blur-sm md:p-10"
        style={`border-color: color-mix(in oklch, ${accent} 35%, transparent);`}
      >
        <div class="grid gap-6 md:grid-cols-[auto_1fr] md:items-center">
          <div class="text-5xl md:text-6xl">🏢</div>

          <div>
            <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>สำหรับ Alumni</p>
            <h3 class="mt-2 font-display text-xl font-bold md:text-2xl">
              จบคอร์สแล้วอยากพาทั้งทีมเข้ามาเรียน? จัด In-house ได้เลย · <span style={`color: ${accent};`}>ลด 15%</span>
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-base-content/80 md:text-base">
              Alumni ของคอร์ส public ทุก batch ได้สิทธิ์จัด In-house Workshop/Training ให้องค์กรตัวเอง
              <span class="font-semibold" style={`color: ${accent};`}>{' '}ในราคาลด 15%</span>
              จาก list ปกติ · ใช้ได้ภายใน 6 เดือนหลังจบคอร์ส · ทักผมเลยถ้าอยากคุยเรื่องสเกล
            </p>

            <div class="mt-5 flex flex-wrap gap-3">
              <a
                href={`/intake-form?program=${data.programCode}&source=alumni-inhouse`}
                class="btn btn-sm border-none font-bold"
                style={`background: ${accent}; color: ${accentButtonText};`}
              >
                คุยเรื่อง In-house
              </a>
              <a
                href={SITE.social.line}
                rel="noopener"
                target="_blank"
                class="btn btn-sm btn-outline"
              >
                ทักใน LINE OA
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== FINAL CTA ===== */}
  {/* Waitlist section — P1 only · waitlist framing (no deadline timer) */}
  {data.programCode === 'p1' && (
    <section
      id="waitlist"
      class="border-y border-base-content/10 bg-base-200/30 px-4 py-20 lg:px-8"
    >
      <div class="mx-auto max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>
          🎟️ Waitlist
        </p>
        <h2 class="mt-3 font-display text-2xl font-black md:text-3xl">
          ยังไม่ต้องจ่ายวันนี้ — ลงชื่อจองสิทธิ์ Waitlist ก่อน
        </h2>
        <p class="mt-1 text-base font-semibold" style={`color: ${accent};`}>
          (First Come, First Serve — ที่นั่งปิดเมื่อเต็ม)
        </p>
        <p class="mt-4 text-base text-base-content/80">
          กรอก 4 ฟิลด์ — ผมจะแจ้งก่อนใครเมื่อถึงคิวคุณ · ราคา lock ฿12,900 (ปกติ ฿16,900 หลังเต็ม)
        </p>

        {/* Seats scarcity counter */}
        <div
          class="mt-6 grid grid-cols-2 gap-4 rounded-2xl border p-5"
          style={`border-color: color-mix(in oklch, ${accent} 30%, transparent); background: color-mix(in oklch, ${accent} 5%, transparent);`}
        >
          <div class="text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-base-content/55">ที่นั่งทั้งหมด</p>
            <p class="mt-1 font-display text-4xl font-black" style={`color: ${accent};`}>20</p>
            <p class="text-xs text-base-content/55">คน · ปิดเมื่อเต็ม</p>
          </div>
          <div class="text-center">
            <p class="text-xs font-bold uppercase tracking-widest text-base-content/55">ราคา Waitlist</p>
            <p class="mt-1 font-display text-4xl font-black" style={`color: ${accent};`}>฿12,900</p>
            <p class="text-xs text-base-content/55">post-cap ฿16,900</p>
          </div>
        </div>

        <form
          id="p1-waitlist-form"
          class="mt-8 space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6"
          novalidate
        >
          {/* Hidden UTM */}
          <input type="hidden" id="wl-utm_source" name="utm_source" value="" />
          <input type="hidden" id="wl-utm_medium" name="utm_medium" value="" />
          <input type="hidden" id="wl-utm_campaign" name="utm_campaign" value="" />
          <input type="hidden" id="wl-utm_content" name="utm_content" value="" />
          <input type="hidden" id="wl-utm_term" name="utm_term" value="" />
          <input type="hidden" id="wl-fbclid" name="fbclid" value="" />
          <input type="hidden" id="wl-ttclid" name="ttclid" value="" />
          <input type="hidden" name="program" value="p1" />

          <div>
            <label class="block text-sm font-bold" for="wl-name">ชื่อ-นามสกุล <span style={`color: ${accent};`}>*</span></label>
            <input type="text" id="wl-name" name="name" required autocomplete="name" class="mt-1.5 w-full rounded-xl border border-base-content/20 bg-base-100 px-4 py-2.5 text-base focus:outline-none" />
          </div>

          <div>
            <label class="block text-sm font-bold" for="wl-email">Email <span style={`color: ${accent};`}>*</span></label>
            <input type="email" id="wl-email" name="email" required autocomplete="email" class="mt-1.5 w-full rounded-xl border border-base-content/20 bg-base-100 px-4 py-2.5 text-base focus:outline-none" />
          </div>

          <div>
            <label class="block text-sm font-bold" for="wl-contact">LINE ID / โทรศัพท์ <span style={`color: ${accent};`}>*</span></label>
            <input type="text" id="wl-contact" name="contact" required autocomplete="tel" placeholder="เช่น @yourline หรือ 081-234-5678" class="mt-1.5 w-full rounded-xl border border-base-content/20 bg-base-100 px-4 py-2.5 text-base focus:outline-none" />
          </div>

          <div>
            <label class="block text-sm font-bold" for="wl-company">ชื่อบริษัท / แบรนด์ <span style={`color: ${accent};`}>*</span></label>
            <input type="text" id="wl-company" name="company" required autocomplete="organization" class="mt-1.5 w-full rounded-xl border border-base-content/20 bg-base-100 px-4 py-2.5 text-base focus:outline-none" />
          </div>

          <button
            type="submit"
            id="wl-submit-btn"
            class="w-full rounded-full px-6 py-3.5 font-display text-base font-bold shadow-lg transition disabled:cursor-not-allowed disabled:opacity-60"
            style={`background: ${accent}; color: ${accentButtonText};`}
          >
            ขึ้น Waitlist + lock ราคา ฿12,900
          </button>

          <p id="wl-form-msg" class="hidden rounded-xl p-3 text-sm" />
        </form>
      </div>

      <script is:inline define:vars={{ accent }}>
        (function () {
          const N8N_WEBHOOK = 'https://rnat.app.n8n.cloud/webhook/p1-waitlist-v1';
          const form = document.getElementById('p1-waitlist-form');
          const btn = document.getElementById('wl-submit-btn');
          const msg = document.getElementById('wl-form-msg');
          if (!form || !btn || !msg) return;

          function genRef() {
            const ts = Date.now().toString(36);
            const rnd = Math.random().toString(36).slice(2, 7);
            return ('PN-WL-' + ts + '-' + rnd).toUpperCase();
          }

          form.addEventListener('submit', async function (ev) {
            ev.preventDefault();
            msg.classList.add('hidden');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            btn.disabled = true;
            btn.textContent = 'กำลังบันทึก...';

            const fd = new FormData(form);
            const ref = genRef();
            const payload = { _meta: { reference: ref, page: location.pathname } };
            fd.forEach((v, k) => { payload[k] = v; });

            if (typeof window.plausible === 'function') {
              try { window.plausible('P1 Waitlist Signup', { props: { ref } }); } catch (_) {}
            }

            try {
              const ctrl = new AbortController();
              const t = setTimeout(() => ctrl.abort(), 8000);
              await fetch(N8N_WEBHOOK, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
                signal: ctrl.signal,
              });
              clearTimeout(t);
            } catch (e) {
              console.error('[p1-waitlist] webhook error', e);
            }

            msg.classList.remove('hidden');
            msg.style.background = 'color-mix(in oklch, ' + accent + ' 12%, transparent)';
            msg.style.color = accent;
            msg.textContent = '✅ ขึ้น Waitlist สำเร็จ — เราจะแจ้งคุณก่อนใครเมื่อ cohort ใกล้เปิด · Ref: ' + ref;
            btn.textContent = 'บันทึกแล้ว ✓';
          });
        })();
      </script>
    </section>
  )}

  <section
    class="px-4 py-20 lg:px-8"
    style={`background: color-mix(in oklch, ${accent} 10%, transparent);`}
    id="apply"
  >
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-widest" style={`color: ${accent};`}>จองสิทธิ์ตอนนี้</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        20 ที่นั่ง · First Come, First Serve
      </h2>
      <p class="mt-4 text-base-content/80">
        ลงชื่อ Waitlist ก่อน — ฟรี ไม่ต้องจ่ายวันนี้ · lock ราคา ฿12,900 (post-cap ฿16,900) · 1 บริษัท / อุตสาหกรรม
      </p>
      <a
        href="#waitlist"
        class="btn btn-lg mt-8 border-none px-10 font-bold shadow-xl transition-all hover:scale-105"
        style={`background: ${accent}; color: ${accentButtonText}; box-shadow: 0 15px 40px -15px color-mix(in oklch, ${accent} 50%, transparent);`}
      >
        จองที่นั่ง Waitlist →
      </a>
      <p class="mt-4 text-xs text-base-content/55">
        ที่นั่งปิดเมื่อเต็ม · ชำระ ฿12,900 หลังยืนยันที่นั่ง · ไม่มี deadline
      </p>
    </div>
  </section>
</BaseLayout>
