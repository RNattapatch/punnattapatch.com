---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SERVICES } from '../data/site';

const title = 'จองบริการกับปัน';
const description =
  'กรอก 3 นาที — เลือก package ที่อยากเริ่ม + ส่งให้ปัน ปันอ่านเองทุกใบและตอบกลับใน 24 ชม. พร้อม link นัดเวลา';

const teamSizes = [
  '1-2 คน (เจ้าของ + ผู้ช่วย)',
  '3-5 คน',
  '6-10 คน',
  '11-20 คน',
  '20+ คน',
];

const painPoints = [
  'ทีมเสียเวลากับงาน manual ซ้ำๆ (report, follow-up, data entry)',
  'เจ้าของแบกยอดขายเอง ทีมไม่ run เอง',
  'ไม่มีระบบ KPI / Commission ที่ fair + วัดได้',
  'ทีมปิดการขายด้วยลดราคาเป็นหลัก',
  'เคยจ่าย workshop แล้วทีมเลิกใช้ภายใน 2 สัปดาห์',
  'อยากเริ่มใช้ AI แต่ไม่รู้จะเริ่มจากไหน',
];

const sources = [
  { value: 'chatgpt', label: 'ChatGPT / GPT-4o / o1' },
  { value: 'claude', label: 'Claude (claude.ai, Claude API)' },
  { value: 'gemini', label: 'Gemini / Google AI Overview' },
  { value: 'perplexity', label: 'Perplexity' },
  { value: 'tiktok', label: 'TikTok (@pun_nattapatch)' },
  { value: 'instagram', label: 'Instagram (@pun_nattapatch)' },
  { value: 'facebook', label: 'Facebook' },
  { value: 'google-search', label: 'Google (ผลลัพธ์ปกติ)' },
  { value: 'referral', label: 'เพื่อน / ลูกค้าเก่าแนะนำ' },
  { value: 'event', label: 'งานสัมมนา / event' },
  { value: 'other', label: 'อื่นๆ' },
];

type AccentToken = 'cyan' | 'coral' | 'violet';
const accentFor = (slug: string): AccentToken => {
  if (slug.startsWith('ai-')) return 'cyan';
  if (slug.startsWith('trust-')) return 'violet';
  return 'coral';
};
const accentVar = (a: AccentToken): string =>
  a === 'cyan'
    ? 'var(--color-pun-cyan)'
    : a === 'violet'
      ? 'var(--color-pun-violet)'
      : 'var(--color-pun-coral)';

const packages = SERVICES.map((s) => ({
  slug: s.slug,
  title: s.title,
  subtitle: s.subtitle,
  priceLabel: s.priceLabel,
  priceThb: s.priceThb,
  accent: accentFor(s.slug),
}));

// Map slug → display name + numeric price for CRM/Telegram schema
// (matches legacy booking-form.html PKG_MAP shape)
const pkgNameBySlug: Record<string, string> = Object.fromEntries(
  SERVICES.map((s) => [s.slug, s.title])
);
const pkgPriceBySlug: Record<string, number> = Object.fromEntries(
  SERVICES.map((s) => [s.slug, s.priceThb])
);
const pkgLookupJson = JSON.stringify({
  names: pkgNameBySlug,
  prices: pkgPriceBySlug,
});
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'จองบริการ', url: `${SITE.url}/booking` },
    ],
  }}
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/css/intlTelInput.css"
    />
    <style is:global>
      /* Dark-theme + row-reorder for intl-tel-input v24 (see intake-form.astro for rationale) */
      .iti { width: 100%; display: block; }

      .iti__dropdown-content {
        background: #0f1a2b !important;
        color: #ffffff !important;
        border: 1px solid rgb(255 255 255 / 0.18) !important;
        border-radius: 0.5rem;
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.7);
      }
      .iti__country-list {
        background: #0f1a2b !important;
        max-height: 280px;
      }
      .iti__search-input {
        background: rgb(255 255 255 / 0.06) !important;
        color: #ffffff !important;
        border: 1px solid rgb(255 255 255 / 0.18) !important;
        padding: 10px 12px !important;
      }
      .iti__search-input::placeholder {
        color: rgb(255 255 255 / 0.5) !important;
      }

      .iti__country {
        display: flex !important;
        align-items: center !important;
        gap: 10px !important;
        padding: 10px 12px !important;
        color: #ffffff !important;
      }
      .iti__country .iti__flag-box,
      .iti__country > .iti__flag {
        order: 1 !important;
        flex-shrink: 0;
      }
      .iti__country .iti__dial-code {
        order: 2 !important;
        color: #22d3ee !important;
        font-weight: 600;
        min-width: 52px;
        flex-shrink: 0;
      }
      .iti__country .iti__country-name {
        order: 3 !important;
        color: #ffffff !important;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .iti__country.iti__highlight,
      .iti__country:hover {
        background: color-mix(in oklch, var(--color-secondary) 30%, transparent) !important;
      }

      .iti__selected-country,
      .iti__selected-country-primary {
        background: rgb(255 255 255 / 0.04) !important;
      }
      .iti__selected-country:hover,
      .iti__selected-country-primary:hover {
        background: rgb(255 255 255 / 0.08) !important;
      }
      .iti--separate-dial-code .iti__selected-dial-code,
      .iti--separate-dial-code .iti__dial-code {
        color: #ffffff !important;
      }

      .iti__divider {
        border-bottom-color: rgb(255 255 255 / 0.12) !important;
        padding: 0 !important;
      }

      .iti__no-results {
        color: rgb(255 255 255 / 0.7) !important;
        padding: 12px !important;
      }
    </style>
  </Fragment>

  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-widest text-secondary">Booking</p>
      <h1 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        จอง Workshop / Consulting กับปัน
      </h1>
      <p class="mt-4 text-lg text-base-content/75">
        เลือก package ที่อยากเริ่ม กรอกข้อมูล 3 นาที ปันอ่านเองทุกใบ ตอบกลับภายใน 24 ชม. พร้อม link นัดเวลา
      </p>

      <form id="booking-form" class="mt-10 space-y-8" novalidate>
        <!-- ===== 1. เลือก Package ===== -->
        <fieldset class="space-y-4 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">1. เลือก Package ที่สนใจ</legend>
          <p class="text-sm text-base-content/65">เลือกได้มากกว่า 1 รายการ</p>

          <div class="space-y-3">
            {
              packages.map((p) => {
                const accent = accentVar(p.accent);
                return (
                  <label
                    data-pkg={p.slug}
                    data-accent={p.accent}
                    class="pkg-card relative flex cursor-pointer items-start gap-4 rounded-xl border border-base-content/15 bg-base-200/30 p-5 transition-all hover:-translate-y-0.5"
                    style={`--pkg-accent: ${accent};`}
                  >
                    <input
                      type="checkbox"
                      name="packages"
                      value={p.slug}
                      class="pkg-input peer sr-only"
                    />
                    <div
                      class="pkg-dot mt-1 h-5 w-5 flex-shrink-0 rounded-full border-2 border-base-content/25 transition-all"
                    />
                    <div class="flex-1">
                      <p class="text-xs uppercase tracking-widest text-base-content/55">
                        {p.subtitle}
                      </p>
                      <p class="mt-1 font-display text-base font-bold">{p.title}</p>
                    </div>
                    <span class="pkg-price font-display text-base font-bold text-secondary">
                      {p.priceLabel}
                    </span>
                  </label>
                );
              })
            }
          </div>
          <p id="err-packages" class="hidden text-sm font-medium text-error">
            เลือกอย่างน้อย 1 package
          </p>
        </fieldset>

        <!-- ===== 2. Contact ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">2. ติดต่อ</legend>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="form-control">
              <label for="b-name" class="label">
                <span class="label-text font-medium">ชื่อ-นามสกุล *</span>
              </label>
              <input
                id="b-name"
                name="name"
                type="text"
                required
                class="input input-bordered w-full"
                placeholder="ปัน ณัฐพัชร์"
              />
            </div>

            <div class="form-control">
              <label for="b-company" class="label">
                <span class="label-text font-medium">บริษัท *</span>
              </label>
              <input
                id="b-company"
                name="company"
                type="text"
                required
                class="input input-bordered w-full"
                placeholder="Pun Nattapatch Co., Ltd."
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="form-control">
              <label for="b-position" class="label">
                <span class="label-text font-medium">ตำแหน่ง</span>
              </label>
              <input
                id="b-position"
                name="position"
                type="text"
                class="input input-bordered w-full"
                placeholder="เจ้าของ / CEO / Sales Manager"
              />
            </div>
            <div class="form-control">
              <label for="b-industry" class="label">
                <span class="label-text font-medium">อุตสาหกรรม</span>
              </label>
              <input
                id="b-industry"
                name="industry"
                type="text"
                class="input input-bordered w-full"
                placeholder="เช่น วัสดุก่อสร้าง / ที่พัก / IT"
              />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="form-control">
              <label for="b-phone" class="label">
                <span class="label-text font-medium">เบอร์โทร *</span>
              </label>
              <input
                id="b-phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                class="input input-bordered w-full"
                placeholder="812345678"
              />
              <p id="b-phone-err" class="mt-1.5 hidden text-xs font-medium text-error">
                กรุณาใส่เบอร์โทรให้ถูก format (เลือกประเทศจาก dropdown ก่อน)
              </p>
            </div>

            <div class="form-control">
              <label for="b-email" class="label">
                <span class="label-text font-medium">อีเมล</span>
              </label>
              <input
                id="b-email"
                name="email"
                type="email"
                class="input input-bordered w-full"
                placeholder="you@company.co.th"
              />
            </div>
          </div>

          <div class="form-control">
            <label for="b-line" class="label">
              <span class="label-text font-medium">LINE ID (optional)</span>
            </label>
            <input
              id="b-line"
              name="line"
              type="text"
              class="input input-bordered w-full"
              placeholder="@punnattapatch"
            />
          </div>

          <div class="form-control">
            <label for="b-team" class="label">
              <span class="label-text font-medium">ขนาดทีมขายปัจจุบัน *</span>
            </label>
            <select
              id="b-team"
              name="teamSize"
              required
              class="select select-bordered w-full"
            >
              <option value="">— เลือก —</option>
              {teamSizes.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="form-control">
            <span class="label">
              <span class="label-text font-medium">
                ปัญหาหลักที่เจอ (เลือกได้หลายข้อ)
              </span>
            </span>
            <div class="space-y-2">
              {
                painPoints.map((p) => (
                  <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-base-content/10 p-3 transition hover:bg-base-200/50">
                    <input
                      type="checkbox"
                      name="problems"
                      value={p}
                      class="checkbox checkbox-sm mt-0.5"
                    />
                    <span class="text-sm">{p}</span>
                  </label>
                ))
              }
            </div>
          </div>

          <div class="form-control">
            <label for="b-comment" class="label">
              <span class="label-text font-medium">
                ปัญหาอื่นๆที่เจอ (ไม่อยู่ในรายการข้างบน)
              </span>
            </label>
            <textarea
              id="b-comment"
              name="comment"
              rows="3"
              class="textarea textarea-bordered w-full"
              placeholder="อธิบาย pain point เฉพาะของคุณ หรือข้อมูลเพิ่มเติมที่อยากให้ปันรู้ก่อน"
            />
          </div>
        </fieldset>

        <!-- ===== 3. Timing ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">3. Timing</legend>

          <div class="form-control">
            <label for="b-date" class="label">
              <span class="label-text font-medium">วันที่สะดวกเริ่ม (ประมาณ)</span>
            </label>
            <input
              id="b-date"
              name="preferred_date"
              type="date"
              min={new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10)}
              class="input input-bordered w-full"
            />
            <p class="mt-1.5 text-xs text-base-content/55">
              เลือกวันที่จากปฏิทิน (เริ่มได้เร็วสุด 7 วันจากวันนี้) · ไม่ fix ได้ — แค่ประมาณการ
            </p>
          </div>

          <div class="form-control">
            <label for="b-source" class="label">
              <span class="label-text font-medium">เจอเว็บนี้ผ่าน *</span>
            </label>
            <select
              id="b-source"
              name="source"
              required
              class="select select-bordered w-full"
            >
              <option value="">— เลือก —</option>
              {sources.map((s) => <option value={s.value}>{s.label}</option>)}
            </select>
          </div>
        </fieldset>

        <!-- ===== Submit ===== -->
        <div class="rounded-2xl border border-base-content/10 bg-base-200/30 p-6">
          <button
            type="submit"
            id="btn-submit"
            class="btn btn-lg w-full bg-secondary text-secondary-content shadow-xl shadow-secondary/30 hover:scale-[1.02] hover:bg-secondary/90"
          >
            ส่งคำจอง →
          </button>
          <p class="mt-3 text-center text-xs text-base-content/55">
            ปันอ่านเองภายใน 24 ชม. · ตอบกลับพร้อม link นัดเวลา + ใบเสนอราคา
          </p>
        </div>
      </form>

      <!-- ===== Success state ===== -->
      <div
        id="booking-success"
        class="hidden rounded-3xl border border-success/30 bg-success/[0.06] p-10 text-center"
      >
        <div
          class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-success text-3xl text-success-content"
        >
          ✓
        </div>
        <h2 class="font-display text-2xl font-bold leading-tight">
          รับคำจองแล้ว
        </h2>
        <p class="mt-3 text-base text-base-content/80">
          เก็บ reference number ไว้ ถ้าทัก LINE OA ก่อน 24 ชม. พิมพ์ reference นี้ ปันจะเปิดเคสของคุณได้เร็วขึ้น
        </p>
        <div
          class="mx-auto mt-6 inline-flex items-center gap-3 rounded-xl border border-base-content/15 bg-base-100 px-5 py-3 font-mono text-lg font-bold"
        >
          <span id="booking-ref">—</span>
          <button
            id="booking-copy-ref"
            type="button"
            class="btn btn-ghost btn-sm"
            aria-label="Copy reference"
          >
            Copy
          </button>
        </div>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <a
            href={SITE.social.line}
            target="_blank"
            rel="noopener"
            class="btn btn-lg gap-2 border-none font-bold text-white hover:opacity-90 active:opacity-80"
            style="background: #06C755;"
          >
            <img src="/line-logo.png" alt="" class="h-6 w-6 shrink-0" aria-hidden="true" />
            ทักมา LINE OA ต่อ →
          </a>
          <a href="/" class="btn btn-lg btn-outline">
            กลับหน้าแรก
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pkg-card:has(.pkg-input:checked) {
    border-color: var(--pkg-accent);
    background: color-mix(in oklch, var(--pkg-accent) 10%, transparent);
  }
  .pkg-card:has(.pkg-input:checked) .pkg-dot {
    border-color: var(--pkg-accent);
    background: radial-gradient(circle, var(--pkg-accent) 0 55%, transparent 60%);
    box-shadow: 0 0 0 2px color-mix(in oklch, var(--pkg-accent) 20%, transparent);
  }
  .pkg-card:has(.pkg-input:checked) .pkg-price {
    color: var(--pkg-accent);
  }
  .pkg-card:hover {
    border-color: color-mix(in oklch, var(--pkg-accent) 40%, transparent);
  }
</style>

<script is:inline define:vars={{ pkgLookupJson }}>
  window.__PKG_LOOKUP__ = JSON.parse(pkgLookupJson);
</script>
<script>
  interface BookingPayload {
    [key: string]: unknown;
    _meta: {
      reference: string;
      submitted_at: string;
      user_agent: string;
      referrer: string | null;
      path: string;
      initial_package: string | null;
    };
  }

  const form = document.getElementById('booking-form') as HTMLFormElement | null;
  const success = document.getElementById('booking-success');
  const refNode = document.getElementById('booking-ref');
  const copyBtn = document.getElementById('booking-copy-ref') as HTMLButtonElement | null;
  const errPackages = document.getElementById('err-packages');

  // Pre-select package(s) from ?package= and ?bundle= query params
  const params = new URLSearchParams(window.location.search);
  const initialPkg = params.get('package');
  const bundle = params.get('bundle');

  // bundle=day1-day2 → pre-select both ai-workshop + ai-workshop-advance
  if (bundle === 'day1-day2') {
    ['ai-workshop', 'ai-workshop-advance'].forEach((slug) => {
      const el = document.querySelector<HTMLInputElement>(
        `.pkg-card[data-pkg="${CSS.escape(slug)}"] .pkg-input`
      );
      if (el) el.checked = true;
    });
    document.querySelector('.pkg-card[data-pkg="ai-workshop"]')
      ?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  } else if (initialPkg) {
    const preselect = document.querySelector<HTMLInputElement>(
      `.pkg-card[data-pkg="${CSS.escape(initialPkg)}"] .pkg-input`
    );
    if (preselect) {
      preselect.checked = true;
      preselect.closest('.pkg-card')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function makeReference(): string {
    const stamp = new Date()
      .toISOString()
      .replace(/[-:T.Z]/g, '')
      .slice(0, 12);
    const rand = Math.random().toString(36).slice(2, 6).toUpperCase();
    return `PN-BK-${stamp}-${rand}`;
  }

  function journalPayload(payload: BookingPayload): void {
    try {
      const raw = localStorage.getItem('pn_booking_journal');
      const journal: BookingPayload[] = raw ? JSON.parse(raw) : [];
      journal.unshift(payload);
      localStorage.setItem('pn_booking_journal', JSON.stringify(journal.slice(0, 10)));
    } catch {
      /* non-fatal */
    }
  }

  const N8N_WEBHOOK = 'https://rnat.app.n8n.cloud/webhook/intake-form-v2';

  async function postToWebhook(payload: BookingPayload): Promise<'sent' | 'failed'> {
    const ctrl = new AbortController();
    const kill = setTimeout(() => ctrl.abort(), 10_000);
    try {
      const res = await fetch(N8N_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: ctrl.signal,
        keepalive: true,
      });
      clearTimeout(kill);
      return res.ok ? 'sent' : 'failed';
    } catch (err) {
      clearTimeout(kill);
      console.error('[booking-form] webhook error', err);
      return 'failed';
    }
  }

  const submitBtn = document.getElementById('btn-submit') as HTMLButtonElement | null;
  const submitBtnLabel = submitBtn?.textContent ?? '';

  /* ==== intl-tel-input init ================================================
   * Same validation setup as /intake-form. Accepts Thai formats like
   * 081-234-5678, 02-1234-5678, 0812345678 and international (+1 US, +65 SG).
   * On submit: block if iti.isValidNumber() === false, else normalize to E.164
   * so Sheet stores canonical +66XXXXXXXXX.
   */
  interface ItiInstance {
    isValidNumber(): boolean;
    getNumber(): string;
  }
  type ItiFactory = (el: HTMLInputElement, opts: Record<string, unknown>) => ItiInstance;
  let phoneIti: ItiInstance | null = null;
  const phoneInput = document.getElementById('b-phone') as HTMLInputElement | null;
  const phoneErr = document.getElementById('b-phone-err');

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error(`failed to load ${src}`));
      document.head.appendChild(s);
    });
  }

  (async () => {
    if (!phoneInput) return;
    try {
      await loadScript(
        'https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/js/intlTelInput.min.js'
      );
      const factory = (window as unknown as { intlTelInput: ItiFactory }).intlTelInput;
      phoneIti = factory(phoneInput, {
        initialCountry: 'th',
        countryOrder: ['th', 'us', 'sg', 'my', 'hk', 'jp', 'gb', 'au'],
        separateDialCode: true,
        autoPlaceholder: 'polite',
        nationalMode: true,
        loadUtilsOnInit:
          'https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/js/utils.js',
      });
    } catch (err) {
      console.error('[booking-form] intl-tel-input failed to load', err);
    }
  })();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const selectedPkgs = Array.from(
      form.querySelectorAll<HTMLInputElement>('.pkg-input:checked')
    ).map((el) => el.value);

    if (selectedPkgs.length === 0) {
      errPackages?.classList.remove('hidden');
      errPackages?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errPackages?.classList.add('hidden');

    if (!form.reportValidity()) return;

    // Phone validation
    if (phoneIti && phoneInput) {
      if (!phoneIti.isValidNumber()) {
        phoneErr?.classList.remove('hidden');
        phoneInput.focus();
        phoneInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      phoneErr?.classList.add('hidden');
      phoneInput.value = phoneIti.getNumber();
    }

    const formData = new FormData(form);

    // Build legacy-compatible `package` + `package_price` from selected slugs
    // so n8n/Telegram can render package name + price without mapping changes.
    const lookup = (window as unknown as {
      __PKG_LOOKUP__: { names: Record<string, string>; prices: Record<string, number> };
    }).__PKG_LOOKUP__;
    const pkgNames = selectedPkgs.map((s) => lookup.names[s] ?? s);
    const pkgPrices = selectedPkgs.map((s) =>
      (lookup.prices[s] ?? 0).toLocaleString('en-US')
    );

    const attr = (window as unknown as { pnAttribution?: Record<string, string> }).pnAttribution ?? {};

    const payload: BookingPayload = {
      source_page: 'booking-astro',
      booking_type: 'package-booking',
      package: pkgNames.join(', '),
      package_price: pkgPrices.join(', '),
      packages: selectedPkgs,
      utm_source:   attr.utm_source   ?? '',
      utm_medium:   attr.utm_medium   ?? '',
      utm_campaign: attr.utm_campaign ?? '',
      utm_content:  attr.utm_content  ?? '',
      utm_term:     attr.utm_term     ?? '',
      fbclid:       attr.fbclid       ?? '',
      ttclid:       attr.ttclid       ?? '',
      _meta: {
        reference: makeReference(),
        submitted_at: new Date().toISOString(),
        user_agent: navigator.userAgent,
        referrer: document.referrer || null,
        path: window.location.pathname,
        initial_package: initialPkg,
      },
    };

    formData.forEach((value, key) => {
      if (key === 'packages') return;
      if (payload[key]) {
        if (Array.isArray(payload[key])) {
          (payload[key] as unknown[]).push(value);
        } else {
          payload[key] = [payload[key], value];
        }
      } else {
        payload[key] = value;
      }
    });

    journalPayload(payload);

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังส่ง...';
    }

    const status = await postToWebhook(payload);
    (payload._meta as Record<string, unknown>).webhook_status = status;
    journalPayload(payload);

    (window as unknown as { plausible?: (...args: unknown[]) => void }).plausible?.(
      'Booking Submit',
      {
        props: {
          source: (payload.source as string) ?? 'unknown',
          packages: selectedPkgs.join('+'),
        },
      }
    );

    if (refNode) refNode.textContent = payload._meta.reference;

    form.classList.add('hidden');
    success?.classList.remove('hidden');
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.textContent = submitBtnLabel;
    }
    window.scrollTo({
      top: (success?.offsetTop ?? 0) - 80,
      behavior: 'smooth',
    });
  });

  copyBtn?.addEventListener('click', async () => {
    const ref = refNode?.textContent?.trim() ?? '';
    if (!ref || ref === '—') return;
    try {
      await navigator.clipboard.writeText(ref);
      const original = copyBtn.textContent;
      copyBtn.textContent = 'Copied ✓';
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 2000);
    } catch {
      /* clipboard blocked */
    }
  });
</script>
