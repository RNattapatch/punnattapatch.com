---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';

const title = 'ประเมินปัญหาทีมขาย';
const description =
  'แบบประเมินปัญหาทีมขาย 3 นาที — ผมอ่านเองทุกเคสและตอบกลับภายใน 2 วันทำการ พร้อมบอกว่าคุณเหมาะกับ package ไหน';

const positions = [
  'CEO / เจ้าของกิจการ',
  'Managing Director',
  'Sales Director',
  'Sales Manager',
  'Marketing Manager',
  'Operations Manager',
  'อื่นๆ',
];

const teamSizes = [
  '1-2 คน (เจ้าของ + ผู้ช่วย)',
  '3-5 คน',
  '6-10 คน',
  '11-20 คน',
  '20+ คน',
];

const revenueBands = [
  'น้อยกว่า 10M THB/ปี',
  '10-30M THB/ปี',
  '30-100M THB/ปี',
  '100-200M THB/ปี',
  '200M+ THB/ปี',
];

const painPoints = [
  'ทีมเสียเวลากับงาน manual ซ้ำๆ (report, follow-up, data entry)',
  'เจ้าของแบกยอดขายเอง ทีมไม่ run เอง',
  'ไม่มีระบบ KPI / Commission ที่ fair + วัดได้',
  'ทีมปิดการขายด้วยลดราคาเป็นหลัก',
  'เคยจ่าย workshop แล้วทีมเลิกใช้ภายใน 2 สัปดาห์',
  'อยากเริ่มใช้ AI แต่ไม่รู้จะเริ่มจากไหน',
];

const aiSources = [
  { value: 'chatgpt', label: 'ChatGPT (รวม GPT-4o, o1)' },
  { value: 'claude', label: 'Claude (claude.ai, Claude API)' },
  { value: 'gemini', label: 'Gemini / Google AI Overview' },
  { value: 'perplexity', label: 'Perplexity' },
  { value: 'ai-search-other', label: 'AI Search อื่น' },
  { value: 'tiktok', label: 'TikTok (@pun_nattapatch)' },
  { value: 'instagram', label: 'Instagram (@pun_nattapatch)' },
  { value: 'facebook', label: 'Facebook / กลุ่ม' },
  { value: 'google-search', label: 'Google (ผลลัพธ์ปกติ)' },
  { value: 'referral', label: 'เพื่อน / ลูกค้าเก่าแนะนำ' },
  { value: 'event', label: 'งานสัมมนา / event' },
  { value: 'other', label: 'อื่นๆ' },
];

const timelines = [
  'เริ่มภายใน 2 สัปดาห์',
  'เริ่มภายใน 1 เดือน',
  'เริ่มภายใน 2-3 เดือน',
  'ยังไม่มีกำหนด — ศึกษาข้อมูลก่อน',
];

const budgets = [
  '< ฿50,000',
  '฿50,000 - ฿100,000',
  '฿100,000 - ฿300,000',
  '฿300,000+',
  'ยังไม่ได้ตั้ง budget',
];
---

<BaseLayout
  title={title}
  description={description}
  schema={{
    types: ['WebPage', 'BreadcrumbList'],
    title,
    description,
    breadcrumbs: [
      { name: 'หน้าแรก', url: SITE.url },
      { name: 'ประเมินปัญหา', url: `${SITE.url}/intake-form` },
    ],
  }}
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/css/intlTelInput.css"
    />
    <style>
      /* Dark-theme overrides for intl-tel-input v24 */
      .iti { width: 100%; display: block; }
      .iti__dropdown-content {
        background: var(--color-base-100) !important;
        color: var(--color-base-content) !important;
        border: 1px solid rgb(255 255 255 / 0.15) !important;
        border-radius: 0.5rem;
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.6);
      }
      .iti__country-list {
        background: var(--color-base-100) !important;
        color: var(--color-base-content) !important;
        max-height: 260px;
      }
      .iti__country {
        padding: 10px 12px;
        color: var(--color-base-content) !important;
      }
      .iti__country-name {
        color: var(--color-base-content) !important;
      }
      .iti__dial-code {
        color: color-mix(in oklch, var(--color-base-content) 65%, transparent) !important;
      }
      .iti__country.iti__highlight,
      .iti__country:hover {
        background: color-mix(in oklch, var(--color-secondary) 20%, transparent) !important;
      }
      .iti__selected-country,
      .iti__selected-country-primary {
        background: rgb(255 255 255 / 0.03) !important;
      }
      .iti__selected-country:hover,
      .iti__selected-country-primary:hover {
        background: rgb(255 255 255 / 0.06) !important;
      }
      .iti--separate-dial-code .iti__selected-dial-code {
        color: var(--color-base-content) !important;
      }
      .iti__search-input {
        background: rgb(255 255 255 / 0.05) !important;
        color: var(--color-base-content) !important;
        border: 1px solid rgb(255 255 255 / 0.15) !important;
        padding: 8px 12px;
      }
      .iti__search-input::placeholder {
        color: color-mix(in oklch, var(--color-base-content) 50%, transparent);
      }
      .iti__divider {
        border-bottom-color: rgb(255 255 255 / 0.1) !important;
      }
    </style>
  </Fragment>

  <section class="px-4 py-16 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-widest text-base-content/50">Assessment</p>
      <h1 class="mt-3 font-display text-3xl font-bold tracking-tight md:text-4xl">
        {title}
      </h1>
      <p class="mt-4 text-lg text-base-content/75">
        ใช้เวลา 3 นาที — ผมอ่านทุกเคสเองและตอบกลับภายใน 2 วันทำการ
      </p>

      <form
        id="intake-form"
        class="mt-10 space-y-8"
        novalidate
      >
        <!-- ===== Contact ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">1. ติดต่อ</legend>

          <div class="form-control">
            <label for="name" class="label">
              <span class="label-text font-medium">ชื่อ-นามสกุล *</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              class="input input-bordered w-full"
              placeholder="ปัน ณัฐพัชร์"
            />
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="form-control">
              <label for="email" class="label">
                <span class="label-text font-medium">อีเมล *</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="input input-bordered w-full"
                placeholder="you@company.co.th"
              />
            </div>

            <div class="form-control">
              <label for="phone" class="label">
                <span class="label-text font-medium">เบอร์โทร *</span>
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                class="input input-bordered w-full"
                placeholder="812345678"
              />
              <p id="phone-err" class="mt-1.5 hidden text-xs font-medium text-error">
                กรุณาใส่เบอร์โทรให้ถูก format (เลือกประเทศจาก dropdown ก่อน)
              </p>
            </div>
          </div>

          <div class="form-control">
            <label for="line" class="label">
              <span class="label-text font-medium">LINE ID (optional)</span>
            </label>
            <input
              id="line"
              name="line"
              type="text"
              class="input input-bordered w-full"
              placeholder="@punnattapatch หรือ LINE ID"
            />
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="form-control">
              <label for="company" class="label">
                <span class="label-text font-medium">ชื่อบริษัท *</span>
              </label>
              <input
                id="company"
                name="company"
                type="text"
                required
                class="input input-bordered w-full"
              />
            </div>

            <div class="form-control">
              <label for="position" class="label">
                <span class="label-text font-medium">ตำแหน่ง *</span>
              </label>
              <select
                id="position"
                name="position"
                required
                class="select select-bordered w-full"
              >
                <option value="">เลือก...</option>
                {positions.map((p) => <option value={p}>{p}</option>)}
              </select>
            </div>
          </div>

          <div class="form-control">
            <label for="industry" class="label">
              <span class="label-text font-medium">อุตสาหกรรม</span>
            </label>
            <input
              id="industry"
              name="industry"
              type="text"
              class="input input-bordered w-full"
              placeholder="เช่น วัสดุก่อสร้าง, ที่พัก, ค้าปลีก"
            />
          </div>
        </fieldset>

        <!-- ===== Team context ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">2. Context ทีมขาย</legend>

          <div class="form-control">
            <label for="team-size" class="label">
              <span class="label-text font-medium">ขนาดทีมขาย *</span>
            </label>
            <select
              id="team-size"
              name="teamSize"
              required
              class="select select-bordered w-full"
            >
              <option value="">เลือก...</option>
              {teamSizes.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="form-control">
            <label for="revenue" class="label">
              <span class="label-text font-medium">รายได้บริษัทต่อปี</span>
            </label>
            <select id="revenue" name="revenue" class="select select-bordered w-full">
              <option value="">ไม่ระบุ</option>
              {revenueBands.map((r) => <option value={r}>{r}</option>)}
            </select>
          </div>

          <div class="form-control">
            <span class="label">
              <span class="label-text font-medium">ปัญหาหลักที่เจอ (เลือกได้หลายข้อ) *</span>
            </span>
            <div class="space-y-2">
              {
                painPoints.map((p) => (
                  <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-base-content/10 p-3 transition hover:bg-base-200/50">
                    <input
                      type="checkbox"
                      name="problems"
                      value={p}
                      class="checkbox checkbox-sm mt-0.5"
                    />
                    <span class="text-sm">{p}</span>
                  </label>
                ))
              }
            </div>
          </div>

          <div class="form-control">
            <label for="goal" class="label">
              <span class="label-text font-medium">
                เป้าหมายใน 6 เดือนข้างหน้า (1-2 ประโยค)
              </span>
            </label>
            <textarea
              id="goal"
              name="message"
              rows="3"
              class="textarea textarea-bordered w-full"
              placeholder="เช่น เพิ่มยอดขาย 30% โดยไม่จ้างเซลล์เพิ่ม / ลดเวลาทีมทำ manual report จาก 10 ชม. เหลือ 1 ชม."
            ></textarea>
          </div>
        </fieldset>

        <!-- ===== Fit & timing ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-base-content/10 bg-base-100 p-6">
          <legend class="px-2 font-display text-lg font-bold">3. Timing + Budget</legend>

          <div class="form-control">
            <label for="timeline" class="label">
              <span class="label-text font-medium">อยากเริ่มเมื่อไหร่ *</span>
            </label>
            <select id="timeline" name="timeline" required class="select select-bordered w-full">
              <option value="">เลือก...</option>
              {timelines.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="form-control">
            <label for="budget" class="label">
              <span class="label-text font-medium">Budget โดยประมาณ</span>
            </label>
            <select id="budget" name="budget" class="select select-bordered w-full">
              <option value="">ยังไม่ระบุ</option>
              {budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>
        </fieldset>

        <!-- ===== AI source (attribution) ===== -->
        <fieldset class="space-y-5 rounded-2xl border border-secondary/30 bg-secondary/5 p-6">
          <legend class="px-2 font-display text-lg font-bold">4. คุณเจอผมจากไหน</legend>
          <p class="-mt-3 text-sm text-base-content/70">
            ข้อมูลนี้ช่วยผมรู้ว่า AI รู้จักผมมากแค่ไหน ใช้ในการประเมิน content strategy ของเว็บ
          </p>

          <div class="form-control">
            <label for="source" class="label">
              <span class="label-text font-medium">เจอเว็บนี้ผ่าน *</span>
            </label>
            <select
              id="source"
              name="source"
              required
              class="select select-bordered w-full"
            >
              <option value="">เลือก...</option>
              {aiSources.map((s) => <option value={s.value}>{s.label}</option>)}
            </select>
          </div>

          <div class="form-control">
            <label for="source-note" class="label">
              <span class="label-text font-medium">
                ถ้าเป็น AI chat: ขอ screenshot / ข้อความที่ AI ตอบ (optional)
              </span>
            </label>
            <textarea
              id="source-note"
              name="comment"
              rows="3"
              class="textarea textarea-bordered w-full"
              placeholder="เช่น 'ถาม ChatGPT ว่าที่ปรึกษา AI ขาย SME ไทยมีใครบ้าง แล้วเจอผม' — ช่วยผมรู้ว่า AEO ทำงานไหม"
            ></textarea>
          </div>
        </fieldset>

        <!-- ===== Submit ===== -->
        <div class="space-y-4 rounded-2xl border border-base-content/10 bg-base-200/40 p-6">
          <label class="flex cursor-pointer items-start gap-3">
            <input type="checkbox" name="consent" required class="checkbox mt-1" />
            <span class="text-sm text-base-content/80">
              ยินยอมให้ Pun Nattapatch เก็บข้อมูลตามแบบฟอร์มเพื่อวัตถุประสงค์ในการตอบกลับและประเมินเคสเท่านั้น ไม่ส่งต่อให้บุคคลที่สาม
              (PDPA compliance) *
            </span>
          </label>

          <button
            type="submit"
            class="btn btn-lg w-full bg-secondary text-secondary-content shadow-lg shadow-secondary/25 hover:bg-secondary/90"
          >
            ส่งแบบประเมิน
          </button>

          <p class="text-center text-xs text-base-content/60">
            ปันอ่านเองทุกเคสและตอบกลับภายใน 2 วันทำการ · ไม่มี mass email
          </p>
        </div>
      </form>

      <div
        id="intake-success"
        class="hidden mt-8 rounded-2xl border border-success/30 bg-success/10 p-8 text-center"
      >
        <div
          class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-success text-2xl text-success-content"
        >
          ✓
        </div>
        <p class="mt-4 font-display text-2xl font-bold text-base-content">
          บันทึกแบบประเมินเรียบร้อย
        </p>
        <p class="mt-3 text-base text-base-content/80">
          ขั้นตอนสุดท้าย — <strong class="text-secondary">ทักหาผมใน LINE</strong>
          พร้อมแนบ Reference ด้านล่าง (ผมจะดึง context ของคุณมาตอบกลับได้เร็วที่สุด)
        </p>
        <p class="mt-5">
          <span class="text-xs uppercase tracking-widest text-base-content/50">Reference</span>
          <br />
          <code
            id="intake-ref"
            class="mt-2 inline-block rounded-lg bg-base-200 px-4 py-2 font-mono text-base font-bold text-base-content"
          >—</code>
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href={SITE.social.line}
            rel="noopener"
            target="_blank"
            class="btn btn-lg bg-secondary text-secondary-content shadow-lg shadow-secondary/25 hover:bg-secondary/90"
          >
            ทักใน LINE OA →
          </a>
          <button
            id="intake-copy-ref"
            type="button"
            class="btn btn-lg btn-outline"
          >
            คัดลอก Reference
          </button>
        </div>
        <p class="mt-6 text-xs text-base-content/60">
          ตอบกลับภายใน 2 วันทำการ · ไม่มี mass email · ข้อมูลไม่ถูกส่งต่อบุคคลที่สาม
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  /**
   * Intake form handler.
   *
   * Current behaviour (shippable v1):
   *  - Serializes the form, stamps a reference token, logs to the browser
   *    console (for dev + for users to screenshot if they want proof of
   *    submission), then reveals a success panel that directs the user to
   *    DM in LINE OA with the reference. LINE is Pun's primary inbound
   *    channel, so every submission becomes an actionable lead today.
   *
   *  - A localStorage journal keeps the last 10 submissions so they aren't
   *    lost if the user closes the tab before DMing.
   *
   * Phase 2 upgrade path (already wired in payload shape):
   *  - POST payload to a Google Apps Script webhook, append to a Sheet,
   *    and fire a Telegram alert to Pun. The reference token is reused so
   *    inbound LINE messages can be correlated to the form submission.
   */

  interface IntakePayload {
    [key: string]: unknown;
    _meta: {
      reference: string;
      submitted_at: string;
      user_agent: string;
      referrer: string | null;
      path: string;
    };
  }

  const form = document.getElementById('intake-form') as HTMLFormElement | null;
  const success = document.getElementById('intake-success');
  const refNode = document.getElementById('intake-ref');
  const copyBtn = document.getElementById('intake-copy-ref') as HTMLButtonElement | null;

  function makeReference(): string {
    const stamp = new Date()
      .toISOString()
      .replace(/[-:T.Z]/g, '')
      .slice(0, 12); // YYYYMMDDHHMM
    const rand = Math.random().toString(36).slice(2, 6).toUpperCase();
    return `PN-${stamp}-${rand}`;
  }

  function journalPayload(payload: IntakePayload): void {
    try {
      const raw = localStorage.getItem('pn_intake_journal');
      const journal: IntakePayload[] = raw ? JSON.parse(raw) : [];
      journal.unshift(payload);
      localStorage.setItem('pn_intake_journal', JSON.stringify(journal.slice(0, 10)));
    } catch {
      /* localStorage quota or disabled — non-fatal */
    }
  }

  const N8N_WEBHOOK = 'https://rnat.app.n8n.cloud/webhook/intake-form-v2';

  async function postToWebhook(payload: IntakePayload): Promise<'sent' | 'failed'> {
    const ctrl = new AbortController();
    const kill = setTimeout(() => ctrl.abort(), 10_000);
    try {
      const res = await fetch(N8N_WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
        signal: ctrl.signal,
        keepalive: true,
      });
      clearTimeout(kill);
      return res.ok ? 'sent' : 'failed';
    } catch (err) {
      clearTimeout(kill);
      console.error('[intake-form] webhook error', err);
      return 'failed';
    }
  }

  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const submitBtnLabel = submitBtn?.textContent ?? '';

  /* ==== intl-tel-input init (loaded async from CDN) ========================
   * Wires phone field to libphonenumber validation so "test by pun" or free
   * text is blocked. Supports Thai native formats (081-234-5678, 02-1234-5678,
   * 0812345678, +66-81-234-5678) + any international number. On valid submit,
   * value is normalized to E.164 (+66812345678) before POSTing to n8n so Sheet
   * stores a canonical number regardless of how the user typed it.
   */
  interface ItiInstance {
    isValidNumber(): boolean;
    getNumber(): string;
    getValidationError(): number;
  }
  type ItiFactory = (el: HTMLInputElement, opts: Record<string, unknown>) => ItiInstance;
  let phoneIti: ItiInstance | null = null;
  const phoneInput = document.getElementById('phone') as HTMLInputElement | null;
  const phoneErr = document.getElementById('phone-err');

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const s = document.createElement('script');
      s.src = src;
      s.onload = () => resolve();
      s.onerror = () => reject(new Error(`failed to load ${src}`));
      document.head.appendChild(s);
    });
  }

  (async () => {
    if (!phoneInput) return;
    try {
      await loadScript(
        'https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/js/intlTelInput.min.js'
      );
      const factory = (window as unknown as { intlTelInput: ItiFactory }).intlTelInput;
      phoneIti = factory(phoneInput, {
        initialCountry: 'th',
        // In v24+, preferredCountries is deprecated — countryOrder reorders the
        // entire list. Placing TH + regional neighbours first, then US/UK, then
        // rest of the world alphabetically keeps the common picks reachable
        // without scrolling while still showing every country.
        countryOrder: ['th', 'us', 'sg', 'my', 'hk', 'jp', 'gb', 'au'],
        separateDialCode: true,
        autoPlaceholder: 'polite',
        nationalMode: true,
        loadUtilsOnInit:
          'https://cdn.jsdelivr.net/npm/intl-tel-input@24.6.0/build/js/utils.js',
      });
    } catch (err) {
      console.error('[intake-form] intl-tel-input failed to load', err);
      /* Silent fallback — native HTML5 tel validation still applies */
    }
  })();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;

    // Phone validation — gate submission if invalid number
    if (phoneIti && phoneInput) {
      if (!phoneIti.isValidNumber()) {
        phoneErr?.classList.remove('hidden');
        phoneInput.focus();
        phoneInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      phoneErr?.classList.add('hidden');
      // Normalize to E.164 before serialization so CRM Sheet stores canonical form
      phoneInput.value = phoneIti.getNumber();
    }

    const formData = new FormData(form);
    const payload: IntakePayload = {
      source_page: 'intake-form-astro',
      _meta: {
        reference: makeReference(),
        submitted_at: new Date().toISOString(),
        user_agent: navigator.userAgent,
        referrer: document.referrer || null,
        path: window.location.pathname,
      },
    };

    formData.forEach((value, key) => {
      if (payload[key]) {
        if (Array.isArray(payload[key])) {
          (payload[key] as unknown[]).push(value);
        } else {
          payload[key] = [payload[key], value];
        }
      } else {
        payload[key] = value;
      }
    });

    journalPayload(payload);

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'กำลังส่ง...';
    }

    const status = await postToWebhook(payload);
    (payload._meta as Record<string, unknown>).webhook_status = status;
    journalPayload(payload);

    if (refNode) refNode.textContent = payload._meta.reference;

    form.classList.add('hidden');
    success?.classList.remove('hidden');
    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.textContent = submitBtnLabel;
    }
    window.scrollTo({
      top: (success?.offsetTop ?? 0) - 80,
      behavior: 'smooth',
    });
  });

  copyBtn?.addEventListener('click', async () => {
    const ref = refNode?.textContent?.trim() ?? '';
    if (!ref || ref === '—') return;
    try {
      await navigator.clipboard.writeText(ref);
      const original = copyBtn.textContent;
      copyBtn.textContent = 'คัดลอกแล้ว ✓';
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 2000);
    } catch {
      /* clipboard blocked — user can still highlight + copy manually */
    }
  });
</script>
