---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import PinGate from '../components/dashboard/PinGate.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';
import DashboardHeader from '../components/dashboard/DashboardHeader.astro';
import KpiGrid from '../components/dashboard/KpiGrid.astro';
import PipelineDonut from '../components/dashboard/PipelineDonut.astro';
import IndustryBar from '../components/dashboard/IndustryBar.astro';
import SalesTrend from '../components/dashboard/SalesTrend.astro';
import SourceDonut from '../components/dashboard/SourceDonut.astro';
import TodayPanel from '../components/dashboard/TodayPanel.astro';
import KanbanBoard from '../components/dashboard/KanbanBoard.astro';
import LeadList from '../components/dashboard/LeadList.astro';
import TabBar from '../components/dashboard/TabBar.astro';
import ExpenseTab from '../components/dashboard/ExpenseTab.astro';
import FabAddLead from '../components/dashboard/FabAddLead.astro';
import AddExpenseModal from '../components/dashboard/AddExpenseModal.astro';
import LeadDetailDrawer from '../components/dashboard/LeadDetailDrawer.astro';
import AddLeadModal from '../components/dashboard/AddLeadModal.astro';
import EditDealModal from '../components/dashboard/EditDealModal.astro';
import Toast from '../components/dashboard/Toast.astro';
---
<DashboardLayout>
  <PinGate />

  <!-- DaisyUI drawer layout (sidebar left on desktop, hamburger on mobile) -->
  <div id="dashboard-app" class="hidden">
    <div class="drawer lg:drawer-open">
      <input id="dash-sidebar-toggle" type="checkbox" class="drawer-toggle" />

      <!-- Main content area -->
      <div class="drawer-content flex flex-col min-h-screen">
        <DashboardHeader />

        <main class="flex-1 p-4 lg:p-6 max-w-7xl w-full mx-auto space-y-6 pb-32 lg:pb-8">

          <!-- Hero banner (command center) -->
          <section class="rounded-3xl p-5 md:p-6 text-white flex flex-col md:flex-row md:items-center gap-4" style="background-color:var(--color-brand-navy);">
            <div class="flex-1 min-w-0">
              <div class="inline-flex rounded-full bg-white/10 px-3 py-1 text-xs font-medium mb-2">Internal Workspace · Private</div>
              <h2 class="font-display text-2xl md:text-3xl font-bold leading-tight">Personal Business Command Center</h2>
              <p class="mt-1 text-sm text-white/60 max-w-xl">Track sales, leads, follow-ups, expenses ทุกอย่างในหน้าเดียว</p>
            </div>
            <div id="hero-today" class="rounded-2xl border border-white/10 bg-white/10 p-4 text-sm shrink-0 min-w-[180px]">
              <p class="font-semibold text-white">Today's Focus</p>
              <p id="hero-focus" class="mt-1 text-white/60 text-xs">—</p>
            </div>
          </section>

          <!-- KPI grid (8 cards) -->
          <KpiGrid />

          <!-- Tab switcher -->
          <TabBar />

          <!-- Leads view -->
          <div id="leads-view">
            <!-- Charts row -->
            <section class="grid gap-3 md:grid-cols-2 mb-4">
              <PipelineDonut />
              <IndustryBar />
            </section>
            <section class="grid gap-3 md:grid-cols-2 mb-4">
              <SalesTrend />
              <SourceDonut />
            </section>

            <!-- Today panel -->
            <TodayPanel />

            <!-- Kanban pipeline -->
            <KanbanBoard />

            <!-- Full lead list -->
            <LeadList />
          </div>

          <!-- Expenses view -->
          <div id="expenses-view" class="hidden">
            <ExpenseTab />
          </div>
        </main>
      </div>

      <!-- Sidebar -->
      <DashboardSidebar />
    </div>

    <!-- FAB (mobile) -->
    <FabAddLead />
  </div>

  <!-- Modals + overlays (outside drawer so z-index is correct) -->
  <LeadDetailDrawer />
  <AddLeadModal />
  <EditDealModal />
  <AddExpenseModal />
  <Toast />

  <script>
    import { initDashboard, subscribe, getState } from '../scripts/dashboard/store';
    initDashboard();

    function renderHeroFocus() {
      const { today, kpis } = getState();
      const focus = document.getElementById('hero-focus');
      if (!focus) return;
      if (!kpis) { focus.textContent = '—'; return; }
      const parts: string[] = [];
      if (today.length) parts.push(`Follow-up ${today.length} lead`);
      if (kpis.pipeline.proposal_sent) parts.push(`${kpis.pipeline.proposal_sent} proposal pending`);
      if (!parts.length) parts.push('ทุกอย่าง on track 🎉');
      focus.textContent = parts.join(' · ');
    }
    renderHeroFocus();
    subscribe(renderHeroFocus);
  </script>
</DashboardLayout>
