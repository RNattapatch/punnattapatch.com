---
import '../styles/global.css';
---
<!doctype html>
<html lang="th" data-theme="pundark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,interactive-widget=resizes-content" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#072b4e" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Dashboard — Pun</title>
    <style>
      :root {
        --font-brand: "Sukhumvit Set", Tahoma, "Helvetica Neue", sans-serif;
      }
      html, body {
        font-family: var(--font-brand);
      }
      .font-display {
        font-family: var(--font-brand);
      }
      button, .btn, .card, input, textarea, select, .badge, .chip {
        font-family: inherit;
      }
      body {
        min-height: 100dvh;
        background: var(--color-base-100);
        color: var(--color-base-content);
      }
      .tap-44 {
        min-width: 44px;
        min-height: 44px;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
