---
import '../styles/global.css';
import { SITE, cleanUrl } from '../data/site';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import type { ComponentProps } from 'astro/types';

type SchemaProps = ComponentProps<typeof Schema>;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: SchemaProps;
}

const {
  title = SITE.titleDefault,
  description = SITE.description,
  canonical = cleanUrl(Astro.url),
  ogImage = `${SITE.url}/og-image.jpg`,
  noindex = false,
  schema = { type: 'WebPage' as const },
} = Astro.props;

const fullTitle = title === SITE.titleDefault ? title : `${title} · ${SITE.nameTh}`;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#072b4e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fdfaf4" media="(prefers-color-scheme: light)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Bai Jamjuree (display) + Sarabun (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Load fonts non-blocking: preload as stylesheet, then flip to stylesheet
      on load. Fallback to synchronous <noscript> for users with JS disabled.
      Saves ~800ms of render-blocking time in production.
    -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700;800&display=swap"
      />
    </noscript>

    <!-- AI discovery signal (announces llms.txt presence) -->
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />

    <!-- Plausible Analytics — proxied through pl.punnattapatch.com to bypass
         DNS-level filters (Pi-hole, NextDNS), Safari ITP, and Brave Shields.
         First-party domain = counts visitors that would otherwise be dropped.
         Worker config: input-to-agent/cloudflare-worker-plausible-proxy.js

         Custom events fired via window.plausible():
           - 'Intake Submit'  — /intake-form submission
           - 'Booking Submit' — /booking submission
           - 'BOSI Complete'  — /bosi-dna-quiz reached result
    -->
    <script is:inline async src="https://pl.punnattapatch.com/js/pa-py-NKga-B2dlJColCdo-p.js"></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
      window.plausible.init = window.plausible.init || function (i) { window.plausible.o = i || {}; };
      window.plausible.init({ endpoint: 'https://pl.punnattapatch.com/api/event' });
    </script>

    <!-- TikTok Pixel — fires PageView on every page.
         Pixel ID: D7KBIH3C77UE6C4V7ETG (punnattapatch-web)
         ViewContent + CompleteRegistration fired elsewhere (see below + thank-you.astro).
         Server-side CAPI dedupe via event_id handled by n8n workflow intake-form-v2. -->
    <script is:inline>
      !function (w, d, t) {
        w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=["page","track","identify","instances","debug","on","off","once","ready","alias","group","enableCookie","disableCookie","holdConsent","revokeConsent","grantConsent"],ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e},ttq.load=function(e,n){var r="https://analytics.tiktok.com/i18n/pixel/events.js",o=n&&n.partner;ttq._i=ttq._i||{},ttq._i[e]=[],ttq._i[e]._u=r,ttq._t=ttq._t||{},ttq._t[e]=+new Date,ttq._o=ttq._o||{},ttq._o[e]=n||{};n=document.createElement("script");n.type="text/javascript",n.async=!0,n.src=r+"?sdkid="+e+"&lib="+t;e=document.getElementsByTagName("script")[0];e.parentNode.insertBefore(n,e)};
        ttq.load('D7KBIH3C77UE6C4V7ETG');
        ttq.page();
      }(window, document, 'ttq');
    </script>

    <Schema {...schema} />

    <!-- Per-page head injection (e.g. intl-tel-input CSS) -->
    <slot name="head" />
  </head>

  <body class="min-h-screen bg-base-100 font-body text-base-content">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-secondary focus:px-4 focus:py-2 focus:text-secondary-content"
    >
      ข้ามไปยังเนื้อหาหลัก
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!--
      UTM + click-ID capture · runs on every page
      Stashes attribution params (utm_*, fbclid, ttclid) to localStorage with
      14-day TTL so users who land via ad → browse → submit still carry source
      into the form payload. Populates hidden <input> fields on pages that
      declare them (e.g., intake-form). Defensive — must never break the page.
    -->
    <script is:inline>
      (function () {
        const ATTR_KEY = 'pn_attribution';
        const TTL_DAYS = 14;
        const UTM_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
        const CLICK_ID_KEYS = ['fbclid', 'ttclid'];

        try {
          const params = new URLSearchParams(window.location.search);
          const now = Date.now();

          let stored = null;
          try {
            const raw = localStorage.getItem(ATTR_KEY);
            if (raw) {
              const parsed = JSON.parse(raw);
              if (parsed && parsed.expires > now) stored = parsed;
            }
          } catch { /* localStorage blocked or corrupt */ }

          const fromUrl = {};
          [...UTM_KEYS, ...CLICK_ID_KEYS].forEach((k) => {
            const v = params.get(k);
            if (v) fromUrl[k] = v;
          });

          // Last-click attribution: URL params overwrite stored
          // No URL params → keep stored (within-session continuity)
          let attribution;
          if (Object.keys(fromUrl).length > 0) {
            attribution = {
              ...fromUrl,
              landing_page: window.location.pathname,
              first_seen: (stored && stored.first_seen) || new Date().toISOString(),
              last_seen: new Date().toISOString(),
              expires: now + TTL_DAYS * 24 * 60 * 60 * 1000,
            };
            try { localStorage.setItem(ATTR_KEY, JSON.stringify(attribution)); } catch {}
          } else {
            attribution = stored || {};
          }

          window.pnAttribution = attribution;

          [...UTM_KEYS, ...CLICK_ID_KEYS].forEach((k) => {
            const input = document.getElementById(k);
            if (input && attribution[k]) input.value = attribution[k];
          });
        } catch { /* defensive: UTM capture must never break page */ }
      })();
    </script>

    <!--
      TikTok ViewContent · fires on /services/* and /training/* landing pages.
      Uses path slug as content_id so ad reports can attribute conversions
      back to the specific service or training program the user viewed.
      CompleteRegistration fires separately on /thank-you (see thank-you.astro).
    -->
    <script is:inline>
      (function () {
        try {
          const path = window.location.pathname;
          const match = path.match(/^\/(services|training)\/([a-z0-9-]+)/i);
          if (!match) return;

          const contentId = match[2];
          const contentType = match[1] === 'services' ? 'service' : 'training';
          const contentName = (document.title || '').replace(/\s·\s.*$/, '');

          // ttq queues calls made before the script loads, so firing immediately is safe.
          if (window.ttq && typeof window.ttq.track === 'function') {
            window.ttq.track('ViewContent', {
              contents: [{ content_id: contentId, content_type: contentType, content_name: contentName }],
              value: 0,
              currency: 'THB',
            });
          }
        } catch { /* defensive: ViewContent tracking must never break page */ }
      })();
    </script>
  </body>
</html>
