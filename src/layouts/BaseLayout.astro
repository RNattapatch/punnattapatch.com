---
import '../styles/global.css';
import { SITE, cleanUrl } from '../data/site';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import type { ComponentProps } from 'astro/types';

type SchemaProps = ComponentProps<typeof Schema>;

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: SchemaProps;
}

const {
  title = SITE.titleDefault,
  description = SITE.description,
  canonical = cleanUrl(Astro.url),
  ogImage = `${SITE.url}/og-image.jpg`,
  noindex = false,
  schema = { type: 'WebPage' as const },
} = Astro.props;

const fullTitle = title === SITE.titleDefault ? title : `${title} · ${SITE.nameTh}`;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#072b4e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fdfaf4" media="(prefers-color-scheme: light)" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts: Bai Jamjuree (display) + Sarabun (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Load fonts non-blocking: preload as stylesheet, then flip to stylesheet
      on load. Fallback to synchronous <noscript> for users with JS disabled.
      Saves ~800ms of render-blocking time in production.
    -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700;800&display=swap"
      />
    </noscript>

    <!-- AI discovery signal (announces llms.txt presence) -->
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />

    <!-- Plausible Analytics — privacy-first, no cookies, GDPR-ok.
         `hash` enables #anchor + SPA pageview events. `outbound-links` tracks
         clicks on external links (LINE OA / social). Production domain only
         so local dev doesn't pollute stats.

         Custom events fired via window.plausible() from form submit handlers:
           - 'Intake Submit' — /intake-form submission
           - 'Booking Submit' — /booking submission
           - 'BOSI Complete' — bosi-dna-quiz reached result
    -->
    <script
      defer
      data-domain="punnattapatch.com"
      src="https://plausible.io/js/script.hash.outbound-links.js"
    ></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (window.plausible.q = window.plausible.q || []).push(arguments);
        };
    </script>

    <Schema {...schema} />

    <!-- Per-page head injection (e.g. intl-tel-input CSS) -->
    <slot name="head" />
  </head>

  <body class="min-h-screen bg-base-100 font-body text-base-content">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-secondary focus:px-4 focus:py-2 focus:text-secondary-content"
    >
      ข้ามไปยังเนื้อหาหลัก
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
